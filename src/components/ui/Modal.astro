---
import Button from "@/components/ui/Button.astro"

interface Props {
	id: string
	size?: "sm" | "md" | "lg" | "xl"
	class?: string
	closeOnOutsideClick?: boolean
	hideCloseButton?: boolean
	noPadding?: boolean
	noBorder?: boolean
}

const {
	id,
	size = "md",
	class: className = "",
	closeOnOutsideClick = true,
	hideCloseButton = false,
	noPadding = false,
	noBorder = false,
} = Astro.props

const sizeClasses = {
	sm: "sm:max-w-md",
	md: "sm:max-w-lg",
	lg: "sm:max-w-2xl",
	xl: "sm:max-w-4xl",
}
---

<dialog
	id={id}
	class={`modal-dialog outline-none fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0 max-h-[calc(100vh-4rem)] overflow-y-auto w-full max-w-[calc(100%-2rem)] rounded-3xl ${noBorder ? "" : "border border-forest/20"} bg-cream ${noPadding ? "" : "p-8"} shadow-[0_20px_60px_rgba(55,68,58,0.3)] backdrop:bg-forest/50 backdrop:backdrop-blur-sm ${sizeClasses[size]} ${className}`}
	data-modal
	data-close-on-outside-click={closeOnOutsideClick}
>
	<slot />

	{
		!hideCloseButton && (
			<Button
				data-modal-close
				class="modal-close text-sage hover:bg-sage/10 hover:text-forest absolute top-4 right-4 z-10 flex h-8 w-8 items-center justify-center rounded-full transition-all duration-300"
				variant="ghost"
				size="icon"
				aria-label="Cerrar modal"
				value="cancel"
			>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
					<line x1="18" y1="6" x2="6" y2="18" />
					<line x1="6" y1="6" x2="18" y2="18" />
				</svg>
			</Button>
		)
	}
</dialog>

<style>
	/* Animaciones de apertura/cierre */
	.modal-dialog {
		opacity: 0;
		transform: scale(0.95);
		transition:
			opacity 300ms ease-in-out,
			transform 300ms ease-in-out,
			overlay 300ms ease-in-out allow-discrete,
			display 300ms ease-in-out allow-discrete;
	}

	.modal-dialog[open] {
		opacity: 1;
		transform: scale(1);
	}

	/* Animación del backdrop */
	.modal-dialog::backdrop {
		opacity: 0;
		transition:
			opacity 300ms ease-in-out,
			overlay 300ms ease-in-out allow-discrete,
			display 300ms ease-in-out allow-discrete;
	}

	.modal-dialog[open]::backdrop {
		opacity: 1;
	}

	/* Soporte para animaciones de cierre en navegadores modernos */
	@starting-style {
		.modal-dialog[open] {
			opacity: 0;
			transform: scale(0.95);
		}

		.modal-dialog[open]::backdrop {
			opacity: 0;
		}
	}
</style>

<script>
	class ModalManager {
		constructor() {
			this.init()
		}

		init() {
			const modals = document.querySelectorAll<HTMLDialogElement>("[data-modal]")

			modals.forEach((modal) => {
				// Cerrar con botones de cerrar (todos los que tengan data-modal-close)
				const closeBtns = modal.querySelectorAll("[data-modal-close]")
				closeBtns.forEach((btn) => {
					btn.addEventListener("click", (e) => {
						e.preventDefault()
						this.close(modal.id)
					})
				})

				// Cerrar al hacer click en el backdrop
				modal.addEventListener("click", (e) => {
					const closeOnOutsideClick = modal.dataset.closeOnOutsideClick !== "false"
					if (!closeOnOutsideClick) return

					const rect = modal.getBoundingClientRect()
					const isInDialog =
						rect.top <= e.clientY &&
						e.clientY <= rect.top + rect.height &&
						rect.left <= e.clientX &&
						e.clientX <= rect.left + rect.width
					if (!isInDialog) {
						this.close(modal.id)
					}
				})

				// Escuchar botones con data-modal-action="close"
				const actionCloseBtns = modal.querySelectorAll('[data-modal-action="close"]')
				actionCloseBtns.forEach((btn) => {
					btn.addEventListener("click", () => this.close(modal.id))
				})

				// Eventos personalizados
				modal.addEventListener("close", () => {
					modal.dispatchEvent(new CustomEvent("modal:closed", { detail: { modalId: modal.id } }))
				})
			})
		}

		open(modalId: string) {
			const modal = document.getElementById(modalId) as HTMLDialogElement
			if (modal && !modal.open) {
				modal.showModal()
				modal.focus()
				modal.dispatchEvent(new CustomEvent("modal:opened", { detail: { modalId } }))
			}
		}

		close(modalId: string) {
			const modal = document.getElementById(modalId) as HTMLDialogElement
			if (modal && modal.open) {
				modal.close()
			}
		}

		toggle(modalId: string) {
			const modal = document.getElementById(modalId) as HTMLDialogElement
			if (modal?.open) {
				this.close(modalId)
			} else {
				this.open(modalId)
			}
		}
	}

	declare global {
		interface Window {
			modalManager: ModalManager
		}
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			window.modalManager = new ModalManager()
		})
	} else {
		window.modalManager = new ModalManager()
	}
</script>

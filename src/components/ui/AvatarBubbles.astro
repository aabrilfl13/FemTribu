---
interface AvatarItem {
	name: string
	image?: string
}

interface Props {
	items: AvatarItem[]
	class?: string
}

const { items, class: className = "" } = Astro.props
---

{
	items.length > 0 && (
		<div class={`flex -space-x-2 ${className}`}>
			{items.map((item) => (
				<div
					class="bg-cream relative h-8 w-8 overflow-hidden rounded-full border-2 border-white"
					title={item.name}
				>
					{item.image && (
						<img
							src={item.image}
							alt={item.name}
							class="h-full w-full object-cover"
							loading="lazy"
						/>
					)}
				</div>
			))}
		</div>
	)
}

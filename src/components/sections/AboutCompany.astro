---
// SVG icons matching lucide-react
const CheckIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`

const pillars = [
	{
		icon: "/images/icons/illustrations/ilustracion-negro_14.svg",
		title: "Ciencia",
		description: "Basado en evidencia científica actualizada y mi experiencia como matrona",
		color: "text-accent",
		bgColor: "bg-accent/10",
	},
	{
		icon: "/images/icons/illustrations/ilustracion-negro_04.svg",
		title: "Espiritualidad",
		description: "Conectando con tu esencia femenina y los ciclos naturales de la vida",
		color: "text-secondary",
		bgColor: "bg-secondary/10",
	},
	{
		icon: "/images/icons/illustrations/ilustracion-negro_02.svg",
		title: "Autocuidado",
		description: "Herramientas prácticas para cuidarte en cada etapa de tu camino",
		color: "text-coral",
		bgColor: "bg-coral/10",
	},
]

const keyPoints = [
	"Acompañamiento online y presencial en Valencia",
	"Todas las etapas: embarazo, parto, postparto, lactancia, menopausia",
	"Comunidad de mujeres que se apoyan",
]
---

<section id="sobre-femm-tribu" class="relative overflow-hidden py-24 lg:py-32">
	{/* Background decorations */}
	<div
		class="bg-coral-light/10 shape-organic absolute top-0 right-0 h-96 w-96 translate-x-1/2 -translate-y-1/2"
	>
	</div>
	<div
		class="bg-secondary/10 shape-blob absolute bottom-0 left-0 h-64 w-64 -translate-x-1/2 translate-y-1/2"
	>
	</div>

	<div class="relative z-10 container mx-auto px-4 lg:px-8">
		{/* FemmTribu Section - Main Focus */}
		<div class="mx-auto mb-16 max-w-4xl text-center lg:mb-20">
			<span
				class="bg-coral-light/30 text-primary mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm"
			>
				<img
					src="/images/icons/illustrations/ilustracion-negro_11.svg"
					alt="Plant icon"
					class="h-8 w-8"
				/>
				Sobre Femm tribu
			</span>
			<h2 class="font-display text-primary mb-6 text-4xl sm:text-5xl lg:text-6xl">
				¿Qué es{" "}
				<span class="text-accent">Femm</span>
				<span class="text-secondary">Tribu</span>?
			</h2>
			<p class="text-muted-foreground mx-auto mb-8 max-w-3xl text-lg lg:text-xl">
				Un espacio online creado por mujeres, para mujeres. Donde la <strong class="text-primary"
					>ciencia</strong
				> se encuentra con la <strong class="text-primary">espiritualidad</strong> para acompañarte en
				cada momento de tu vida.
			</p>

			{/* Three Pillars - Compact */}
			<div class="mb-8 flex flex-wrap justify-center gap-4">
				{
					pillars.map((pillar) => (
						<div
							class={`flex items-center gap-2 rounded-full px-5 py-3 ${pillar.bgColor} border-border/30 border`}
						>
							<pillar.icon class={`h-5 w-5 ${pillar.color}`} />
							<span class="text-primary font-medium">{pillar.title}</span>
						</div>
					))
				}
			</div>

			{/* Key Points */}
			<div class="mb-8 flex flex-wrap justify-center gap-3">
				{
					keyPoints.map((point) => (
						<div class="bg-muted/50 flex items-center gap-2 rounded-full px-4 py-2 text-sm">
							<span class="text-accent h-4 w-4 flex-shrink-0" set:html={CheckIcon} />
							<span class="text-muted-foreground">{point}</span>
						</div>
					))
				}
			</div>
		</div>
		{/* CTA */}
		<div class="mt-16 text-center">
			<a
				href="/sobre-mi"
				class="bg-accent text-cream font-body hover:bg-accent/90 hover:shadow-elegant rounded-full px-8 py-4 text-lg transition-all duration-300 hover:scale-105"
			>
				Conoce la historia completa <span aria-hidden="true">→</span>
			</a>
		</div>
	</div>
</section>

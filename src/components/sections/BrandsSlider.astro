---
import Marquee from "@/components/ui/Marquee.astro"

const brands = [
	{
		name: "Laura Jorge — Centro de nutrición, psicología y salud",
		logo: "/images/logos/laura-jorge/laura-jorge-logo.png",
		url: "https://laurajorgenutricion.com/",
	},
]
---

<section class="py-12 lg:py-16" data-animate="animate-fade-up" data-animate-duration="1s">
	<div class="container mx-auto px-4 lg:px-8">
		<p class="text-muted-foreground mb-8 text-center text-sm font-medium tracking-widest uppercase">
			Colaboramos con
		</p>
	</div>
	<Marquee time={40} gap={48} pauseOnHover>
		{
			brands.map((brand) => (
				<a
					href={brand.url}
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center justify-center px-4 transition-all duration-300 hover:scale-105"
					aria-label={`Visitar ${brand.name}`}
				>
					<img
						src={brand.logo}
						alt={`Logo ${brand.name}`}
						class="h-20 w-auto max-w-[200px] object-contain sm:h-22 md:h-25"
						loading="lazy"
					/>
				</a>
			))
		}
	</Marquee>
</section>

---
import { fade } from "astro:transitions"

import CalendarIcon from "@/assets/iconos/calendar.svg"
import InstagramIcon from "@/assets/iconos/instagram.svg"
import TikTokIcon from "@/assets/iconos/tiktok.svg"
import WhatsAppIcon from "@/assets/iconos/whatsapp.svg"

import Button from "../ui/Button.astro"

const images = ["/images/hands-together.webp"]

const description = "Matrona en Valencia y Online: Salud Femenina Integral"
---

<div id="home">
	<div class="background-overlay"></div>
	<div class="relative h-screen w-full overflow-hidden">
		{
			images.map((image, index) => (
				<img
					src={image}
					alt="Femm Tribu - Matrona Online y Salud Integral Femenina"
					class="absolute top-0 left-0 h-screen w-full object-cover transition-opacity duration-[2s] ease-in-out"
					class:list={{
						"opacity-100": index === 0,
						"opacity-0": index !== 0,
						"object-[38%_center] sm:object-center": image.includes("pregnant-woman"),
					}}
					data-index={index}
					transition:animate={fade()}
					loading={index === 0 ? "eager" : "lazy"}
					fetchpriority={index === 0 ? "high" : "low"}
					decoding={index === 0 ? "sync" : "async"}
				/>
			))
		}
	</div>
	<div
		class="absolute top-5 left-0 z-100 flex h-full w-full flex-col items-center justify-center px-4 text-center text-white"
	>
		<!-- Logo and Description grouped together -->
		<div class="mb-12 flex w-full flex-col items-center gap-1">
			<img
				src="/images/logos/logo_principal_fullcolor.svg"
				alt="Femm tribu Logo"
				class="logo"
				style="max-width: min(500px, 90vw); width: 100%; height: auto;"
			/>
			<h1
				class="font-display text-xl font-normal tracking-wide [animation-duration:2s] sm:text-2xl"
				data-animate="animate-fade-up"
				data-animate-duration="2s"
				data-animate-delay="0.2s"
			>
				{description}
			</h1>
		</div>

		<!-- CTA Buttons -->
		<div class="cta-buttons mb-4 flex flex-col gap-2 sm:flex-row sm:gap-6">
			<Button
				href={import.meta.env.WHATSAPP_COMMUNITY_URL}
				target="_blank"
				rel="noopener noreferrer"
				variant="secondary"
				data-animate="animate-fade-up"
				data-animate-duration="2s"
				data-animate-delay="0.3s"
			>
				<WhatsAppIcon />
				<span>Únete a nuestra comunidad</span>
			</Button>
			<Button
				href={import.meta.env.CALENDLY_URL}
				target="_blank"
				rel="noopener noreferrer"
				variant="organic"
				data-animate="animate-fade-up"
				data-animate-duration="2s"
				data-animate-delay="0.4s"
			>
				<CalendarIcon />
				<span>Reserva tu cita</span>
			</Button>
		</div>

		<!-- Social Media Icons -->
		<div class="mb-12 flex gap-6">
			<a
				href={import.meta.env.INSTRAGRAM_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="social-icon rounded-full [animation-duration:2s]"
				data-animate="animate-fade-up"
				data-animate-duration="2s"
				data-animate-delay="0.3s"
				aria-label="Instagram"
			>
				<InstagramIcon />
			</a>
			<a
				href={import.meta.env.TIKTOK_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="social-icon [animation-duration:2s]"
				data-animate="animate-fade-up"
				data-animate-duration="2s"
				data-animate-delay="0.3s"
				aria-label="TikTok"
			>
				<TikTokIcon />
			</a>
		</div>

		<!-- Scroll indicator -->
		<button
			id="scroll-indicator"
			class="animate-fade-up absolute bottom-8 left-1/2 -translate-x-1/2 transform cursor-pointer border-none bg-transparent [animation-duration:2s]"
			aria-label="Descubrir más"
		>
			<div class="flex items-center gap-3">
				<p class="font-[questrial] text-lg tracking-wide">Descubrir más</p>
				<div class="animate-bounce">
					<svg
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M7 10L12 15L17 10"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</div>
			</div>
		</button>
	</div>
</div>

<script>
	const images = document.querySelectorAll("img[data-index]")
	let currentIndex = 0

	function changeBackground() {
		// Hide current image
		images[currentIndex].classList.remove("opacity-100")
		images[currentIndex].classList.add("opacity-0")

		// Move to next image
		currentIndex = (currentIndex + 1) % images.length

		// Show next image
		images[currentIndex].classList.remove("opacity-0")
		images[currentIndex].classList.add("opacity-100")
	}

	setTimeout(() => {
		setInterval(changeBackground, 6000)
	}, 500)
</script>
<script>
	import { animate } from "animejs"

	document.addEventListener("DOMContentLoaded", () => {
		const isMobile = window.innerWidth < 640
		const scaleMultiplier = isMobile ? 0.3 : 1

		animate(".logo", {
			translateY: [50, 0], // Move from 50px down to original position
			opacity: [0, 1], // Fade from transparent to visible
			duration: 1000, // Animation duration in milliseconds
			easing: "easeOutExpo", // Easing function
			delay: 0, // Start immediately (or add delay in ms)
		})

		// Wait for fade-up animation to complete (1.5s) before starting heartbeat
		setTimeout(() => {
			function heartbeat() {
				animate(".logo", {
					scale: [
						{ to: 1 + 0.05 * scaleMultiplier, duration: 100, ease: "easeOutQuad" }, // first strong thump
						{ to: 1 - 0.02 * scaleMultiplier, duration: 80, ease: "easeInQuad" }, // quick release
						{ to: 1 + 0.03 * scaleMultiplier, duration: 90, ease: "easeOutQuad" }, // softer second thump
						{ to: 1, duration: 230, ease: "easeInOutQuad" }, // return to rest
					],
					loop: true,
					loopDelay: 500, // adjust so total ~900–1000ms (≈60–70 bpm)
				})
			}
			heartbeat()
		}, 1500)
	})
</script>
<script>
	// Scroll functionality for the discover more indicator
	document.addEventListener("DOMContentLoaded", function () {
		const scrollIndicator = document.getElementById("scroll-indicator")

		if (scrollIndicator) {
			scrollIndicator.addEventListener("click", function () {
				window.scrollTo({
					top: window.innerHeight,
					behavior: "smooth",
				})
			})
		}
	})
</script>

<style>
	.background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100lvh;
		background: linear-gradient(
			45deg,
			rgba(245, 213, 184, 0.7) 0%,
			rgba(232, 196, 160, 0.5) 50%,
			rgba(245, 213, 184, 0.3) 100%
		);
		backdrop-filter: blur(1px);
		z-index: 20;
	}

	.social-icon {
		color: white;
		transition: all 0.3s ease;
		padding: 10px;
		min-width: 44px;
		min-height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	.social-icon:hover {
		transform: translateY(-3px);
		background: rgba(255, 255, 255, 0.2);
		box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
	}

	/* CTA Buttons Styles */
	.cta-buttons {
		z-index: 30;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 14px 28px;
		border-radius: 50px;
		font-size: 1rem;
		font-weight: 500;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		backdrop-filter: blur(10px);
		position: relative;
		overflow: hidden;
		border: 2px solid transparent;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
	}

	.cta-button::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		width: 0;
		height: 0;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.3);
		transform: translate(-50%, -50%);
		transition:
			width 0.5s,
			height 0.5s;
	}

	.cta-button:hover::before {
		width: 300px;
		height: 300px;
	}

	.cta-whatsapp {
		background: rgba(37, 211, 102, 0.8);
		color: white;
		border-color: rgba(255, 255, 255, 0.2);
	}

	.cta-whatsapp:hover {
		background: rgba(37, 211, 102, 1);
		transform: translateY(-3px);
		box-shadow:
			0 10px 25px rgba(37, 211, 102, 0.4),
			0 0 20px rgba(37, 211, 102, 0.3);
	}

	.cta-primary {
		background: linear-gradient(135deg, rgba(203, 110, 95, 0.8), rgba(213, 161, 142, 0.8));
		color: white;
		border-color: rgba(255, 255, 255, 0.2);
	}

	.cta-primary:hover {
		background: linear-gradient(135deg, rgba(203, 110, 95, 1), rgba(213, 161, 142, 1));
		transform: translateY(-3px);
		box-shadow:
			0 10px 25px rgba(203, 110, 95, 0.4),
			0 0 20px rgba(203, 110, 95, 0.3);
	}
</style>

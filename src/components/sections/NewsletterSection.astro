---
import EmailIcon from "@/assets/iconos/email.svg"
import Button from "@/components/ui/button.astro"
import Input from "@/components/ui/input.astro"

const benefits = [
	{
		text: "Consejos mensuales",
		icon: "/images/icons/illustrations/ilustracion-negro_10.svg",
		title: "Consejos mensuales",
	},
	{
		text: "Recursos gratuitos",
		icon: "/images/icons/illustrations/ilustracion-negro_10.svg",
		title: "Recursos gratuitos",
	},
	{
		text: "Acceso prioritario",
		icon: "/images/icons/illustrations/ilustracion-negro_10.svg",
		title: "Acceso prioritario",
	},
]
---

<section id="newsletter" class="bg-cream relative overflow-hidden bg-gradient-to-br py-10 lg:py-18">
	{/* Decorative elements */}
	<div
		class="bg-sage/20 absolute top-0 left-0 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
	>
	</div>
	<div
		class="bg-coral/10 absolute right-0 bottom-0 h-96 w-96 translate-x-1/3 translate-y-1/3 rounded-full blur-3xl"
	>
	</div>
	<div class="bg-coral-light/40 animate-pulse-soft absolute top-1/2 left-1/4 h-4 w-4 rounded-full">
	</div>
	<div
		class="bg-sage/40 animate-pulse-soft absolute top-1/3 right-1/4 h-3 w-3 rounded-full"
		style={{ animationDelay: "1s" }}
	>
	</div>

	<div class="relative z-10 container mx-auto px-4">
		<div class="mx-auto max-w-2xl text-center">
			{/* Icon */}
			<div
				class="bg-coral/20 animate-pulse-soft mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full"
			>
				<EmailIcon />
			</div>

			{/* Title */}
			<h2 class="font-display text-primary mb-4 text-3xl md:text-4xl lg:text-5xl">
				Únete a nuestra tribu
			</h2>

			{/* Subtitle */}
			<p class="text-primary/80 mx-auto mb-8 max-w-lg text-lg leading-relaxed">
				Recibe consejos exclusivos sobre salud femenina, novedades y recursos gratuitos directamente
				en tu correo.
			</p>

			{/* Benefits */}
			<div class="mb-8 flex flex-wrap justify-center gap-4">
				{
					benefits.map((benefit) => (
						<div class="text-primary/70 flex items-center gap-2 text-sm">
							<img src={benefit.icon} alt={benefit.title} class="h-6 w-6" />
							<span>{benefit.text}</span>
						</div>
					))
				}
			</div>

			{/* Form */}
			<!-- src/components/sections/NewsletterSection.astro -->{
				/* Agrega method="post" y action="#" para prevenir comportamiento default */
			}
			<form
				id="newsletter-form"
				class="mx-auto max-w-md flex-col gap-3 sm:flex-row"
				method="post"
				action="#"
			>
				<div class="flex w-full gap-3">
					{/* Email input */}
					<Input
						id="newsletter-email"
						type="email"
						name="email"
						placeholder="Tu correo electrónico"
						required
						class="bg-cream/10 border-coral text-primary placeholder:text-primary/50 focus:border-coral-light focus:ring-coral-light/20 h-12 flex-1"
					/>
					<Button id="newsletter-submit" type="submit" variant="hero" class="whitespace-nowrap">
						Suscribirme
					</Button>
				</div>
				<div id="newsletter-message" class="mt-3 hidden rounded-lg px-4 py-2 text-sm"></div>
			</form>
		</div>
	</div>
</section>

<script>
	const form = document.getElementById("newsletter-form") as HTMLFormElement
	const emailInput = document.getElementById("newsletter-email") as HTMLInputElement
	const submitButton = document.getElementById("newsletter-submit") as HTMLButtonElement
	const messageDiv = document.getElementById("newsletter-message") as HTMLDivElement

	let isSubmitting = false

	form?.addEventListener("submit", async (e) => {
		e.preventDefault()
		e.stopPropagation()

		// Debug - agrega esto temporalmente para ver qué está pasando
		console.log("Form submitted", { isSubmitting, email: emailInput.value })

		if (isSubmitting) {
			console.log("Already submitting, aborting")
			return
		}

		const email = emailInput.value.trim()

		// Basic email validation
		if (!email || !email.includes("@")) {
			showMessage("Por favor, introduce un email válido.", "error")
			return
		}

		// Set loading state
		isSubmitting = true
		submitButton.disabled = true
		submitButton.textContent = "Suscribiendo..."
		hideMessage()

		try {
			console.log("Making POST request to /api/newsletter")

			const response = await fetch("/api/newsletter", {
				method: "POST",
				headers: {
					"Content-Type": "application/json",
				},
				body: JSON.stringify({ email }),
			})

			console.log("Response received", { status: response.status })

			const data = await response.json()

			if (data.success) {
				console.log("Newsletter subscription successful:", data)
				showMessage(data.message, "success")
				submitButton.textContent = "¡Suscrita!"
				emailInput.value = ""

				// Reset button after 30 seconds
				setTimeout(() => {
					submitButton.textContent = "Suscribirme"
					submitButton.disabled = false
					isSubmitting = false
				}, 30000)
			} else {
				showMessage(data.message, "error")
				resetButton()
			}
		} catch (error) {
			console.error("Newsletter error:", error)
			showMessage("Error al suscribirse. Por favor, intenta de nuevo.", "error")
			resetButton()
		}
	})

	function showMessage(message: string, type: "success" | "error") {
		messageDiv.textContent = message
		messageDiv.className = `mt-4 text-sm ${
			type === "success" ? "text-green-700" : "text-red-700"
		} px-4 py-2 rounded-lg`
		messageDiv.classList.remove("hidden")
	}

	function hideMessage() {
		messageDiv.classList.add("hidden")
	}

	function resetButton() {
		submitButton.textContent = "Suscribirme"
		submitButton.disabled = false
		isSubmitting = false
	}
</script>

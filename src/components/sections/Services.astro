---
import ServiceInfoModal from "@/components/modals/ServiceInfoModal.astro"
import Button from "@/components/ui/Button.astro"

const services = [
	{
		id: "salud-hormonal",
		icon: "/images/icons/illustrations/ilustracion-negro_01.svg",
		title: "Salud Hormonal",
		description:
			"Entiende tu ciclo menstrual y vive en sintonía con tus fases. Aprende a escuchar las señales de tu cuerpo y toma decisiones desde el conocimiento.",
		features: [
			"Sesiones online personalizadas",
			"Guías prácticas de nutrición y movimiento",
			"Acompañamiento continuo",
		],
		price: "Ver más",
		color: "terracotta",
		href: "/servicios/salud-hormonal",
	},
	{
		id: "preparacion-al-parto",
		icon: "/images/icons/illustrations/ilustracion-negro_07.svg",
		title: "Preparación al Parto",
		description:
			"El parto es un proceso físico, emocional y mental. Te acompañamos a entender tu cuerpo, gestionar miedos y confiar en tu capacidad para parir.",
		features: ["Fisiología del parto", "Movilidad y respiración", "Conexión en pareja"],
		price: "Ver más",
		color: "coral",
		href: "/servicios/preparacion-al-parto",
	},
	{
		id: "lactancia",
		icon: "/images/icons/illustrations/ilustracion-negro_05.svg",
		title: "Lactancia",
		description:
			"Cada lactancia es única. Te ayudamos a entender cómo funciona tu cuerpo, resolver dificultades y disfrutar de tu lactancia sin miedo ni culpa.",
		features: ["Información basada en evidencia", "Resolución de dificultades", "Apoyo emocional"],
		price: "Ver más",
		color: "sage",
		href: "/servicios/lactancia",
	},
	{
		id: "menopausia",
		icon: "/images/icons/illustrations/ilustracion-negro_14.svg",
		title: "Menopausia",
		description:
			"Una etapa de cambios hormonales y emocionales. Te acompañamos a redescubrir tu energía y tomar decisiones conscientes sobre tu salud.",
		features: ["Gestión de síntomas", "Estilo de vida saludable", "Bienestar integral"],
		price: "Ver más",
		color: "forest",
		href: "/servicios/menopausia",
	},
]

const colorClasses = {
	terracotta: {
		bg: "bg-terracotta/10",
		icon: "text-terracotta",
		border: "border-terracotta/20",
		hover: "hover:border-terracotta/40",
	},
	coral: {
		bg: "bg-coral/10",
		icon: "text-coral",
		border: "border-coral/20",
		hover: "hover:border-coral/40",
	},
	sage: {
		bg: "bg-sage/10",
		icon: "text-sage",
		border: "border-sage/20",
		hover: "hover:border-sage/40",
	},
	forest: {
		bg: "bg-forest/10",
		icon: "text-forest",
		border: "border-forest/20",
		hover: "hover:border-forest/40",
	},
}

const phoneNumber = import.meta.env.WHATSAPP_NUMBER
---

<section id="servicios" class="bg-coral-light/10 relative overflow-hidden py-20 lg:py-28">
	{/* Decorative blobs */}

	<div
		class="bg-coral/10 absolute bottom-0 left-0 h-80 w-80 -translate-x-1/2 translate-y-1/2 rounded-full blur-3xl"
		aria-hidden="true"
	>
	</div>

	<div class="relative z-10 container mx-auto px-4">
		{/* Header */}
		<div class="mx-auto mb-16 max-w-3xl text-center">
			<span
				class="bg-sage/20 text-forest font-body mb-4 inline-block rounded-full px-4 py-2 text-sm"
				data-animate="animate-fade-up"
				data-animate-duration="1s"
			>
				Nuestros Servicios
			</span>
			<h2
				class="font-display text-forest mb-6 text-4xl md:text-5xl lg:text-6xl"
				data-animate="animate-fade-up"
				data-animate-duration="1s"
				data-animate-delay="0.1s"
			>
				Te acompañamos en cada etapa
			</h2>
			<p
				class="text-forest/70 font-body text-lg leading-relaxed"
				data-animate="animate-fade-up"
				data-animate-duration="1s"
				data-animate-delay="0.2s"
			>
				Desde tu ciclo menstrual hasta la menopausia, pasando por el embarazo, el parto y la
				lactancia. Una mirada integral y humana para cada momento de tu vida.
			</p>
		</div>

		{/* Services Grid */}
		<div class="mx-auto grid max-w-5xl gap-6 md:grid-cols-2 lg:gap-8">
			{
				services.map((service, index) => {
					const colors = colorClasses[service.color as keyof typeof colorClasses]

					return (
						<div
							id={service.id}
							class={`group bg-background relative rounded-3xl border-2 p-8 ${colors.border} ${colors.hover} hover:shadow-elegant scroll-mt-24 transition-all duration-300`}
							data-animate="animate-fade-up"
							data-animate-duration="1s"
							data-animate-delay={`${index * 100}ms`}
						>
							{/* Header con Icon y Share Button */}
							<div class="mb-6 flex items-start justify-between">
								<div
									class={`h-16 w-16 ${colors.bg} flex items-center justify-center rounded-2xl transition-transform duration-300 group-hover:scale-110`}
								>
									<img
										src={service.icon}
										alt={service.title}
										class={`h-16 w-16 ${service.color}`}
										style="filter: brightness(0) saturate(100%);"
										loading="lazy"
									/>
								</div>
								{service.id === "lactancia" && (
									<img
										src="/images/logos/laura-jorge/laura-jorge-icon.png"
										alt="Laura Jorge"
										loading="lazy"
										class="ml-auto h-8 w-auto flex-shrink-0 object-contain"
									/>
								)}
								<button
									class="share-service-btn text-forest/40 hover:text-forest hover:bg-forest/5 flex h-11 w-11 cursor-pointer items-center justify-center rounded-lg transition-all duration-200"
									data-service-id={service.id}
									aria-label="Compartir servicio"
									title="Copiar enlace"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="20"
										height="20"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<circle cx="18" cy="5" r="3" />
										<circle cx="6" cy="12" r="3" />
										<circle cx="18" cy="19" r="3" />
										<line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
										<line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
									</svg>
								</button>
							</div>

							{/* Content */}
							<Button
								href={service.href !== "#" ? service.href : undefined}
								variant="link"
								class="p-0 no-underline hover:no-underline"
							>
								<h3 class="font-display text-forest mb-3 text-2xl lg:text-3xl">{service.title}</h3>
							</Button>
							<p class="text-forest/70 font-body mb-6 leading-relaxed">{service.description}</p>

							{/* Features */}
							<ul class="mb-6 space-y-2">
								{service.features.map((feature) => (
									<li class="text-forest/70 font-body flex items-center gap-2 text-sm">
										<span class={`bg-terracotta h-1.5 w-1.5 rounded-full`} />
										{feature}
									</li>
								))}
							</ul>

							{/* Price & CTA */}
							<div class="border-forest/10 flex items-center justify-between border-t pt-4">
								<Button
									href={service.href !== "#" ? service.href : undefined}
									variant="linkMuted"
									class="no-underline hover:no-underline"
									size="sm"
								>
									<span class="font-display text-forest text-xl">{service.price}</span>
								</Button>
								<Button
									class="bg-gradient-terracota text-accent-foreground shadow-warm hover:shadow-organic service-info-btn rounded-full px-4 py-2 transition-all duration-300 hover:scale-105"
									data-service-name={service.title}
									data-service-href={service.href}
								>
									Pedir cita
								</Button>
							</div>
						</div>
					)
				})
			}
		</div>

		{/* Sesiones sueltas info */}
		<div class="mx-auto mt-12 max-w-2xl">
			<div
				class="from-secondary/10 via-background to-accent/10 border-secondary/30 relative rounded-2xl border bg-gradient-to-r p-6"
			>
				<div class="absolute -top-3 left-1/2 -translate-x-1/2">
					<span
						class="bg-background font-body text-primary/70 border-secondary/30 rounded-full border px-4 py-1 text-sm"
					>
						También disponible
					</span>
				</div>
				<div class="pt-2 text-center">
					<h3 class="font-display text-primary mb-2 text-xl">Sesiones sueltas</h3>
					<p class="text-primary/80 font-body mb-3">
						Si necesitas una consulta puntual sobre lactancia, salud hormonal, preparación al parto
						o menopausia, reserva una sesión individual online o presencial en Valencia por
						<data value="50" class="font-display text-primary text-xl font-semibold">50€</data>.
					</p>
					<a
						href={`https://wa.me/34${phoneNumber}?text=${encodeURIComponent("¡Hola! Me gustaría reservar una sesión suelta en Femm tribu.")}`}
						target="_blank"
						rel="noopener noreferrer"
						class="text-accent font-body hover:text-accent/80 inline-flex items-center gap-1 text-sm font-semibold transition-colors"
						onclick="window.gtag && window.gtag('event', 'cta_click', { cta_type: 'whatsapp', cta_label: 'sesion_suelta', page: window.location.pathname })"
					>
						Reservar sesión suelta
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="16"
							height="16"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
						>
					</a>
				</div>
			</div>
		</div>

		{/* Schema: Sesión suelta */}
		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "Service",
				"name": "Sesión suelta de matrona",
				"description":
					"Consulta individual con matrona sobre lactancia, salud hormonal, preparación al parto o menopausia. Disponible online y presencial en Valencia.",
				"provider": {
					"@type": "Person",
					"name": "María Belenguer",
					"jobTitle": "Matrona",
				},
				"areaServed": [
					{ "@type": "City", "name": "Valencia" },
					{ "@type": "Country", "name": "España" },
				],
				"offers": {
					"@type": "Offer",
					"price": 50,
					"priceCurrency": "EUR",
					"availability": "https://schema.org/InStock",
					"priceValidUntil": new Date(new Date().setFullYear(new Date().getFullYear() + 1))
						.toISOString()
						.split("T")[0],
				},
				"category": "Healthcare Services",
				"audience": {
					"@type": "PeopleAudience",
					"suggestedGender": "female",
				},
			})}
		/>

		{/* CTA */}
		<div
			class="mt-16 text-center"
			data-animate="animate-fade-up"
			data-animate-duration="1s"
			data-animate-delay="0.3s"
		>
			<p class="text-forest/70 font-body mb-4">¿No sabes por dónde empezar?</p>
			<a
				href={import.meta.env.CALENDLY_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="bg-accent text-cream font-body hover:bg-accent/90 hover:shadow-elegant rounded-full px-8 py-4 text-lg transition-all duration-300 hover:scale-105"
				onclick="window.gtag && window.gtag('event', 'cta_click', { cta_type: 'calendly', cta_label: 'agenda_llamada_gratuita', page: window.location.pathname })"
			>
				Agenda una llamada gratuita
			</a>
		</div>
	</div>
	{/* Service Info Modal */}
	<ServiceInfoModal />
</section>

<script define:vars={{ phoneNumber }}>
	document.addEventListener("DOMContentLoaded", () => {
		// Handle share buttons
		const shareButtons = document.querySelectorAll(".share-service-btn")

		shareButtons.forEach((button) => {
			button.addEventListener("click", async (e) => {
				e.stopPropagation()
				const serviceId = button.getAttribute("data-service-id")
				const url = `${window.location.origin}${window.location.pathname}#${serviceId}`

				try {
					await navigator.clipboard.writeText(url)

					// Visual feedback
					const originalHTML = button.innerHTML
					button.innerHTML = `
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					`
					button.classList.add("text-sage")

					setTimeout(() => {
						button.innerHTML = originalHTML
						button.classList.remove("text-sage")
					}, 2000)
				} catch (err) {
					console.error("Error al copiar el enlace:", err)
				}
			})
		})

		// Handle hash navigation and smooth scroll
		if (window.location.hash) {
			setTimeout(() => {
				const element = document.querySelector(window.location.hash)
				if (element) {
					element.scrollIntoView({ behavior: "smooth", block: "center" })
				}
			}, 100)
		}

		const serviceButtons = document.querySelectorAll(".service-info-btn")

		serviceButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const serviceName = button.getAttribute("data-service-name") || "nuestros servicios"
				const href = button.getAttribute("data-service-href")

				if (window.gtag) {
					window.gtag("event", "service_inquiry", {
						service_name: serviceName,
						page: window.location.pathname,
					})
				}
				const whatsappBtn = document.getElementById("whatsapp-service-btn")

				if (href != "#" && href != null && whatsappBtn) {
					const message = encodeURIComponent(
						`¡Hola! Quiero reservar una cita para el servicio de *${serviceName}* de *Femm tribu*.`
					)
					window.open(`https://wa.me/34${phoneNumber}?text=${message}`, "_blank")
				}
				// Update the WhatsApp button's data attribute in the modal
				else if (whatsappBtn) {
					whatsappBtn.setAttribute("data-service-name", serviceName)
					// Open the modal
					window.modalManager.open("service-info-modal")
				}
			})
		})

		// Handle "Más información" buttons
		const masInfoButtons = document.querySelectorAll(".mas-info-btn")

		masInfoButtons.forEach((button) => {
			button.addEventListener("click", (e) => {
				e.preventDefault()
				const serviceName = button.getAttribute("data-service-name") || "nuestros servicios"

				// Update the WhatsApp button's data attribute in the modal
				const whatsappBtn = document.getElementById("whatsapp-service-btn")
				if (whatsappBtn) {
					whatsappBtn.setAttribute("data-service-name", serviceName)
				}

				// Open the modal
				window.modalManager.open("service-info-modal")
			})
		})
	})
</script>

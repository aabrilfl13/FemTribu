---
import ServiceSchema from "@/components/schema/ServiceSchema.astro"
import Button from "@/components/ui/Button.astro"
import OfferCard from "@/components/ui/OfferCard.astro"
import SectionHeading from "@/components/ui/SectionHeading.astro"
import { STAGE, type StageColor } from "@/components/ui/stageColors"
import { CONSULTATION_PRICE, SERVICES } from "@/data/services"
import { getAssetUrl } from "@/services/directus"

interface HomeService {
	id: string
	icon: string
	title: string
	description: string
	price: string
	priceSuffix?: string
	color: StageColor
	href: string
	badge?: { label: string; image: string }
	highlight?: boolean
	pack?: boolean
}

const services: HomeService[] = [
	{
		id: "salud-hormonal",
		icon: "/images/icons/illustrations/ilustracion-negro_01.svg",
		title: SERVICES.saludHormonal.nameShort,
		description:
			"Dolor menstrual, SPM, ciclos irregulares o desajustes hormonales. Aprende a escuchar tu cuerpo.",
		price: `${CONSULTATION_PRICE}€`,
		priceSuffix: "60 min",
		color: "terracotta",
		href: SERVICES.saludHormonal.url,
	},
	{
		id: "preconcepcional",
		icon: "/images/icons/illustrations/ilustracion-negro_03.svg",
		title: SERVICES.preconcepcional.nameShort,
		description:
			"Preparación consciente del embarazo. Ciclo, ovulación, nutrición y suplementación básica.",
		price: `${CONSULTATION_PRICE}€`,
		priceSuffix: "60 min",
		color: "sage",
		href: SERVICES.preconcepcional.url,
	},
	{
		id: "preparacion-al-parto",
		icon: "/images/icons/illustrations/ilustracion-negro_07.svg",
		title: SERVICES.preparacionParto.nameShort,
		description:
			"Sesión de dudas sobre embarazo, parto y posparto. Plan de parto, intervenciones y gestión del miedo.",
		price: `${CONSULTATION_PRICE}€`,
		priceSuffix: "60 min",
		color: "coral",
		href: SERVICES.preparacionParto.url,
	},
	{
		id: "lactancia",
		icon: "/images/icons/illustrations/ilustracion-negro_05.svg",
		title: SERVICES.lactancia.nameShort,
		description:
			"Agarre, dolor, producción, banco de leche, vuelta al trabajo y destete respetuoso.",
		price: `${CONSULTATION_PRICE}€`,
		priceSuffix: "60 min",
		color: "sage",
		href: SERVICES.lactancia.url,
		// badge: {
		// 	label: "Laura Jorge",
		// 	image: "/images/logos/laura-jorge/laura-jorge-icon.png",
		// },
	},
	{
		id: "menopausia",
		icon: "/images/icons/illustrations/ilustracion-negro_14.svg",
		title: SERVICES.menopausia.nameShort,
		description:
			"Sofocos, sueño, cambios emocionales, sequedad vaginal, salud ósea y hábitos de autocuidado.",
		price: `${CONSULTATION_PRICE}€`,
		priceSuffix: "60 min",
		color: "terracotta",
		href: SERVICES.menopausia.url,
	},
	{
		id: "conoce-tu-ciclo",
		icon: "/images/icons/illustrations/ilustracion-negro_02.svg",
		title: SERVICES.conoceTuCiclo.nameShort,
		description:
			"Pack de 3 meses para aprender a entender, observar y conectar con tu ciclo menstrual.",
		price: `${SERVICES.conoceTuCiclo.priceMin}€`,
		priceSuffix: "3 meses",
		color: "forest",
		href: SERVICES.conoceTuCiclo.url,
		highlight: true,
		pack: true,
	},
]

const femmbarre = SERVICES.femmbarre
const femmbarreMotif = "/images/icons/illustrations/ilustracion-negro_16.svg"
const femmbarreImage = "434e8c6a-e85f-4c33-a049-298dd53bedcd"
const femmbarreFeatures = [
	"1 clase semanal en directo",
	"Acceso a grabaciones",
	"Guiado por matrona profesional",
	"Adaptado a cada trimestre",
]
---

<section id="servicios" class="bg-coral-light/10 relative overflow-hidden py-20 lg:py-28">
	{/* Decorative blob */}
	<div
		class="bg-coral/10 absolute bottom-0 left-0 h-80 w-80 -translate-x-1/2 translate-y-1/2 rounded-full blur-3xl"
		aria-hidden="true"
	>
	</div>

	<div class="relative z-10 container mx-auto px-4">
		{/* Header (kept large — section hero) */}
		<div class="mx-auto mb-16 max-w-3xl text-center">
			<span
				class="bg-sage/20 text-forest font-body mb-4 inline-block rounded-full px-4 py-2 text-sm"
				data-animate="animate-fade-up"
				data-animate-duration="1s"
			>
				Nuestros Servicios
			</span>
			<h2
				class="font-display text-forest mb-6 text-4xl md:text-5xl lg:text-6xl"
				data-animate="animate-fade-up"
				data-animate-duration="1s"
				data-animate-delay="0.1s"
			>
				Te acompañamos en cada etapa
			</h2>
			<p
				class="text-forest/70 font-body text-lg leading-relaxed"
				data-animate="animate-fade-up"
				data-animate-duration="1s"
				data-animate-delay="0.2s"
			>
				Consultas individuales con matrona a {CONSULTATION_PRICE}€, el pack Conoce tu Ciclo de 3
				meses y FemmBarre prenatal. Elige lo que necesites para cada momento de tu vida.
			</p>
		</div>

		{/* Services grid — 6 compact stages */}
		<div class="mx-auto grid max-w-6xl gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
			{
				services.map((service, index) => {
					const color = STAGE[service.color]
					return (
						<a
							id={service.id}
							href={service.href}
							class:list={[
								"group bg-background hover:shadow-elegant relative flex scroll-mt-24 flex-col rounded-3xl border-2 p-6 transition-all duration-300",
								color.border,
								color.hover,
								service.highlight ? `ring-2 ring-offset-2 ${color.ring}` : "",
							]}
							data-animate="animate-fade-up"
							data-animate-duration="1s"
							data-animate-delay={`${index * 80}ms`}
						>
							{/* Header with motif icon */}
							<div class="mb-5 flex items-center justify-between">
								<div
									class:list={[
										"shape-organic flex h-14 w-14 items-center justify-center transition-transform duration-300 group-hover:scale-110",
										color.soft,
									]}
								>
									<span
										class:list={["mask-motif h-9 w-9", color.text]}
										style={`--motif:url('${service.icon}')`}
										aria-hidden="true"
									/>
								</div>
								<div class="flex flex-row items-center">
									{service.badge && (
										<img
											src={service.badge.image}
											alt={service.badge.label}
											loading="lazy"
											class="h-7 w-auto flex-shrink-0 object-contain"
										/>
									)}
									{service.pack && (
										<span class="bg-accent text-accent-foreground font-body rounded-full px-3 py-1 text-xs font-medium">
											Pack
										</span>
									)}
								</div>
							</div>

							{/* Content */}
							<h3 class="font-display text-forest group-hover:text-accent mb-2 text-xl transition-colors lg:text-2xl">
								{service.title}
							</h3>
							<p class="text-forest/70 font-body mb-5 flex-1 text-sm leading-relaxed">
								{service.description}
							</p>

							{/* Price + arrow */}
							<div class="border-forest/10 flex items-center justify-between border-t pt-4">
								<div class="flex flex-col">
									<span class="font-display text-forest text-lg">{service.price}</span>
									{service.priceSuffix && (
										<span class="text-forest/60 font-body text-xs">{service.priceSuffix}</span>
									)}
								</div>
								<span
									class:list={[
										"flex h-9 w-9 items-center justify-center rounded-full transition-transform duration-300 group-hover:translate-x-1",
										color.soft,
									]}
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="16"
										height="16"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										class={color.text}
										aria-hidden="true"
									>
										<path d="M5 12h14" />
										<path d="m12 5 7 7-7 7" />
									</svg>
								</span>
							</div>
						</a>
					)
				})
			}
		</div>

		{/* CTA to hub */}
		<div
			class="mt-10 text-center"
			data-animate="animate-fade-up"
			data-animate-duration="1s"
			data-animate-delay="0.3s"
		>
			<Button
				href="/servicios"
				variant="outline"
				class="rounded-full px-6 py-3 text-sm transition-all duration-300 hover:scale-105"
			>
				Ver todos los servicios
			</Button>
		</div>

		{/* More from FemmTribu — FemmBarre */}
		<div class="mt-20">
			<SectionHeading
				class="mb-12"
				color="accent"
				label="Más de FemmTribu"
				title="Bienestar y movimiento"
				subtitle="Además de nuestras consultas, ofrecemos FemmBarre Maternity: una suscripción mensual de barre prenatal online."
			/>

			<div class="mx-auto max-w-3xl" data-animate="animate-fade-up" data-animate-duration="1s">
				<OfferCard
					href={femmbarre.url}
					title={femmbarre.name}
					subtitle="Barre prenatal para embarazadas"
					body="Clases de barre adaptadas al embarazo, guiadas por matrona. Online desde cualquier sitio, a tu ritmo y con total seguridad."
					features={femmbarreFeatures}
					price={femmbarre.priceMin}
					priceSuffix="/mes"
					ctaLabel="Descubre FemmBarre"
					badge="Suscripción mensual"
					color="accent"
					motif={femmbarreMotif}
					image={getAssetUrl(femmbarreImage)}
					imageAlt="FemmBarre Maternity — Barre prenatal para embarazadas"
				/>
			</div>

			{/* Schema: FemmBarre */}
			<ServiceSchema
				name={femmbarre.name}
				description={femmbarre.description}
				serviceType={femmbarre.serviceType}
				priceMin={femmbarre.priceMin}
				isSubscription={true}
				billingPeriod="month"
				onlineOnly={true}
				url={femmbarre.url}
			/>
		</div>

		{/* Final CTA */}
		<div
			class="mt-16 text-center"
			data-animate="animate-fade-up"
			data-animate-duration="1s"
			data-animate-delay="0.3s"
		>
			<p class="text-forest/70 font-body mb-4">¿No sabes por dónde empezar?</p>
			<a
				href={import.meta.env.CALENDLY_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="bg-accent text-cream font-body hover:bg-accent/90 hover:shadow-elegant rounded-full px-8 py-4 text-lg transition-all duration-300 hover:scale-105"
				onclick="window.gtag && window.gtag('event', 'cta_click', { cta_type: 'calendly', cta_label: 'agenda_llamada_gratuita', page: window.location.pathname })"
			>
				Agenda una llamada gratuita
			</a>
		</div>
	</div>
</section>

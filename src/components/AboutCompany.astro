---
// SVG icons matching lucide-react
const CheckIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`

const pillars = [
	{
		icon: "/images/icons/illustrations/ilustracion-negro_14.svg",
		title: "Ciencia",
		description: "Basado en evidencia científica actualizada y mi experiencia como matrona",
		color: "text-accent",
		bgColor: "bg-accent/10",
	},
	{
		icon: "/images/icons/illustrations/ilustracion-negro_04.svg",
		title: "Espiritualidad",
		description: "Conectando con tu esencia femenina y los ciclos naturales de la vida",
		color: "text-secondary",
		bgColor: "bg-secondary/10",
	},
	{
		icon: "/images/icons/illustrations/ilustracion-negro_02.svg",
		title: "Autocuidado",
		description: "Herramientas prácticas para cuidarte en cada etapa de tu camino",
		color: "text-coral",
		bgColor: "bg-coral/10",
	},
]

const features = [
	"Atención integral cuerpo-mente-alma",
	"Acompañamiento online y presencial en Valencia",
	"Todas las etapas: ciclo, embarazo, parto, menopausia",
	"Comunidad de mujeres que se apoyan",
]
---

<section id="sobre-mi" class="py-24 lg:py-32 relative overflow-hidden">
	<!-- Background decorations -->
	<div
		class="absolute top-0 right-0 w-96 h-96 bg-coral-light/10 shape-organic -translate-y-1/2 translate-x-1/2"
	>
	</div>
	<div
		class="absolute bottom-0 left-0 w-64 h-64 bg-secondary/10 shape-blob translate-y-1/2 -translate-x-1/2"
	>
	</div>

	<div class="container mx-auto px-4 lg:px-8 relative z-10">
		<!-- Section header -->
		<div class="text-center max-w-3xl mx-auto mb-16 lg:mb-18">
			<span
				class="inline-flex items-center gap-2 bg-coral-light/30 text-primary px-4 py-1 rounded-full text-sm mb-6"
			>
				<img
					src="/images/icons/illustrations/ilustracion-negro_11.svg"
					alt="Plant icon"
					class="w-8 h-8"
				/>
				Sobre FemmTribu
			</span>
			<h2 class="font-display text-3xl sm:text-4xl lg:text-5xl text-primary mb-6">
				¿Qué es{" "}
				<span class="text-accent">Femm</span><span class="text-secondary">Tribu</span>?
			</h2>
			<p class="text-lg text-muted-foreground">
				Un espacio online creado por mujeres, para mujeres. Donde la ciencia se encuentra con la
				espiritualidad para acompañarte en cada momento de tu vida.
			</p>
		</div>

		<div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
			<!-- Image -->
			<div class="relative order-2 lg:order-1">
				<div class="relative">
					<!-- Background shape -->
					<div class="absolute -inset-6 bg-gradient-organic shape-blob opacity-10"></div>

					<!-- Main image -->
					<div class="relative overflow-hidden rounded-3xl shadow-organic">
						<img
							src="/images/mujeres-circulo.webp"
							alt="Círculo de mujeres en FemmTribu"
							class="w-full h-auto object-cover aspect-[4/5]"
						/>
						<div
							class="absolute inset-0 bg-gradient-to-t from-primary/30 via-transparent to-transparent"
						>
						</div>
					</div>

					<!-- Floating card -->
					<!-- TODO: Fix animate-float that rotates instead of jump -->
					<div
						class="absolute -bottom-8 -right-4 lg:-right-8 bg-background shadow-warm rounded-2xl p-5 max-w-xs animate-fade-in animation-delay-600"
					>
						<p class="font-display text-lg text-primary mb-2">
							"Crear un espacio donde las mujeres puedan encontrar un sitio dedicado para ellas"
						</p>
						<p class="text-sm text-accent font-medium">— María Belenguer</p>
					</div>
				</div>
			</div>

			<!-- Content -->
			<div class="space-y-8 order-1 lg:order-2">
				<div class="space-y-4">
					<h3 class="font-display text-2xl lg:text-3xl text-primary">
						Acompañamiento integral en todas tus etapas
					</h3>
					<p class="text-muted-foreground leading-relaxed">
						FemmTribu es un espacio creado para acompañarte en todas las etapas de tu vida como
						mujer. Un lugar donde la ciencia, la intuición y el autocuidado se encuentran para
						ofrecerte una mirada completa, humana y respetuosa de tu salud.
					</p>
					<p class="text-muted-foreground leading-relaxed">
						Aquí no solo atendemos síntomas: escuchamos tu historia, tus ritmos, tus miedos y tus
						necesidades. Te acompañamos <strong class="text-primary"
							>todas las etapas de tu vida</strong
						>: desde tu ciclo menstrual hasta la menopausia, pasando por el embarazo, el parto, la
						lactancia y el posparto, para que vivas cada etapa desde la calma, el conocimiento y la
						conexión con tu cuerpo.
					</p>
					<p class="text-muted-foreground leading-relaxed">
						FemmTribu nace del deseo de crear un espacio seguro: un lugar donde puedas sentirte
						sostenida, comprendida y libre de vivir tu proceso sin juicios.
					</p>
					<p class="text-muted-foreground leading-relaxed">
						<strong class="text-primary">Somos una tribu.</strong>
					</p>
					<p class="text-muted-foreground leading-relaxed">
						Una comunidad de mujeres que comparten, se inspiran y se acompañan. Y tú también formas
						parte de ella.
					</p>
				</div>

				<!-- Features list -->
				<div class="space-y-3">
					{
						features.map((feature) => (
							<div class="flex items-center gap-3 p-3 rounded-xl bg-muted/50 hover:bg-muted transition-colors duration-300">
								<div class="w-6 h-6 bg-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
									<span class="w-4 h-4 text-accent" set:html={CheckIcon} />
								</div>
								<span class="text-primary">{feature}</span>
							</div>
						))
					}
				</div>

				<!-- Three pillars -->
				<div class="grid sm:grid-cols-3 gap-4 pt-4">
					{
						pillars.map((pillar) => (
							<div class="group p-5 rounded-2xl bg-background shadow-soft hover:shadow-warm transition-all duration-300 hover:-translate-y-1">
								<div
									class={`w-12 h-12 ${pillar.bgColor} rounded-xl flex items-center justify-center mb-4 transition-transform duration-300 group-hover:scale-110`}
								>
									<img
										src={pillar.icon}
										alt={pillar.title}
										class={`w-9 h-9 ${pillar.color}`}
										style="filter: brightness(0) saturate(100%);"
									/>
								</div>
								<h4 class="font-display text-lg text-primary mb-2">{pillar.title}</h4>
								<p class="text-sm text-muted-foreground">{pillar.description}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

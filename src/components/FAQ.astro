---
/**
 * FAQ Component - Preguntas frecuentes con diseño minimalista
 */

interface FAQ {
	question: string
	answer: string
}

interface Props {
	faqs: FAQ[]
	title?: string
	subtitle?: string
}

const { faqs, title = "Preguntas frecuentes", subtitle } = Astro.props
---

<section class="pb-16 lg:pb-24">
	<div class="container mx-auto px-4 lg:px-8">
		<div class="mx-auto max-w-3xl">
			<div class="mb-12 text-center">
				<h2
					class="font-display text-primary mb-4 text-3xl md:text-4xl"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
				>
					{title}
				</h2>
				{
					subtitle && (
						<p
							class="text-muted-foreground font-body mx-auto max-w-2xl text-lg"
							data-animate="animate-fade-in"
							data-animate-duration="1s"
							data-animate-delay="0.1s"
						>
							{subtitle}
						</p>
					)
				}
			</div>

			<div
				class="border-border/40 divide-border/40 divide-y border-t border-b"
				data-animate="animate-fade-in"
				data-animate-duration="1s"
				data-animate-delay="0.2s"
			>
				{
					faqs.map((faq) => (
						<div class="group">
							<button
								class="faq-button flex w-full cursor-pointer items-center justify-between gap-4 py-5 text-left"
								aria-expanded="false"
							>
								<h3 class="font-display text-primary text-base md:text-lg">{faq.question}</h3>
								<svg
									class="text-muted-foreground faq-icon h-5 w-5 flex-shrink-0 transition-transform duration-200"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M6 9l6 6 6-6" />
								</svg>
							</button>
							<div class="faq-content max-h-0 overflow-hidden transition-all duration-300">
								<p class="text-muted-foreground font-body pb-5 text-sm leading-relaxed md:text-base">
									{faq.answer}
								</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<script>
	function initFAQ() {
		const faqButtons = document.querySelectorAll(".faq-button")

		faqButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const content = button.nextElementSibling as HTMLElement
				const icon = button.querySelector(".faq-icon") as HTMLElement
				const isExpanded = button.getAttribute("aria-expanded") === "true"

				// Toggle current FAQ
				if (isExpanded) {
					button.setAttribute("aria-expanded", "false")
					content.style.maxHeight = "0"
					icon.style.transform = "rotate(0deg)"
				} else {
					button.setAttribute("aria-expanded", "true")
					content.style.maxHeight = content.scrollHeight + "px"
					icon.style.transform = "rotate(180deg)"
				}
			})
		})
	}

	// Initialize on page load
	initFAQ()

	// Reinitialize on Astro navigation
	document.addEventListener("astro:page-load", initFAQ)
</script>

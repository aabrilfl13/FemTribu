---
import InstagramIcon from "@/assets/iconos/instagram.svg"
import TikTokIcon from "@/assets/iconos/tiktok.svg"
import WhatsAppIcon from "@/assets/iconos/whatsapp.svg"
---

<footer class="footer">
	<div class="footer-container">
		<!-- Decorative elements -->
		<div class="floating-element one"></div>
		<div class="floating-element two"></div>

		<div class="footer-content">
			<!-- Main footer section -->
			<div class="footer-main">
				<div class="footer-brand">
					<div class="logo-wrapper">
						<img src="/images/logos/logo_sello_fullcolor.svg" alt="Femm tribu Logo" class="mb-8" loading="lazy" />
					</div>
					<p class="brand-description">
						Una <i>guía femenina integral</i> para todo el viaje corporal y emocional de ser mujer.
					</p>
				</div>

				<div class="footer-links">
					<div class="links-section">
						<h4>Recursos</h4>
						<ul>
							<li><a href="#videos">Vídeos</a></li>
							<li><a class="disabled-link" href="#guias">Guías</a></li>
							<li><a class="disabled-link" href="#testimonios">Testimonios</a></li>
							<li><a class="disabled-link" href="#blog">Blog</a></li>
						</ul>
					</div>

					<div class="links-section">
						<h4>Comunidad</h4>
						<ul>
							<li><a class="disabled-link" href="#profesionales">Profesionales</a></li>
							<li><a class="disabled-link" href="#contacto">Contacto</a></li>
						</ul>
					</div>

					<div class="links-section">
						<h4>Legal</h4>
						<ul>
							<li><a href="/privacy">Política de privacidad</a></li>
							<li><a href="#terminos">Términos de uso</a></li>
							<li><a href="/cookies">Cookies</a></li>
						</ul>
					</div>
				</div>

				<div class="footer-newsletter">
					<h4>Mantente conectada</h4>
					<p>Recibe nuestras últimas actualizaciones y recursos exclusivos</p>
					<form class="newsletter-form" id="newsletter-form-footer">
						<input
							type="email"
							placeholder="tu@email.com"
							class="newsletter-input"
							id="newsletter-email-footer"
						/>
						<button type="submit" class="newsletter-button" id="newsletter-submit-footer">
							Suscribirme
						</button>
						<div id="newsletter-message-footer" class="mt-3 hidden rounded-lg px-4 py-2 text-sm">
						</div>
					</form>
				</div>
			</div>

			<!-- Social media section -->
			<div class="footer-social">
				<div class="social-links">
					<a
						href={import.meta.env.INSTRAGRAM_URL}
						class="social-link"
						aria-label="Instagram"
						target="_blank"
						rel="noopener noreferrer"
					>
						<InstagramIcon />
					</a>
					<a
						href={import.meta.env.TIKTOK_URL}
						class="social-link"
						aria-label="TikTok"
						target="_blank"
						rel="noopener noreferrer"
					>
						<TikTokIcon />
					</a>
					<a
						href={import.meta.env.WHATSAPP_COMMUNITY_URL}
						class="social-link"
						aria-label="WhatsApp"
						target="_blank"
						rel="noopener noreferrer"
					>
						<WhatsAppIcon />
					</a>
				</div>

				<!-- Company email section -->
				<div class="footer-email">
					<a href="mailto:info@femmtribu.es" class="email-link">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4Z"
							></path>
						</svg>
						<span>info@femmtribu.es</span>
					</a>
				</div>
			</div>

			<!-- Bottom section -->
			<div class="footer-bottom">
				<div class="footer-bottom-content">
					<p class="copyright">© 2025 Femm tribu. Todos los derechos reservados.</p>
					<p class="made-with-love">Hecho con ❤️ para mujeres extraordinarias</p>
				</div>
			</div>
			<!-- Developer Credit -->
			<div class="developer-credit">
				<p>
					Desarrollado por <strong>Antonio Abril</strong> ·
					<a href="https://github.com/aabrilfl13" target="_blank" rel="noopener">
						<img src="/images/icons/github-mark.svg" alt="GitHub Logo" loading="lazy" />
						@aabrilfl13
					</a>
				</p>
			</div>
		</div>
	</div>

	<style>
		.footer {
			background: linear-gradient(135deg, #37443a 0%, #6a8067 100%);
			color: #fff5eb;
			position: relative;
			overflow: hidden;
		}

		/* Decorative background pattern */
		.footer::before {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			background-image:
				radial-gradient(circle at 20% 30%, rgba(255, 245, 235, 0.05) 0%, transparent 50%),
				radial-gradient(circle at 80% 70%, rgba(203, 110, 95, 0.08) 0%, transparent 60%);
			pointer-events: none;
		}

		.footer-container {
			max-width: 1200px;
			margin: 0 auto;
			padding: 60px 20px 0;
			position: relative;
			z-index: 1;
		}

		.footer-content {
			position: relative;
			z-index: 2;
		}

		/* Floating decorative elements */
		.floating-element {
			position: absolute;
			border: 1px solid rgba(255, 245, 235, 0.1);
			border-radius: 50%;
			pointer-events: none;
		}

		.floating-element.one {
			width: 120px;
			height: 120px;
			top: 10%;
			right: 5%;
			animation: float-slow 20s ease-in-out infinite;
		}

		.floating-element.two {
			width: 80px;
			height: 80px;
			bottom: 20%;
			left: 8%;
			animation: float-slow 25s ease-in-out infinite reverse;
		}

		.disabled-link {
			pointer-events: none;
			opacity: 0.6;
			cursor: default;
		}

		@keyframes float-slow {
			0%,
			100% {
				transform: translate(0, 0) rotate(0deg);
				opacity: 0.3;
			}
			25% {
				transform: translate(10px, -15px) rotate(90deg);
				opacity: 0.5;
			}
			50% {
				transform: translate(-5px, 10px) rotate(180deg);
				opacity: 0.4;
			}
			75% {
				transform: translate(15px, 5px) rotate(270deg);
				opacity: 0.6;
			}
		}

		/* Main footer content */
		.footer-main {
			display: grid;
			grid-template-columns: 1fr 1fr 300px;
			gap: 60px;
			margin-bottom: 50px;
		}

		.footer-brand {
			max-width: 350px;
		}

		.logo-wrapper {
			width: 250px;
			height: 250px;
			opacity: 0.8;
		}

		.logo-wrapper svg {
			width: 100%;
			height: 100%;
			fill: #fff5eb;
		}

		.footer-brand h3 {
			font-family: "The Seasons", serif;
			font-size: 1.8rem;
			font-weight: 400;
			margin-bottom: 15px;
			color: #fff5eb;
			letter-spacing: 0.5px;
		}

		.brand-description {
			font-family: "Questrial", sans-serif;
			font-size: 0.95rem;
			line-height: 1.6;
			color: rgba(255, 245, 235, 0.8);
		}

		.footer-links {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 40px;
		}

		.links-section h4 {
			font-family: "The Seasons", serif;
			font-size: 1.1rem;
			font-weight: 400;
			margin-bottom: 20px;
			color: #fff5eb;
			letter-spacing: 0.5px;
		}

		.links-section ul {
			list-style: none;
			padding: 0;
			margin: 0;
		}

		.links-section li {
			margin-bottom: 12px;
		}

		.links-section a {
			font-family: "Questrial", sans-serif;
			color: rgba(255, 245, 235, 0.8);
			text-decoration: none;
			font-size: 0.9rem;
			transition: all 0.3s ease;
			position: relative;
		}

		.links-section a::before {
			content: "";
			position: absolute;
			bottom: -2px;
			left: 0;
			width: 0;
			height: 1px;
			background: #cb6e5f;
			transition: width 0.3s ease;
		}

		.links-section a:hover {
			color: #fff5eb;
			transform: translateX(5px);
		}

		.links-section a:hover::before {
			width: 100%;
		}

		/* Newsletter section */
		.footer-newsletter {
			background: rgba(255, 245, 235, 0.05);
			padding: 30px;
			border-radius: 20px;
			border: 1px solid rgba(255, 245, 235, 0.1);
		}

		.footer-newsletter h4 {
			font-family: "The Seasons", serif;
			font-size: 1.1rem;
			font-weight: 400;
			margin-bottom: 10px;
			color: #fff5eb;
			letter-spacing: 0.5px;
		}

		.footer-newsletter p {
			font-family: "Questrial", sans-serif;
			font-size: 0.9rem;
			color: rgba(255, 245, 235, 0.8);
			margin-bottom: 20px;
			line-height: 1.5;
		}

		.newsletter-form {
			display: flex;
			flex-direction: column;
			gap: 12px;
		}

		.newsletter-input {
			padding: 12px 16px;
			border: 1px solid rgba(255, 245, 235, 0.2);
			border-radius: 25px;
			background: rgba(255, 245, 235, 0.1);
			color: #fff5eb;
			font-family: "Questrial", sans-serif;
			font-size: 0.9rem;
			outline: none;
			transition: all 0.3s ease;
		}

		.newsletter-input::placeholder {
			color: rgba(255, 245, 235, 0.5);
		}

		.newsletter-input:focus {
			border-color: #cb6e5f;
			background: rgba(255, 245, 235, 0.15);
			box-shadow: 0 0 0 2px rgba(203, 110, 95, 0.2);
		}

		.newsletter-button {
			padding: 12px 20px;
			background: linear-gradient(135deg, #cb6e5f 0%, #d5a18e 100%);
			color: white;
			border: none;
			border-radius: 25px;
			font-family: "Questrial", sans-serif;
			font-size: 0.9rem;
			font-weight: 500;
			cursor: pointer;
			transition: all 0.3s ease;
			position: relative;
			overflow: hidden;
		}

		.newsletter-button::before {
			content: "";
			position: absolute;
			top: 50%;
			left: 50%;
			width: 0;
			height: 0;
			border-radius: 50%;
			background: rgba(255, 255, 255, 0.2);
			transform: translate(-50%, -50%);
			transition:
				width 0.5s,
				height 0.5s;
		}

		.newsletter-button:hover::before {
			width: 200px;
			height: 200px;
		}

		.newsletter-button:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 20px rgba(203, 110, 95, 0.3);
		}

		/* Social media section */
		.footer-social {
			padding: 30px 0;
			border-top: 1px solid rgba(255, 245, 235, 0.1);
			border-bottom: 1px solid rgba(255, 245, 235, 0.1);
			margin-bottom: 30px;
		}

		.social-links {
			display: flex;
			justify-content: center;
			gap: 25px;
		}

		.social-link {
			width: 45px;
			height: 45px;
			border-radius: 50%;
			background: rgba(255, 245, 235, 0.1);
			border: 1px solid rgba(255, 245, 235, 0.2);
			display: flex;
			align-items: center;
			justify-content: center;
			color: rgba(255, 245, 235, 0.8);
			transition: all 0.3s ease;
			text-decoration: none;
		}

		.social-link svg {
			width: 20px;
			height: 20px;
		}

		.social-link:hover {
			background: #cb6e5f;
			border-color: #cb6e5f;
			color: white;
			transform: translateY(-3px);
			box-shadow: 0 5px 15px rgba(203, 110, 95, 0.4);
		}

		/* Company email styling */
		.footer-email {
			margin-top: 25px;
			display: flex;
			justify-content: center;
		}

		.email-link {
			display: flex;
			align-items: center;
			gap: 12px;
			color: rgba(255, 245, 235, 0.8);
			text-decoration: none;
			font-family: "Questrial", sans-serif;
			font-size: 0.95rem;
			padding: 12px 20px;
			border: 1px solid rgba(255, 245, 235, 0.2);
			border-radius: 25px;
			background: rgba(255, 245, 235, 0.05);
			backdrop-filter: blur(10px);
			transition: all 0.3s ease;
			font-weight: 500;
		}

		.email-link:hover {
			color: #fff5eb;
			border-color: #cb6e5f;
			background: rgba(203, 110, 95, 0.1);
			transform: translateY(-2px);
			box-shadow: 0 8px 25px rgba(203, 110, 95, 0.2);
		}

		.email-link svg {
			width: 18px;
			height: 18px;
			opacity: 0.8;
		}

		.email-link:hover svg {
			opacity: 1;
		}

		/* Bottom section */
		.footer-bottom {
			text-align: center;
			padding-bottom: 40px;
		}

		.footer-bottom-content {
			display: flex;
			justify-content: space-between;
			align-items: center;
			flex-wrap: wrap;
			gap: 20px;
		}

		.copyright,
		.made-with-love {
			font-family: "Questrial", sans-serif;
			font-size: 0.85rem;
			color: rgba(255, 245, 235, 0.6);
			margin: 0;
		}

		.made-with-love {
			font-style: italic;
		}

		/* Developer Credit */
		.developer-credit {
			padding: 5px;
			margin-top: 0px;
			text-align: center;
		}

		.developer-credit p {
			margin: 0;
			color: rgba(255, 245, 235, 0.6);
			font-size: 0.85rem;
			font-family: "Questrial", sans-serif;
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
		}

		.developer-credit strong {
			color: rgba(255, 245, 235, 0.8);
		}

		.developer-credit a {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			color: rgba(255, 245, 235, 0.7);
			text-decoration: none;
			transition: all 0.3s ease;
			padding: 4px 8px;
			border-radius: 6px;
			position: relative;
		}

		.developer-credit a::before {
			content: "";
			position: absolute;
			bottom: -2px;
			left: 0;
			width: 0;
			height: 1px;
			background: #cb6e5f;
			transition: width 0.3s ease;
		}

		.developer-credit a:hover {
			color: #fff5eb;
			background: rgba(203, 110, 95, 0.1);
			transform: translateY(-1px);
		}

		.developer-credit a:hover::before {
			width: 100%;
		}

		.developer-credit img {
			width: 16px;
			height: 16px;
			opacity: 0.8;
		}

		.developer-credit a:hover img {
			opacity: 1;
		}

		/* Responsive design */
		@media (max-width: 1024px) {
			.footer-main {
				grid-template-columns: 1fr 1fr;
				gap: 40px;
			}

			.footer-newsletter {
				grid-column: 1 / -1;
				max-width: 400px;
				margin: 0 auto;
			}

			.footer-links {
				grid-template-columns: repeat(2, 1fr);
				gap: 30px;
			}
		}

		@media (max-width: 768px) {
			.footer-container {
				padding: 40px 16px 0;
			}

			.footer-main {
				grid-template-columns: 1fr;
				gap: 40px;
				text-align: center;
			}

			.footer-brand {
				max-width: none;
			}

			.footer-links {
				grid-template-columns: 1fr;
				gap: 30px;
			}

			.footer-newsletter {
				text-align: left;
			}

			.logo-wrapper {
				width: 250px;
				height: 250px;
				opacity: 0.8;
				margin: 0 auto;
			}

			.newsletter-form {
				gap: 15px;
			}

			.social-links {
				gap: 20px;
			}

			.footer-bottom-content {
				flex-direction: column;
				text-align: center;
				gap: 10px;
			}

			.floating-element {
				display: none;
			}
		}

		@media (max-width: 480px) {
			.footer-container {
				padding: 30px 16px 0;
			}

			.footer-brand h3 {
				font-size: 1.5rem;
			}

			.footer-newsletter {
				padding: 25px 20px;
			}

			.social-link {
				width: 44px;
				height: 44px;
			}

			.social-link svg {
				width: 20px;
				height: 20px;
			}

			.email-link {
				font-size: 0.85rem;
				padding: 10px 16px;
			}

			.email-link svg {
				width: 16px;
				height: 16px;
			}
		}
	</style>

	<script>
		const form = document.getElementById("newsletter-form-footer") as HTMLFormElement
		const emailInput = document.getElementById("newsletter-email-footer") as HTMLInputElement
		const submitButton = document.getElementById("newsletter-submit-footer") as HTMLButtonElement
		const messageDiv = document.getElementById("newsletter-message-footer") as HTMLDivElement

		let isSubmitting = false

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()
			e.stopPropagation()

			// Debug - agrega esto temporalmente para ver qué está pasando
			console.log("Form submitted", { isSubmitting, email: emailInput.value })

			if (isSubmitting) {
				console.log("Already submitting, aborting")
				return
			}

			const email = emailInput.value.trim()

			// Basic email validation
			if (!email || !email.includes("@")) {
				showMessage("Por favor, introduce un email válido.", "error")
				return
			}

			// Set loading state
			isSubmitting = true
			submitButton.disabled = true
			submitButton.textContent = "Suscribiendo..."
			hideMessage()

			try {
				console.log("Making POST request to /api/newsletter")

				const response = await fetch("/api/newsletter", {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({ email }),
				})

				console.log("Response received", { status: response.status })

				const data = await response.json()

				if (data.success) {
					console.log("Newsletter subscription successful:", data)
					showMessage(data.message, "success")
					submitButton.textContent = "¡Suscrita!"
					emailInput.value = ""

					// Reset button after 30 seconds
					setTimeout(() => {
						submitButton.textContent = "Suscribirme"
						submitButton.disabled = false
						isSubmitting = false
					}, 30000)
				} else {
					showMessage(data.message, "error")
					resetButton()
				}
			} catch (error) {
				console.error("Newsletter error:", error)
				showMessage("Error al suscribirse. Por favor, intenta de nuevo.", "error")
				resetButton()
			}
		})

		function showMessage(message: string, type: "success" | "error") {
			messageDiv.textContent = message
			messageDiv.className = `mt-4 text-sm ${
				type === "success" ? "text-white-700" : "text-red-700"
			} px-4 py-2 rounded-lg`
			messageDiv.classList.remove("hidden")
		}

		function hideMessage() {
			messageDiv.classList.add("hidden")
		}

		function resetButton() {
			submitButton.textContent = "Suscribirme"
			submitButton.disabled = false
			isSubmitting = false
		}
	</script>
</footer>

---
import InstagramIcon from "@/assets/iconos/instagram.svg"
import TikTokIcon from "@/assets/iconos/tiktok.svg"
import Button from "@/components/ui/button.astro"

// Define the interface for navigation items
interface NavItem {
	href: string
	label: string
	disabled?: boolean
}

// Accept navItems as a prop
interface Props {
	navItems: NavItem[]
}

const { navItems } = Astro.props
---

<!-- Mobile Menu Button -->
<button class="mobile-menu-button" aria-label="Menú" aria-expanded="false">
	<span class="hamburger-line"></span>
	<span class="hamburger-line"></span>
	<span class="hamburger-line"></span>
</button>

<!-- Mobile Menu -->
<div class="mobile-menu">
	<div class="mobile-menu-content">
		<nav class="mt-20 flex flex-1 flex-col gap-2">
			<div class="flex flex-col gap-4">
				{
					navItems.map((item, index) => (
						<a
							href={item.href}
							class:list={[
								"mobile-link",
								{
									"pointer-events-none cursor-not-allowed opacity-50": item.disabled,
								},
							]}
							aria-disabled={item.disabled}
						>
							{item.label}
						</a>
					))
				}
				<div class="mt-6 flex w-full flex-col gap-4">
					<Button
						id="newsletter-modal-mobile-trigger"
						class="border-terracotta text-terracotta hover:bg-terracotta/10 inline-flex w-full items-center justify-center rounded-full border-1 bg-transparent px-6 py-3 font-medium transition-all duration-[400ms] hover:scale-105"
					>
						Únete a la newsletter
					</Button>
					<a
						href={import.meta.env.CALENDLY_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="bg-accent text-accent-foreground hover:bg-accent/90 inline-flex w-full items-center justify-center rounded-full px-6 py-3 font-medium transition-colors duration-300"
					>
						Reserva tu cita
					</a>
				</div>
			</div>
		</nav>

		<!-- Social Links in Mobile Menu -->
		<div class="mobile-social">
			<a
				href="https://www.instagram.com/femm.tribu/"
				target="_blank"
				rel="noopener noreferrer"
				class="mobile-social-link"
				aria-label="Instagram"
			>
				<InstagramIcon />
			</a>
			<a
				href="https://www.tiktok.com/@merypebe"
				target="_blank"
				rel="noopener noreferrer"
				class="mobile-social-link"
				aria-label="TikTok"
			>
				<TikTokIcon />
			</a>
		</div>
	</div>
</div>

<style>
	/* Mobile Menu Button */
	.mobile-menu-button {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: none;
		border: none;
		padding: 8px;
		cursor: pointer;
		z-index: 1001;
		position: relative;
		border-radius: 8px;
		transition: all 0.3s ease;
	}

	.mobile-menu-button:hover {
		background: rgba(203, 110, 95, 0.1);
	}

	.hamburger-line {
		width: 28px;
		height: 3px;
		background: var(--hamburger-color, #fff5eb);
		border-radius: 3px;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: var(--hamburger-shadow, 0 2px 4px rgba(55, 68, 58, 0.2));
	}

	/* Mobile menu button animation */
	.mobile-menu-button.active .hamburger-line:nth-child(1) {
		transform: translateY(9px) rotate(45deg);
	}

	.mobile-menu-button.active .hamburger-line:nth-child(2) {
		opacity: 0;
		transform: translateX(-20px);
	}

	.mobile-menu-button.active .hamburger-line:nth-child(3) {
		transform: translateY(-9px) rotate(-45deg);
	}

	/* Mobile Menu */
	.mobile-menu {
		position: fixed;
		top: 0;
		right: -100%;
		width: 100%;
		max-width: 400px;
		height: 100vh;
		background: linear-gradient(135deg, #fff5eb 0%, #d5a18e 100%);
		transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 1000;
		box-shadow: -10px 0 50px rgba(55, 68, 58, 0.2);
		overflow-y: auto;
	}

	.mobile-menu.active {
		right: 0;
	}

	.mobile-menu-content {
		padding: 100px 40px 40px;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.mobile-link {
		font-family: "The Seasons", serif;
		font-size: 1.8rem;
		color: #37443a;
		text-decoration: none;
		padding: 15px 0;
		transition: all 0.3s ease;
		position: relative;
		border-bottom: 1px solid rgba(55, 68, 58, 0.1);
		display: block;
	}

	.mobile-link::before {
		content: "";
		position: absolute;
		left: -20px;
		top: 50%;
		transform: translateY(-50%);
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, #cb6e5f 0%, #d5a18e 100%);
		transition: width 0.3s ease;
	}

	.mobile-link:hover {
		color: #cb6e5f;
		transform: translateX(10px);
	}

	.mobile-link:hover::before {
		width: 40px;
	}

	/* Mobile Social Links */
	.mobile-social {
		display: flex;
		gap: 20px;
		margin-top: 40px;
		padding-top: 30px;
		border-top: 2px solid rgba(55, 68, 58, 0.1);
	}

	.mobile-social-link {
		width: 50px;
		height: 50px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.5);
		backdrop-filter: blur(10px);
		border: 2px solid rgba(203, 110, 95, 0.2);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #37443a;
		transition: all 0.3s ease;
		text-decoration: none;
	}

	.mobile-social-link svg {
		width: 24px;
		height: 24px;
	}

	.mobile-social-link:hover {
		background: rgba(203, 110, 95, 0.9);
		color: white;
		transform: translateY(-3px);
		box-shadow: 0 8px 20px rgba(203, 110, 95, 0.3);
	}

	/* Overlay when mobile menu is open */
	.mobile-menu::before {
		content: "";
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		backdrop-filter: blur(5px);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.4s ease;
		z-index: -1;
	}

	.mobile-menu.active::before {
		opacity: 1;
		pointer-events: all;
		left: -100vw;
	}

	@media (max-width: 768px) {
		.mobile-menu-button {
			display: flex;
		}
		.mobile-menu {
			max-width: 100%;
		}

		.mobile-menu-content {
			padding: 80px 30px 40px;
		}

		.mobile-link {
			font-size: 1.5rem;
		}
	}

	@media (max-width: 480px) {
		.mobile-menu-content {
			padding: 70px 20px 30px;
		}

		.mobile-link {
			font-size: 1.3rem;
			padding: 12px 0;
		}

		.mobile-social-link {
			width: 45px;
			height: 45px;
		}

		.mobile-social-link svg {
			width: 22px;
			height: 22px;
		}
	}

	/* Decorative elements */
	.mobile-menu::after {
		content: "";
		position: absolute;
		top: -100px;
		right: -100px;
		width: 300px;
		height: 300px;
		background: radial-gradient(circle, rgba(203, 110, 95, 0.1) 0%, transparent 70%);
		border-radius: 50%;
		pointer-events: none;
		animation: float 20s ease-in-out infinite;
	}

	@keyframes float {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg);
		}
		33% {
			transform: translate(20px, -20px) rotate(120deg);
		}
		66% {
			transform: translate(-10px, 10px) rotate(240deg);
		}
	}
</style>

<script>
	function initMobileMenu() {
		const newsletterModalMobileTrigger = document.getElementById("newsletter-modal-mobile-trigger")
		newsletterModalMobileTrigger?.addEventListener("click", () => {
			window.modalManager.open("newsletter-modal")
		})
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initMobileMenu)
	} else {
		initMobileMenu()
	}
</script>

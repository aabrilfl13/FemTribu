---
import MobileMenu from "@/components/layout/MobileMenu.astro"
import NewsletterModal from "@/components/modals/NewsletterModal.astro"
import Button from "@/components/ui/button.astro"

interface Props {
	scrolled?: boolean
}

const { scrolled = false } = Astro.props

const navItems = [
	{ label: "Inicio", href: "/#" },
	{ label: "Sobre Femm tribu", href: "/#sobre-femm-tribu" },
	{ label: "Servicios", href: "/#servicios" },
	{ label: "Talleres y eventos ", href: "/cursos/curso-lactancia" },
]
---

<header
	id="main-nav"
	data-force-scrolled={scrolled}
	class:list={[
		"border-border/50 [&.scrolled]:bg-background/75 fixed top-0 right-0 left-0 z-[1000] bg-transparent py-5 transition-all duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)] [&.scrolled]:py-3 [&.scrolled]:shadow-[0_4px_30px_rgba(55,68,58,0.08)] [&.scrolled]:backdrop-blur-md",
		{ scrolled: scrolled },
	]}
>
	<div class="container mx-auto px-4 lg:px-8">
		<div
			class="flex h-15 items-center justify-between lg:justify-center lg:[.scrolled_&]:justify-between"
		>
			{/* Logo */}
			<a
				href="/"
				class="group relative z-[1001] flex items-center transition-all duration-300 lg:absolute lg:left-8 lg:[.scrolled_&]:relative"
			>
				<img
					src="/images/logos/logo_icono.svg"
					alt="Femm Tribu"
					class="h-[60px] w-auto opacity-0 drop-shadow-[0_2px_8px_rgba(55,68,58,0.15)] transition-all duration-[400ms] group-hover:scale-105 group-hover:drop-shadow-[0_4px_12px_rgba(203,110,95,0.3)] [.scrolled_&]:h-[50px] [.scrolled_&]:opacity-100"
				/>
				<div class="block opacity-0 transition-opacity duration-[400ms] [.scrolled_&]:opacity-100">
					<span class="font-display text-primary text-2xl">Femm</span>
					<span class="font-display text-accent text-2xl">tribu</span>
				</div>
			</a>

			{/* Desktop Navigation */}
			<nav class="hidden items-center gap-10 lg:flex">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="nav-link relative py-2 text-base font-medium tracking-[0.5px] text-[#fff5eb] no-underline transition-all duration-300 [text-shadow:0_2px_4px_rgba(55,68,58,0.3)] after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-0 after:bg-gradient-to-r after:from-[#cb6e5f] after:to-[#d5a18e] after:transition-[width] after:duration-300 after:content-[''] hover:text-[#cb6e5f] hover:[text-shadow:0_2px_8px_rgba(203,110,95,0.3)] hover:after:w-full [.scrolled_&]:text-[#37443a] [.scrolled_&]:[text-shadow:none]"
						>
							{item.label}
						</a>
					))
				}
			</nav>

			{/* CTA Buttons */}
			<div class="hidden items-center gap-3 md:hidden md:[.scrolled_&]:flex">
				<Button
					id="newsletter-modal-trigger"
					class="border-terracotta text-terracotta hover:bg-terracotta/10 inline-flex items-center justify-center rounded-full border-1 bg-transparent px-6 py-3 font-medium transition-all duration-[400ms] hover:scale-105"
				>
					<span class="lg:hidden">Únete a la newsletter</span><span
						class="hidden lg:inline xl:hidden">Únete</span
					><span class="hidden xl:inline">Únete a la newsletter</span>
				</Button>
				<a
					href={import.meta.env.CALENDLY_URL}
					target="_blank"
					rel="noopener noreferrer"
					class="bg-accent text-accent-foreground hover:bg-accent/90 inline-flex items-center justify-center rounded-full px-6 py-3 font-medium transition-all duration-[400ms] hover:scale-105"
				>
					Reserva tu cita
				</a>
			</div>

			<MobileMenu navItems={navItems} />
		</div>
	</div>
</header>

{/* Newsletter Modal */}
<NewsletterModal />

<style>
	/* CSS Custom Properties for MobileMenu communication */
	#main-nav {
		--hamburger-color: #fff5eb;
		--hamburger-shadow: 0 2px 4px rgba(55, 68, 58, 0.2);
	}

	#main-nav.scrolled {
		--hamburger-color: #37443a;
		--hamburger-shadow: none;
	}
</style>

<script define:vars={{ forceScrolled: scrolled }}>
	// Navigation scroll behavior
	function initNav() {
		const nav = document.getElementById("main-nav")
		const mobileMenuButton = document.querySelector(".mobile-menu-button")
		const mobileMenu = document.querySelector(".mobile-menu")
		const newsletterModalTrigger = document.getElementById("newsletter-modal-trigger")

		if (!nav) return

		// Newsletter modal trigger
		newsletterModalTrigger?.addEventListener("click", () => {
			window.modalManager.open("newsletter-modal")
		})

		// Handle scroll to add background
		let lastScroll = 0
		const handleScroll = () => {
			const currentScroll = window.pageYOffset

			// Add scrolled class for background
			if (forceScrolled || currentScroll > 100) {
				nav.classList.add("scrolled")
			} else {
				nav.classList.remove("scrolled")
			}
		}

		// Mobile menu toggle (if mobile menu exists)
		if (mobileMenuButton && mobileMenu) {
			const toggleMobileMenu = () => {
				const isActive = mobileMenuButton.classList.toggle("active")
				mobileMenu.classList.toggle("active")
				mobileMenuButton.setAttribute("aria-expanded", isActive.toString())

				if (isActive) {
					document.body.style.overflow = "hidden"
				} else {
					document.body.style.overflow = ""
				}
			}

			const closeMobileMenu = () => {
				mobileMenuButton.classList.remove("active")
				mobileMenu.classList.remove("active")
				mobileMenuButton.setAttribute("aria-expanded", "false")
				document.body.style.overflow = ""
			}

			mobileMenuButton.addEventListener("click", toggleMobileMenu)

			mobileMenu.addEventListener("click", (e) => {
				if (e.target === mobileMenu) {
					closeMobileMenu()
				}
			})

			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape" && mobileMenuButton.classList.contains("active")) {
					closeMobileMenu()
				}
			})

			const mobileLinks = document.querySelectorAll(".mobile-link")
			mobileLinks.forEach((link) => {
				link.addEventListener("click", (e) => {
					const href = link.getAttribute("href")
					if (!href) return

					// Check if we're on the same page (home or current path)
					const url = new URL(href, window.location.href)
					const isCurrentPage = url.pathname === window.location.pathname
					const hash = url.hash

					// Only handle smooth scroll if we're on the same page and there's a hash
					if (isCurrentPage && hash) {
						e.preventDefault()
						const targetElement = document.querySelector(hash)

						if (targetElement) {
							const navHeight = nav.offsetHeight
							const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset
							const offsetPosition = targetPosition - navHeight - 20

							window.scrollTo({
								top: offsetPosition,
								behavior: "smooth",
							})
						}
						closeMobileMenu()
					}
					// For links to other pages, close menu and let them navigate naturally
					else {
						closeMobileMenu()
					}
				})
			})
		}

		// Smooth scroll for desktop nav links
		const navLinks = document.querySelectorAll(".nav-link")
		navLinks.forEach((link) => {
			link.addEventListener("click", (e) => {
				const href = link.getAttribute("href")

				// Check if we're on the same page (home or current path)
				const url = new URL(href, window.location.href)
				const isCurrentPage = url.pathname === window.location.pathname
				const hash = url.hash

				// Only handle smooth scroll if we're on the same page and there's a hash
				if (isCurrentPage && hash) {
					e.preventDefault()
					const targetElement = document.querySelector(hash)

					if (targetElement) {
						const navHeight = nav.offsetHeight
						const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset
						const offsetPosition = targetPosition - navHeight - 20

						window.scrollTo({
							top: offsetPosition,
							behavior: "smooth",
						})
					}
				}
				// For links to other pages, let them navigate naturally
			})
		})

		window.addEventListener("scroll", handleScroll, { passive: true })
		handleScroll()
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initNav)
	} else {
		initNav()
	}
</script>

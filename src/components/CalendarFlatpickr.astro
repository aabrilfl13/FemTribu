---
// src/components/CalendarFlatpickr.astro
interface Props {
	id?: string
	name?: string
	placeholder?: string
	inline?: boolean
	mode?: "single" | "multiple" | "range"
	minDate?: string
	maxDate?: string
}

const {
	id = "datepicker",
	name = "date",
	placeholder = "Selecciona una fecha",
	inline = false,
	mode = "single",
	minDate,
	maxDate,
} = Astro.props
---

<div class="calendar-flatpickr">
	<input
		type="text"
		id={id}
		name={name}
		class="w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-900 placeholder:text-gray-400 focus:border-transparent focus:ring-2 focus:ring-blue-600"
		placeholder={placeholder}
		data-inline={inline}
		data-mode={mode}
		data-min-date={minDate}
		data-max-date={maxDate}
	/>
</div>

<script>
	import flatpickr from "flatpickr"
	import { Spanish } from "flatpickr/dist/l10n/es.js"

	document.querySelectorAll(".calendar-flatpickr input").forEach((input) => {
		const htmlInput = input as HTMLInputElement
		const isInline = htmlInput.getAttribute("data-inline") === "true"
		const mode =
			(htmlInput.getAttribute("data-mode") as "single" | "multiple" | "range") || "single"
		const minDate = htmlInput.getAttribute("data-min-date") || undefined
		const maxDate = htmlInput.getAttribute("data-max-date") || undefined

		flatpickr(htmlInput, {
			locale: Spanish,
			dateFormat: "d/m/Y",
			inline: isInline,
			mode: mode,
			minDate: minDate,
			maxDate: maxDate,
			// Opciones adicionales útiles:
			disableMobile: true, // Fuerza el picker custom en móviles
			// defaultDate: 'today',
			// enable: [
			//   function(date) {
			//     // Habilitar solo días laborables
			//     return (date.getDay() !== 0 && date.getDay() !== 6);
			//   }
			// ],
			onChange: function (selectedDates, dateStr, instance) {
				// Callback cuando cambia la fecha
				console.log("Fecha seleccionada:", dateStr)
			},
		})
	})
</script>

<style is:global>
	/* Sin @apply, solo CSS vanilla */
	.flatpickr-calendar {
		border-radius: 0.5rem;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
		border: 1px solid #e5e7eb;
		background-color: white;
		font-family: inherit;
	}

	.flatpickr-months {
		padding: 0.75rem 0.75rem 0.5rem;
	}

	.flatpickr-current-month {
		font-size: 0.875rem;
		font-weight: 500;
		color: #111827;
	}

	.flatpickr-prev-month,
	.flatpickr-next-month {
		padding: 0.375rem;
		border-radius: 0.375rem;
		transition: background-color 150ms;
		position: static;
	}

	.flatpickr-prev-month:hover,
	.flatpickr-next-month:hover {
		background-color: #f3f4f6;
	}

	.flatpickr-day {
		height: 2.25rem;
		width: 2.25rem;
		border-radius: 0.375rem;
		border: none;
		color: #111827;
	}

	.flatpickr-day:hover {
		background-color: #f3f4f6;
	}

	.flatpickr-day.today {
		background-color: #f3f4f6;
		font-weight: 500;
	}

	.flatpickr-day.selected {
		background-color: #2563eb;
		color: white;
	}

	.flatpickr-day.selected:hover {
		background-color: #1d4ed8;
	}
</style>

---
// src/components/Footer.astro
import Logo from "../assets/iconos/ilustracion-negro_27.svg"
---

<footer class="footer">
	<div class="footer-container">
		<!-- Decorative elements -->
		<div class="floating-element one"></div>
		<div class="floating-element two"></div>

		<div class="footer-content">
			<!-- Main footer section -->
			<div class="footer-main">
				<div class="footer-brand">
					<div class="logo-wrapper">
						<Logo />
					</div>
					<h3>Femm Tribu</h3>
					<p class="brand-description">
						Apoyando a las madres en su camino con un cuidado compasivo y una fuerza inquebrantable.
					</p>
				</div>

				<div class="footer-links">
					<div class="links-section">
						<h4>Recursos</h4>
						<ul>
							<li><a href="#videos">Vídeos</a></li>
							<li><a href="#guias">Guías</a></li>
							<li><a href="#testimonios">Testimonios</a></li>
							<li><a href="#blog">Blog</a></li>
						</ul>
					</div>

					<div class="links-section">
						<h4>Comunidad</h4>
						<ul>
							<li><a href="#eventos">Eventos</a></li>
							<li><a href="#grupos">Grupos de apoyo</a></li>
							<li><a href="#profesionales">Profesionales</a></li>
							<li><a href="#contacto">Contacto</a></li>
						</ul>
					</div>

					<div class="links-section">
						<h4>Legal</h4>
						<ul>
                            <li><a href="/privacy">Política de privacidad</a></li>
							<li><a href="#terminos">Términos de uso</a></li>
							<li><a href="#cookies">Cookies</a></li>
						</ul>
					</div>
				</div>

				<div class="footer-newsletter">
					<h4>Mantente conectada</h4>
					<p>Recibe nuestras últimas actualizaciones y recursos exclusivos</p>
					<form class="newsletter-form">
						<input type="email" placeholder="tu@email.com" class="newsletter-input" />
						<button type="submit" class="newsletter-button"> Suscribirme </button>
					</form>
				</div>
			</div>

			<!-- Social media section -->
			<div class="footer-social">
				<div class="social-links">
					<a href="#" class="social-link" aria-label="Instagram">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
							></path>
						</svg>
					</a>
					<a href="#" class="social-link" aria-label="Facebook">

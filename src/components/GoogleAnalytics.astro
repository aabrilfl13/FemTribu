---
const GA_ID = import.meta.env.PUBLIC_GA_ID || "G-XXXXXXXXXX"
const ENV = import.meta.env.ENV || "production"
const isDevelopment = ENV === "development"
---

<script define:vars={{ GA_ID, isDevelopment }}>
	if (!isDevelopment) {
		function loadGAScript() {
			if (document.getElementById("ga-external-script")) return

			const script = document.createElement("script")
			script.id = "ga-external-script"
			script.async = true
			script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`
			document.head.appendChild(script)

			window.dataLayer = window.dataLayer || []
			function gtag() {
				dataLayer.push(arguments)
			}
			window.gtag = gtag
			gtag("js", new Date())
			gtag("config", GA_ID)

			console.log("GA4: Activado tras consentimiento.")
		}

		window.addEventListener("load-analytics-services", loadGAScript)
	}
</script>

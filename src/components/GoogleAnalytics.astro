---
const GA_ID = import.meta.env.PUBLIC_GA_ID || "G-XXXXXXXXXX"
---

<script define:vars={{ GA_ID }}>
	// Creamos una función para cargar el script de Google de forma dinámica
	function loadGAScript() {
		if (document.getElementById("ga-external-script")) return // Evitar duplicados

		const script = document.createElement("script")
		script.id = "ga-external-script"
		script.async = true
		script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`
		document.head.appendChild(script)

		window.dataLayer = window.dataLayer || []
		function gtag() {
			dataLayer.push(arguments)
		}
		window.gtag = gtag // Hacerlo global
		gtag("js", new Date())
		gtag("config", GA_ID)

		console.log("GA4: Activado tras consentimiento.")
	}

	// Escuchar el evento que enviamos desde Layout.astro
	window.addEventListener("load-analytics-services", loadGAScript)
</script>

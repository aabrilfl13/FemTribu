---
const GA_ID = import.meta.env.PUBLIC_GA_ID || "G-XXXXXXXXXX"
const isDevelopment = import.meta.env.DEV
---

<script is:inline define:vars={{ GA_ID, isDevelopment }}>
	if (!isDevelopment) {
		// Consent Mode v2: initialize dataLayer and gtag immediately, before any script loads
		window.dataLayer = window.dataLayer || []
		function gtag() {
			dataLayer.push(arguments)
		}
		window.gtag = gtag

		// Set default consent to denied (Basic mode — no data sent to Google before consent)
		gtag("consent", "default", {
			analytics_storage: "denied",
			ad_storage: "denied",
			ad_user_data: "denied",
			ad_personalization: "denied",
		})

		function loadGAScript(userId) {
			if (document.getElementById("ga-external-script")) {
				// Script already loaded — just set user_id if it became available
				if (userId) gtag("config", GA_ID, { user_id: userId })
				return
			}

			gtag("consent", "update", {
				analytics_storage: "granted",
			})

			const script = document.createElement("script")
			script.id = "ga-external-script"
			script.async = true
			script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`
			document.head.appendChild(script)

			gtag("js", new Date())
			gtag("config", GA_ID, userId ? { user_id: userId } : undefined)

			// console.log("GA4: Activado tras consentimiento.")
		}

		window.addEventListener("load-analytics-services", (event) => {
			const userId = event?.detail?.userId ?? null
			loadGAScript(userId)
		})
	}
</script>

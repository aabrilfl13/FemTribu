---
interface VideoMeta {
	url: string
	secureUrl?: string
	width?: number
	height?: number
	thumbnailUrl?: string
}

interface Props {
	title?: string
	description?: string
	image?: string
	type?: "website" | "article"
	noindex?: boolean
	video?: VideoMeta
}

const {
	title = "Femm tribu",
	description = "Acompañamiento a mujeres en todas las etapas de su vida para entender su cuerpo y mejorar su salud. Salud hormonal, embarazo, lactancia, menopausia.",
	image = "images/og-hands-together.webp", // imagen por defecto
	type = "website",
	noindex = false,
	video,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImage = video?.thumbnailUrl || image
const fullImageUrl = video?.thumbnailUrl
	? video.thumbnailUrl
	: new URL(ogImage, Astro.site).toString()
const isDevelopment = import.meta.env.ENV === "development"
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Robots Meta Tags -->
{
	noindex || isDevelopment ? (
		<>
			<meta name="robots" content="noindex, nofollow" />
			<meta name="googlebot" content="noindex, nofollow" />
		</>
	) : (
		<>
			<meta name="robots" content="index, follow, noai, noimageai" />
			<meta name="googlebot" content="index, follow, noai, noimageai" />
		</>
	)
}

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:locale" content="es_ES" />
<meta property="og:site_name" content="Femm tribu" />

{
	video && (
		<>
			<meta property="og:video" content={video.url} />
			<meta property="og:video:secure_url" content={video.secureUrl || video.url} />
			<meta property="og:video:type" content="text/html" />
			{video.width && <meta property="og:video:width" content={String(video.width)} />}
			{video.height && <meta property="og:video:height" content={String(video.height)} />}
		</>
	)
}

<!-- Twitter -->
<meta name="twitter:card" content={video ? "player" : "summary_large_image"} />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />

{
	video && (
		<>
			<meta name="twitter:player" content={video.secureUrl || video.url} />
			{video.width && <meta name="twitter:player:width" content={String(video.width)} />}
			{video.height && <meta name="twitter:player:height" content={String(video.height)} />}
		</>
	)
}

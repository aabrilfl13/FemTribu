---
import videosData from "../data/videos.json"
import EmailOverlay from "./EmailOverlay.astro"
import VerificationOverlay from "./VerificationOverlay.astro"

const { videos, timezone } = videosData

// Function to create timezone-aware date
function createTimezoneAwareDate(dateString: string, timezone: string) {
	// If the date doesn't have timezone info, interpret it in the specified timezone
	if (!dateString.includes("Z") && !dateString.includes("+") && !dateString.includes("-")) {
		// Parse the date as if it's in the specified timezone
		return new Date(dateString + " UTC")
	}
	return new Date(dateString)
}

// Function to check if video is unlocked
function isVideoUnlocked(unlockDate: string, timezone: string) {
	const now = new Date()
	const unlock = createTimezoneAwareDate(unlockDate, timezone)
	return now >= unlock
}

// Function to format time until unlock
function formatTimeUntilUnlock(unlockDate: string, timezone: string) {
	const now = new Date()
	const unlock = createTimezoneAwareDate(unlockDate, timezone)
	const diff = unlock.getTime() - now.getTime()

	if (diff <= 0) return "Disponible ahora"

	const days = Math.floor(diff / (1000 * 60 * 60 * 24))
	const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))

	if (days > 0) {
		return `${days} día${days !== 1 ? "s" : ""}`
	} else if (hours > 0) {
		return `${hours} hora${hours !== 1 ? "s" : ""}`
	} else {
		return "Menos de una hora"
	}
}

// Process videos with lock status
const processedVideos = videos.map((video) => ({
	...video,
	isLocked: !isVideoUnlocked(video.unlockDate, timezone),
	timeUntilUnlock: formatTimeUntilUnlock(video.unlockDate, timezone),
	unlockDateFormatted: createTimezoneAwareDate(video.unlockDate, timezone).toLocaleDateString(
		"es-ES",
		{
			year: "numeric",
			month: "long",
			day: "numeric",
			hour: "2-digit",
			minute: "2-digit",
			timeZone: timezone,
		}
	),
}))
---

<section class="videos-section" id="videos">
	<div class="videos-container">
		<div class="videos-header">
			<h2>Nuestros Recursos</h2>
			<p>
				Explora contenido cuidadosamente seleccionado para acompañarte en cada etapa de tu viaje
			</p>
		</div>

		<div class="videos-grid-wrapper">
			<EmailOverlay />
			<VerificationOverlay />

			<div class="videos-grid">
				{
					processedVideos.map((video, index) => (
						<div
							class="video-card"
							style={`animation-delay: ${0.1 * (index + 1)}s`}
							data-video-id={video.youtubeId}
							data-unlock-date={video.unlockDate}
							data-timezone={timezone}
						>
							<div class="video-wrapper">
								{!video.isLocked ? (
									<iframe
										data-youtube-id={video.youtubeId}
										title={video.title}
										loading="lazy"
										allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
										referrerpolicy="strict-origin-when-cross-origin"
										allowfullscreen
									/>
								) : (
									<div class="video-placeholder">
										<div class="placeholder-content">
											<img
												src="/images/decoratives/ilustracion-negro_24.svg"
												alt=""
												class="placeholder-icon"
											/>
											<div class="video-info-preview">
												<h3>{video.title}</h3>
												<p>{video.description}</p>
											</div>
										</div>
									</div>
								)}

								{/* Unlock Overlay for locked videos */}
								{video.isLocked && (
									<div class="unlock-overlay">
										<div class="unlock-content">
											<div class="lock-icon">
												<svg viewBox="0 0 24 24" fill="currentColor">
													<path d="M18,8h-1V6c0-2.76-2.24-5-5-5S7,3.24,7,6v2H6c-1.1,0-2,0.9-2,2v10c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V10C20,8.9,19.1,8,18,8z M12,17c-1.1,0-2-0.9-2-2s0.9-2,2-2s2,0.9,2,2S13.1,17,12,17z M15.1,8H8.9V6c0-1.71,1.39-3.1,3.1-3.1c1.71,0,3.1,1.39,3.1,3.1V8z" />
												</svg>
											</div>
											<div class="unlock-text">
												<h4>Se desbloquea en</h4>
												<p
													class="countdown"
													data-unlock-date={video.unlockDate}
													data-timezone={timezone}
												>
													{video.timeUntilUnlock}
												</p>
												<span class="unlock-date">{video.unlockDateFormatted}</span>
											</div>
										</div>
									</div>
								)}
							</div>

							<div class="video-info">
								<h3 class="video-title">{video.title}</h3>
								<p class="video-description">{video.description}</p>
								<div class="video-tags">
									{video.tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	/* Sección de Vídeos */
	.videos-section {
		margin-top: 60px;
		padding: 80px 20px;
		background: #fff5eb;
		position: relative;
		overflow: hidden;
	}

	/* Patrón decorativo de fondo */
	.videos-section::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image:
			radial-gradient(circle at 10% 20%, rgba(106, 128, 103, 0.03) 0%, transparent 50%),
			radial-gradient(circle at 80% 80%, rgba(203, 110, 95, 0.03) 0%, transparent 50%),
			radial-gradient(circle at 40% 60%, rgba(213, 161, 142, 0.02) 0%, transparent 70%);
		pointer-events: none;
	}

	.videos-container {
		max-width: 1400px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
		max-width: 1024px;
	}

	.videos-header {
		text-align: center;
		margin-bottom: 60px;
	}

	.videos-header h2 {
		font-size: 2.5rem;
		color: #37443a;
		font-weight: 300;
		letter-spacing: 1px;
		margin-bottom: 15px;
		position: relative;
		display: inline-block;
	}

	/* Elemento decorativo circular */
	.videos-header h2::before {
		content: url("../assets/iconos/ilustracion-negro_24.svg");
		position: absolute;
		top: -20px;
		right: -40px;
		width: 60px;
		height: 60px;
		opacity: 0.3;
		animation: pulse 3s ease-in-out infinite;
	}

	/* Elemento decorativo circular */
	@keyframes pulse {
		0%,
		100% {
			transform: scale(1);
			opacity: 0.3;
		}
		50% {
			transform: scale(1.1);
			opacity: 0.5;
		}
	}

	.videos-header p {
		color: #6a8067;
		font-size: 1.1rem;
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.6;
	}

	/* Videos grid wrapper for overlay */
	.videos-grid-wrapper {
		position: relative;
		margin-left: auto;
		margin-right: auto;
	}

	/* Grid de vídeos */
	.videos-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		grid-template-rows: repeat(2, 1fr);
		gap: 40px;
		margin-bottom: 40px;
		/* max-width: 1000px;  /* This will limit the width */
		margin-left: auto;
		margin-right: auto;
	}

	.video-card {
		background: white;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 10px 30px rgba(55, 68, 58, 0.08);
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		opacity: 0;
		transform: translateY(30px);
		animation: fadeInUp 0.6s ease forwards;
	}

	/* Locked video card styling */
	.video-card:has(.unlock-overlay) {
		background: linear-gradient(
			135deg,
			rgba(106, 128, 103, 0.05) 0%,
			rgba(203, 110, 95, 0.03) 100%
		);
	}

	@keyframes fadeInUp {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.video-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, #cb6e5f 0%, #d5a18e 100%);
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.4s ease;
	}

	.video-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 20px 40px rgba(55, 68, 58, 0.15);
	}

	.video-card:hover::before {
		transform: scaleX(1);
	}

	.video-wrapper {
		position: relative;
		padding-bottom: 56.25%; /* 16:9 */
		height: 0;
		overflow: hidden;
		background: linear-gradient(135deg, #6a8067 0%, #37443a 100%);
	}

	.video-wrapper iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: none;
	}

	/* Video placeholder for locked content */
	.video-placeholder {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #6a8067 0%, #37443a 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0.7;
	}

	.placeholder-content {
		text-align: center;
		color: white;
		padding: 20px;
		max-width: 80%;
	}

	.placeholder-icon {
		width: 60px;
		height: 60px;
		opacity: 0.6;
		margin: 0 auto 15px;
		filter: invert(1);
	}

	.video-info-preview h3 {
		font-size: 1rem;
		margin: 0 0 8px 0;
		opacity: 0.9;
	}

	.video-info-preview p {
		font-size: 0.85rem;
		margin: 0;
		opacity: 0.7;
		line-height: 1.4;
	}

	/* Unlock Overlay Styles */
	.unlock-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(55, 68, 58, 0.95);
		backdrop-filter: blur(10px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 10;
	}

	.unlock-content {
		text-align: center;
		color: rgb(183, 182, 182);
		padding: 20px;
		animation: unlock-pulse 5s ease-in-out infinite;
	}

	@keyframes unlock-pulse {
		0%,
		100% {
			transform: scale(1);
			opacity: 1;
		}
		50% {
			transform: scale(1.05);
			opacity: 0.9;
		}
	}

	.lock-icon {
		width: 48px;
		height: 48px;
		margin: 0 auto 15px;
		opacity: 0.9;
	}

	.lock-icon svg {
		width: 100%;
		height: 100%;
		color: #fff5eb;
	}

	.unlock-text h4 {
		font-family: "The Seasons", serif;
		font-size: 1.1rem;
		margin: 0 0 8px 0;
		font-weight: 400;
		letter-spacing: 0.5px;
	}

	.countdown {
		font-size: 1.3rem;
		font-weight: 500;
		color: #d5a18e;
		margin: 0 0 8px 0;
		text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
	}

	.unlock-date {
		font-size: 0.85rem;
		opacity: 0.8;
		font-style: italic;
	}

	.video-info {
		padding: 25px;
		background: white;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.video-title {
		font-size: 1.2rem;
		color: #37443a;
		margin-bottom: 10px;
		font-weight: 400;
		letter-spacing: 0.5px;
	}

	.video-description {
		font-size: 0.95rem;
		color: #6a8067;
		line-height: 1.6;
		margin-bottom: 15px;
	}

	.video-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tag {
		padding: 5px 12px;
		background: linear-gradient(135deg, rgba(203, 110, 95, 0.1), rgba(213, 161, 142, 0.1));
		border-radius: 20px;
		font-size: 0.85rem;
		color: #a22f11;
		border: 1px solid rgba(203, 110, 95, 0.2);
		transition: all 0.3s ease;
	}

	.tag:hover {
		background: linear-gradient(135deg, rgba(203, 110, 95, 0.2), rgba(213, 161, 142, 0.2));
		transform: translateY(-2px);
	}

	@media (max-width: 1024px) {
		.videos-grid-wrapper {
			max-width: 800px;
		}

		.videos-grid {
			gap: 30px;
		}
	}

	@media (max-width: 768px) {
		.videos-section {
			padding: 60px 15px;
		}

		.videos-header h2 {
			font-size: 2rem;
		}

		.videos-grid {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			gap: 30px;
		}

		.unlock-content {
			padding: 15px;
		}

		.countdown {
			font-size: 1.1rem;
		}

		.lock-icon {
			width: 40px;
			height: 40px;
			margin-bottom: 12px;
		}
	}
</style>

<script>
	import EmailVerificationManager from "../utils/emailVerification.ts"

	// Extend Window interface to include emailVerificationManager
	declare global {
		interface Window {
			emailVerificationManager: EmailVerificationManager
		}
	}

	/**
	 * Get the appropriate YouTube URL based on cookie preferences
	 * @param {string} videoId - YouTube video ID
	 * @returns {string} - Complete YouTube embed URL
	 */
	function getYouTubeEmbedUrl(videoId: string): string {
		// Check if cookie manager exists and YouTube cookies are enabled
		const cookieManager = (window as any).cookieManager
		const isYouTubeCookiesEnabled = cookieManager?.isCategoryEnabled?.("youtube") || false

		// Use no-cookie domain if YouTube cookies are not enabled
		const domain = isYouTubeCookiesEnabled ? "www.youtube.com" : "www.youtube-nocookie.com"
		return `https://${domain}/embed/${videoId}`
	}

	// Function to create timezone-aware date on client side
	function createClientTimezoneAwareDate(dateString: string, timezone: string) {
		// If the date doesn't have timezone info, interpret it in the specified timezone
		if (!dateString.includes("Z") && !dateString.includes("+") && !dateString.includes("-")) {
			// Parse the date as if it's in UTC (since we want Spain time to be treated as Spain time)
			return new Date(dateString + " UTC")
		}
		return new Date(dateString)
	}

	// Update countdown timers and unlock videos when time comes
	function updateCountdowns() {
		// Check both countdown elements and video cards for unlocking
		const videoCards = document.querySelectorAll(".video-card[data-unlock-date]")

		videoCards.forEach((videoCard) => {
			const unlockDateString = videoCard.getAttribute("data-unlock-date")
			const timezone = videoCard.getAttribute("data-timezone") || "Europe/Madrid"
			const youtubeId = videoCard.getAttribute("data-video-id")

			if (!unlockDateString || !youtubeId) return

			const unlockDate = createClientTimezoneAwareDate(unlockDateString, timezone)
			const now = new Date()
			const diff = unlockDate.getTime() - now.getTime()

			const unlockOverlay = videoCard.querySelector(".unlock-overlay") as HTMLElement
			const countdownElement = videoCard.querySelector(".countdown") as HTMLElement
			const videoWrapper = videoCard.querySelector(".video-wrapper") as HTMLElement

			if (diff <= 0) {
				// Video should be unlocked
				if (unlockOverlay && videoWrapper) {
					// Remove the unlock overlay with a smooth transition
					unlockOverlay.style.transition = "opacity 0.5s ease"
					unlockOverlay.style.opacity = "0"

					setTimeout(() => {
						// Replace the placeholder with the actual iframe
						const videoPlaceholder = videoWrapper.querySelector(".video-placeholder")
						if (videoPlaceholder) {
							const iframe = document.createElement("iframe")
							iframe.src = getYouTubeEmbedUrl(youtubeId)
							iframe.title = videoCard.querySelector(".video-title")?.textContent || ""
							iframe.loading = "lazy"
							iframe.allow =
								"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							iframe.setAttribute("referrerpolicy", "strict-origin-when-cross-origin")
							iframe.allowFullscreen = true
							iframe.style.position = "absolute"
							iframe.style.top = "0"
							iframe.style.left = "0"
							iframe.style.width = "100%"
							iframe.style.height = "100%"
							iframe.style.border = "none"

							// Replace placeholder with iframe
							videoWrapper.removeChild(videoPlaceholder)
							videoWrapper.appendChild(iframe)
						}

						// Remove the unlock overlay completely
						if (unlockOverlay.parentNode) {
							unlockOverlay.parentNode.removeChild(unlockOverlay)
						}

						// Remove the data attribute to prevent further processing
						videoCard.removeAttribute("data-unlock-date")
					}, 500)
				}
				return
			}

			// Update countdown text if still locked
			if (countdownElement) {
				const days = Math.floor(diff / (1000 * 60 * 60 * 24))
				const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))
				const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))

				let timeText
				if (days > 0) {
					timeText = `${days} día${days !== 1 ? "s" : ""}`
				} else if (hours > 0) {
					timeText = `${hours} hora${hours !== 1 ? "s" : ""}`
				} else if (minutes > 0) {
					timeText = `${minutes} minuto${minutes !== 1 ? "s" : ""}`
				} else {
					timeText = "Menos de un minuto"
				}

				countdownElement.textContent = timeText
			}
		})
	}

	// Initialize when DOM is loaded
	document.addEventListener("DOMContentLoaded", () => {
		// Initialize email verification manager
		const verificationManager = new EmailVerificationManager()

		// Store reference globally for potential external access
		window.emailVerificationManager = verificationManager

		// Set YouTube URLs for unlocked videos based on cookie preferences
		const unlockedIframes = document.querySelectorAll("iframe[data-youtube-id]")
		unlockedIframes.forEach((iframe) => {
			const youtubeId = iframe.getAttribute("data-youtube-id")
			if (youtubeId && iframe instanceof HTMLIFrameElement) {
				iframe.src = getYouTubeEmbedUrl(youtubeId)
			}
		})

		// Update countdowns
		updateCountdowns()
		setInterval(updateCountdowns, 30000) // Update every 30 seconds
	})
</script>

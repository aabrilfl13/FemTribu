---
// src/components/modals/ServiceInfoModal.astro
import Modal from "@/components/ui/Modal.astro"

interface Props {
	serviceName?: string
}

const { serviceName = "nuestros servicios" } = Astro.props

// Access environment variables in the frontmatter
const phoneNumber = import.meta.env.WHATSAPP_NUMBER
---

<Modal id="service-info-modal" size="md" ariaLabelledBy="service-info-modal-title">
	<!-- Header -->
	<div class="mb-6 text-center">
		<div class="bg-coral/10 mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full">
			<img src="/images/icons/illustrations/ilustracion-negro_24.svg" alt="" class="h-12 w-12" />
		</div>
		<h2 id="service-info-modal-title" class="font-display text-forest mb-3 text-2xl">
			¡Estamos preparando algo especial!
		</h2>
		<p class="text-sage">
			Estamos trabajando en nuestros packs de servicios para ofrecerte la mejor experiencia
			personalizada.
		</p>
	</div>

	<!-- Body -->
	<div class="space-y-4">
		<p class="text-forest text-center font-medium">Mientras tanto, puedes:</p>

		<div class="space-y-3">
			<!-- Cita button -->
			<a
				href={import.meta.env.CALENDLY_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="bg-accent text-cream font-body shadow-warm hover:shadow-organic hover:shadow-elegant hover:bg-accent/90 flex w-full items-center justify-center gap-2 rounded-full bg-gradient-to-br px-6 py-3.5 font-medium transition-all duration-300 hover:scale-[1.02]"
				data-modal-action="close"
			>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
					<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
					<line x1="16" y1="2" x2="16" y2="6"></line>
					<line x1="8" y1="2" x2="8" y2="6"></line>
					<line x1="3" y1="10" x2="21" y2="10"></line>
				</svg>
				Concertar una cita gratuita
			</a>
		</div>

		<!-- WhatsApp button -->
		<button
			id="whatsapp-service-btn"
			class="border-coral text-coral hover:bg-coral/10 flex w-full cursor-pointer items-center justify-center gap-2 rounded-full border-2 bg-transparent px-6 py-3.5 font-medium transition-all duration-300 hover:scale-[1.02]"
			data-service-name={serviceName}
		>
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
				<path
					d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
				></path>
			</svg>
			Contactar por WhatsApp
		</button>
	</div>

	<p class="text-sage pt-2 text-center text-sm">
		Estaremos encantadas de conocerte y resolver todas tus dudas 💛
	</p>
</Modal>

<script define:vars={{ phoneNumber }}>
	document.addEventListener("DOMContentLoaded", () => {
		const whatsappBtn = document.getElementById("whatsapp-service-btn")

		whatsappBtn?.addEventListener("click", () => {
			const serviceName = whatsappBtn.dataset.serviceName || "los servicios"
			const message = encodeURIComponent(
				`Hola! Me interesa saber más sobre *${serviceName}* de *Femm tribu*.`
			)
			window.open(`https://wa.me/34${phoneNumber}?text=${message}`, "_blank")
			window.modalManager.close("service-info-modal")
		})
	})
</script>

---

<section class="section">
		<div class="container">
			<!-- Contenido principal -->
			<div class="content">
				<!-- Imagen y presentación principal -->
				<div class="hero-content">
					<div class="image-wrapper">
						<div class="image-container">
							<img
								src="/images/about-me/mery-portrait.jpg"
								alt="María Belenguer, Matrona"
								class="portrait-image"
							/>
							<!-- Overlay decorativo -->
							<div class="image-overlay">
								<div class="pattern-overlay"></div>
							</div>
						</div>

						<!-- Elemento decorativo con icono místico -->
						<IconDecoration iconName="24" size="medium" />
					</div>

					<div class="intro-content">
						<div class="title-section">
							<h2>Sobre Mí</h2>
							<div class="subtitle-wrapper">
								<h3>María Belenguer</h3>
								<span class="profession">Matrona</span>
							</div>
						</div>

						<div class="intro-text">
							<p class="lead-paragraph">
								Soy María, matrona con más de 8 años acompañando a mujeres en su viaje más
								transformador: la maternidad. Mi misión es crear espacios seguros donde cada madre
								pueda conectar con su sabiduría interior y vivir esta experiencia desde el
								empoderamiento y la confianza.
							</p>

							<p>
								Creo firmemente en el poder de la información, el apoyo emocional y el respeto hacia
								las decisiones de cada mujer. En Femm Tribu encontrarás un lugar donde tu voz es
								escuchada, tus dudas son válidas y tu experiencia única es celebrada.
							</p>
						</div>

						<!-- Credenciales y certificaciones -->
						<div class="credentials">
							<h4>Formación y Experiencia</h4>
							<ul class="credentials-list">
								<li>
									<span class="credential-icon">🎓</span>
									<div>
										<strong>Diplomatura en Enfermería</strong>
										<span>Universidad de Valencia</span>
									</div>
								</li>
								<li>
									<span class="credential-icon">👶</span>
									<div>
										<strong>Especialización en Obstetricia y Ginecología</strong>
										<span>Hospital Universitario La Fe</span>
									</div>
								</li>
								<li>
									<span class="credential-icon">🤱</span>
									<div>
										<strong>Certificación en Lactancia Materna IBCLC</strong>
										<span>International Board of Lactation Consultant Examiners</span>
									</div>
								</li>
								<li>
									<span class="credential-icon">🧘</span>
									<div>
										<strong>Formación en Yoga Prenatal y Mindfulness</strong>
										<span>Asociación Española de Matronas</span>
									</div>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
</section>
<style>
	.section {
		padding: 80px 20px;
		background: #fff5eb;
		position: relative;
		overflow: visible;
	}

	/* Patrón de fondo */
	.section::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image:
			radial-gradient(circle at 20% 30%, rgba(106, 128, 103, 0.03) 0%, transparent 50%),
			radial-gradient(circle at 80% 70%, rgba(203, 110, 95, 0.04) 0%, transparent 60%),
			radial-gradient(circle at 40% 90%, rgba(213, 161, 142, 0.03) 0%, transparent 70%);
		pointer-events: none;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.content {
		position: relative;
		z-index: 2;
		animation: fadeInUp 0.8s ease-out;
	}

	/* Sección principal hero */
	.hero-content {
		display: grid;
		grid-template-columns: 400px 1fr;
		gap: 60px;
		margin-bottom: 80px;
		align-items: start;
	}

	.image-wrapper {
		position: relative;
	}

	.image-container {
		position: relative;
		width: 100%;
		height: 500px;
		border-radius: 30px;
		overflow: hidden;
		box-shadow: 0 20px 50px rgba(55, 68, 58, 0.15);
	}

	.portrait-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.image-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(
			135deg,
			rgba(203, 110, 95, 0.1) 0%,
			rgba(106, 128, 103, 0.05) 50%,
			transparent 100%
		);
	}

	.pattern-overlay {
		position: absolute;
		top: -50%;
		right: -50%;
		width: 200%;
		height: 200%;
		background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M30 30c0-16.569 13.431-30 30-30v60c-16.569 0-30-13.431-30-30z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")
			repeat;
		animation: pattern-float 40s linear infinite;
		opacity: 0.7;
	}

	@keyframes pattern-float {
		from {
			transform: translate(0, 0) rotate(0deg);
		}
		to {
			transform: translate(-60px, -60px) rotate(360deg);
		}
	}

	.intro-content {
		padding-top: 20px;
	}

	.title-section {
		margin-bottom: 30px;
	}

	.title-section h2 {
		font-family: "The Seasons", serif;
		font-size: 3rem;
		color: #37443a;
		font-weight: 300;
		letter-spacing: 1px;
		margin-bottom: 10px;
		position: relative;
	}

	.title-section h2::after {
		content: "";
		position: absolute;
		bottom: -8px;
		left: 0;
		width: 80px;
		height: 3px;
		background: linear-gradient(90deg, #cb6e5f 0%, #d5a18e 100%);
		border-radius: 2px;
	}

	.subtitle-wrapper {
		display: flex;
		align-items: baseline;
		gap: 15px;
		flex-wrap: wrap;
	}

	.subtitle-wrapper h3 {
		font-family: "The Seasons", serif;
		font-size: 1.8rem;
		color: #cb6e5f;
		font-weight: 400;
		margin: 0;
	}

	.profession {
		font-family: "Questrial", sans-serif;
		color: #6a8067;
		font-size: 1.1rem;
		font-weight: 500;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}

	.intro-text {
		margin-bottom: 40px;
	}

	.lead-paragraph {
		font-size: 1.2rem;
		line-height: 1.7;
		color: #37443a;
		margin-bottom: 20px;
		font-weight: 400;
	}

	.intro-text p {
		font-size: 1rem;
		line-height: 1.7;
		color: #4a5a4d;
		margin-bottom: 15px;
	}

	/* Credenciales */
	.credentials h4 {
		font-family: "The Seasons", serif;
		font-size: 1.3rem;
		color: #37443a;
		margin-bottom: 20px;
		font-weight: 400;
	}

	.credentials-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.credentials-list li {
		display: flex;
		align-items: flex-start;
		gap: 15px;
		margin-bottom: 20px;
		padding: 15px;
		background: rgba(255, 255, 255, 0.8);
		border-radius: 15px;
		border-left: 4px solid #cb6e5f;
		transition: all 0.3s ease;
	}

	.credentials-list li:hover {
		background: white;
		transform: translateX(5px);
		box-shadow: 0 5px 20px rgba(55, 68, 58, 0.1);
	}

	.credential-icon {
		font-size: 1.5rem;
		line-height: 1;
		margin-top: 2px;
	}

	.credentials-list strong {
		display: block;
		color: #37443a;
		font-weight: 500;
		margin-bottom: 3px;
	}

	.credentials-list span:not(.credential-icon) {
		color: #6a8067;
		font-size: 0.9rem;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.hero-content {
			grid-template-columns: 350px 1fr;
			gap: 40px;
		}

		.image-container {
			height: 450px;
		}
	}

	@media (max-width: 768px) {
		.section {
			padding: 60px 15px;
		}

		.hero-content {
			grid-template-columns: 1fr;
			gap: 40px;
			text-align: center;
		}

		.image-container {
			max-width: 350px;
			height: 400px;
			margin: 0 auto;
		}

		.title-section h2 {
			font-size: 2.5rem;
		}

		.subtitle-wrapper {
			justify-content: center;
		}
	}

	@media (max-width: 480px) {
		.title-section h2 {
			font-size: 2rem;
		}

		.subtitle-wrapper h3 {
			font-size: 1.5rem;
		}

		.credentials-list li {
			padding: 12px;
		}

		.credential-icon {
			font-size: 1.3rem;
		}
	}

	/* Animation de entrada */
	.content {
		animation: fadeInUp 0.8s ease-out;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

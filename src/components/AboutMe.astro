---
// src/components/SobreMi.astro
import MysticDecoration from "./decoratives/MysticDecoration.astro"
import IconDecoration from "./decoratives/IconDecoration.astro"
import DecorativeContainer from "./decoratives/DecorativeContainer.astro"
---

<section class="sobre-mi-section">
	<DecorativeContainer class="has-floating-decorations">
		<div class="sobre-mi-container">
			<!-- Elementos decorativos flotantes místicos -->
			<MysticDecoration
				iconName="01"
				animationType="spiral"
				size="large"
				position={{ top: "8%", right: "3%" }}
				animationDuration="40s"
			/>
			<MysticDecoration
				iconName="25"
				animationType="organic"
				size="medium"
				position={{ top: "25%", left: "2%" }}
				animationDuration="35s"
				animationDirection="reverse"
			/>
			<MysticDecoration
				iconName="27"
				animationType="fluid"
				size="small"
				position={{ top: "45%", right: "8%" }}
				animationDuration="30s"
			/>
			<MysticDecoration
				iconName="26"
				animationType="organic"
				size="large"
				position={{ bottom: "15%", left: "5%" }}
				animationDuration="45s"
			/>
			<MysticDecoration
				iconName="09"
				animationType="spiral"
				size="small"
				position={{ bottom: "8%", right: "12%" }}
				animationDuration="38s"
				animationDirection="reverse"
			/>

			<!-- Contenido principal -->
			<div class="sobre-mi-content">
				<!-- Imagen y presentación principal -->
				<div class="hero-content">
					<div class="image-wrapper">
						<div class="image-container">
							<img
								src="/images/about-me/mery-portrait.jpg"
								alt="María Belenguer, Matrona"
								class="portrait-image"
							/>
							<!-- Overlay decorativo -->
							<div class="image-overlay">
								<div class="pattern-overlay"></div>
							</div>
						</div>

						<!-- Elemento decorativo con icono místico -->
						<IconDecoration iconName="24" size="medium" />
					</div>

					<div class="intro-content">
						<div class="title-section">
							<h2>Sobre Mí</h2>
							<div class="subtitle-wrapper">
								<h3>María Belenguer</h3>
								<span class="profession">Matrona</span>
							</div>
						</div>

						<div class="intro-text">
							<p class="lead-paragraph">
								Soy María, matrona con más de 8 años acompañando a mujeres en su viaje más
								transformador: la maternidad. Mi misión es crear espacios seguros donde cada madre
								pueda conectar con su sabiduría interior y vivir esta experiencia desde el
								empoderamiento y la confianza.
							</p>

							<p>
								Creo firmemente en el poder de la información, el apoyo emocional y el respeto hacia
								las decisiones de cada mujer. En Femm Tribu encontrarás un lugar donde tu voz es
								escuchada, tus dudas son válidas y tu experiencia única es celebrada.
							</p>
						</div>

						<!-- Credenciales y certificaciones -->
						<div class="credentials">
							<h4>Formación y Experiencia</h4>
							<ul class="credentials-list">
								<li>
									<span class="credential-icon">🎓</span>
									<div>
										<strong>Diplomatura en Enfermería</strong>
										<span>Universidad de Valencia</span>
									</div>
								</li>
								<li>
									<span class="credential-icon">👶</span>
									<div>
										<strong>Especialización en Obstetricia y Ginecología</strong>
										<span>Hospital Universitario La Fe</span>
									</div>
								</li>
								<li>
									<span class="credential-icon">🤱</span>
									<div>
										<strong>Certificación en Lactancia Materna IBCLC</strong>
										<span>International Board of Lactation Consultant Examiners</span>
									</div>
								</li>
								<li>
									<span class="credential-icon">🧘</span>
									<div>
										<strong>Formación en Yoga Prenatal y Mindfulness</strong>
										<span>Asociación Española de Matronas</span>
									</div>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>

			<!-- Call to action -->
			<div class="cta-section">
				<div class="cta-content">
					<h3>¿Lista para Comenzar este Viaje Juntas?</h3>
					<p>
						Si sientes que mi enfoque resuena contigo y buscas un acompañamiento personalizado y
						respetuoso, me encantaría conocerte y ser parte de tu historia.
					</p>
					<div class="cta-buttons">
						<a href="#contacto" class="cta-primary"> Agenda una Consulta </a>
						<a href="#videos" class="cta-secondary"> Explora Nuestros Recursos </a>
					</div>
				</div>
			</div>
		</div>
	</DecorativeContainer>
</section>

<style>
	.sobre-mi-section {
		padding: 80px 20px;
		background: #fff5eb;
		position: relative;
		overflow: visible;
	}

	/* Patrón de fondo */
	.sobre-mi-section::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image:
			radial-gradient(circle at 20% 30%, rgba(106, 128, 103, 0.03) 0%, transparent 50%),
			radial-gradient(circle at 80% 70%, rgba(203, 110, 95, 0.04) 0%, transparent 60%),
			radial-gradient(circle at 40% 90%, rgba(213, 161, 142, 0.03) 0%, transparent 70%);
		pointer-events: none;
	}

	.sobre-mi-container {
		max-width: 1200px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.sobre-mi-content {
		position: relative;
		z-index: 2;
	}

	/* Sección principal hero */
	.hero-content {
		display: grid;
		grid-template-columns: 400px 1fr;
		gap: 60px;
		margin-bottom: 80px;
		align-items: start;
	}

	.image-wrapper {
		position: relative;
	}

	.image-container {
		position: relative;
		width: 100%;
		height: 500px;
		border-radius: 30px;
		overflow: hidden;
		box-shadow: 0 20px 50px rgba(55, 68, 58, 0.15);
	}

	.portrait-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.image-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(
			135deg,
			rgba(203, 110, 95, 0.1) 0%,
			rgba(106, 128, 103, 0.05) 50%,
			transparent 100%
		);
	}

	.pattern-overlay {
		position: absolute;
		top: -50%;
		right: -50%;
		width: 200%;
		height: 200%;
		background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M30 30c0-16.569 13.431-30 30-30v60c-16.569 0-30-13.431-30-30z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")
			repeat;
		animation: pattern-float 40s linear infinite;
		opacity: 0.7;
	}

	@keyframes pattern-float {
		from {
			transform: translate(0, 0) rotate(0deg);
		}
		to {
			transform: translate(-60px, -60px) rotate(360deg);
		}
	}

	.intro-content {
		padding-top: 20px;
	}

	.title-section {
		margin-bottom: 30px;
	}

	.title-section h2 {
		font-family: "The Seasons", serif;
		font-size: 3rem;
		color: #37443a;
		font-weight: 300;
		letter-spacing: 1px;
		margin-bottom: 10px;
		position: relative;
	}

	.title-section h2::after {
		content: "";
		position: absolute;
		bottom: -8px;
		left: 0;
		width: 80px;
		height: 3px;
		background: linear-gradient(90deg, #cb6e5f 0%, #d5a18e 100%);
		border-radius: 2px;
	}

	.subtitle-wrapper {
		display: flex;
		align-items: baseline;
		gap: 15px;
		flex-wrap: wrap;
	}

	.subtitle-wrapper h3 {
		font-family: "The Seasons", serif;
		font-size: 1.8rem;
		color: #cb6e5f;
		font-weight: 400;
		margin: 0;
	}

	.profession {
		font-family: "Questrial", sans-serif;
		color: #6a8067;
		font-size: 1.1rem;
		font-weight: 500;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}

	.intro-text {
		margin-bottom: 40px;
	}

	.lead-paragraph {
		font-size: 1.2rem;
		line-height: 1.7;
		color: #37443a;
		margin-bottom: 20px;
		font-weight: 400;
	}

	.intro-text p {
		font-size: 1rem;
		line-height: 1.7;
		color: #4a5a4d;
		margin-bottom: 15px;
	}

	/* Credenciales */
	.credentials h4 {
		font-family: "The Seasons", serif;
		font-size: 1.3rem;
		color: #37443a;
		margin-bottom: 20px;
		font-weight: 400;
	}

	.credentials-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.credentials-list li {
		display: flex;
		align-items: flex-start;
		gap: 15px;
		margin-bottom: 20px;
		padding: 15px;
		background: rgba(255, 255, 255, 0.8);
		border-radius: 15px;
		border-left: 4px solid #cb6e5f;
		transition: all 0.3s ease;
	}

	.credentials-list li:hover {
		background: white;
		transform: translateX(5px);
		box-shadow: 0 5px 20px rgba(55, 68, 58, 0.1);
	}

	.credential-icon {
		font-size: 1.5rem;
		line-height: 1;
		margin-top: 2px;
	}

	.credentials-list strong {
		display: block;
		color: #37443a;
		font-weight: 500;
		margin-bottom: 3px;
	}

	.credentials-list span:not(.credential-icon) {
		color: #6a8067;
		font-size: 0.9rem;
	}

	/* Responsive Design */ /* Sección de expertise con elementos orgánicos */
	.expertise-section {
		margin-bottom: 80px;
		position: relative;
	}

	.expertise-content {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 60px;
		align-items: start;
		position: relative;
		z-index: 1;
	}

	.expertise-text h3 {
		font-family: "The Seasons", serif;
		font-size: 2.2rem;
		color: #37443a;
		font-weight: 400;
		margin-bottom: 20px;
		letter-spacing: 0.5px;
	}

	.expertise-text > p {
		font-size: 1.1rem;
		color: #4a5a4d;
		line-height: 1.7;
		margin-bottom: 30px;
	}

	.specialties-list {
		display: grid;
		gap: 20px;
	}

	.specialty-item {
		padding: 25px;
		background: white;
		border-radius: 15px;
		border-left: 4px solid #6a8067;
		box-shadow: 0 5px 20px rgba(55, 68, 58, 0.08);
		transition: all 0.3s ease;
	}

	.specialty-item:hover {
		transform: translateX(5px);
		border-left-color: #cb6e5f;
		box-shadow: 0 10px 30px rgba(55, 68, 58, 0.15);
	}

	.specialty-item h5 {
		font-family: "The Seasons", serif;
		font-size: 1.1rem;
		color: #37443a;
		margin-bottom: 8px;
		font-weight: 400;
	}

	.specialty-item p {
		color: #6a8067;
		margin: 0;
		line-height: 1.6;
	}

	/* Stats */
	.stats-wrapper {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.stats-container {
		background: white;
		padding: 40px;
		border-radius: 25px;
		box-shadow: 0 20px 50px rgba(55, 68, 58, 0.1);
		display: grid;
		gap: 30px;
	}

	.stat-item {
		text-align: center;
		padding: 20px 0;
		border-bottom: 1px solid rgba(106, 128, 103, 0.1);
	}

	.stat-item:last-child {
		border-bottom: none;
	}

	.stat-number {
		display: block;
		font-family: "The Seasons", serif;
		font-size: 2.5rem;
		font-weight: 700;
		color: #cb6e5f;
		line-height: 1;
		margin-bottom: 5px;
	}

	.stat-label {
		color: #6a8067;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		font-weight: 500;
	}

	/* Testimonios con marcos orgánicos */
	.testimonials-section {
		margin-bottom: 80px;
		position: relative;
	}

	.testimonials-section h3 {
		font-family: "The Seasons", serif;
		font-size: 2.2rem;
		color: #37443a;
		font-weight: 400;
		text-align: center;
		margin-bottom: 50px;
		letter-spacing: 0.5px;
		position: relative;
		z-index: 1;
	}

	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 30px;
		position: relative;
		z-index: 1;
	}

	.testimonial-card {
		background: white;
		padding: 40px 30px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(55, 68, 58, 0.1);
		position: relative;
		border-top: 4px solid #cb6e5f;
		transition: all 0.3s ease;
	}

	.testimonial-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 20px 50px rgba(55, 68, 58, 0.15);
	}

	.quote-icon {
		font-size: 4rem;
		color: rgba(203, 110, 95, 0.2);
		line-height: 1;
		margin-bottom: 20px;
		font-family: serif;
	}

	.testimonial-card blockquote {
		color: #4a5a4d;
		line-height: 1.7;
		margin: 0 0 20px 0;
		font-style: italic;
		font-size: 1.05rem;
	}

	.testimonial-card cite {
		display: block;
		font-style: normal;
	}

	.testimonial-name {
		display: block;
		font-weight: 500;
		color: #37443a;
		margin-bottom: 3px;
	}

	.testimonial-role {
		color: #6a8067;
		font-size: 0.9rem;
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, #37443a 0%, #6a8067 100%);
		border-radius: 30px;
		padding: 60px;
		text-align: center;
		color: #fff5eb;
		position: relative;
		overflow: hidden;
	}

	.cta-section::before {
		content: "";
		position: absolute;
		top: -50%;
		right: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle, rgba(255, 245, 235, 0.05) 0%, transparent 70%);
		animation: cta-glow 20s linear infinite;
		pointer-events: none;
	}

	@keyframes cta-glow {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	.cta-content {
		position: relative;
		z-index: 1;
	}

	.cta-content h3 {
		font-family: "The Seasons", serif;
		font-size: 2rem;
		font-weight: 400;
		margin-bottom: 20px;
		letter-spacing: 0.5px;
	}

	.cta-content p {
		font-size: 1.1rem;
		line-height: 1.6;
		margin-bottom: 30px;
		opacity: 0.9;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.cta-buttons {
		display: flex;
		gap: 20px;
		justify-content: center;
		flex-wrap: wrap;
	}

	.cta-primary,
	.cta-secondary {
		padding: 15px 35px;
		border-radius: 50px;
		text-decoration: none;
		font-weight: 500;
		letter-spacing: 0.5px;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
		min-width: 200px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.cta-primary {
		background: linear-gradient(135deg, #cb6e5f 0%, #d5a18e 100%);
		color: white;
		border: 2px solid transparent;
	}

	.cta-secondary {
		background: transparent;
		color: #fff5eb;
		border: 2px solid rgba(255, 245, 235, 0.3);
	}

	.cta-primary::before,
	.cta-secondary::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		width: 0;
		height: 0;
		border-radius: 50%;
		transform: translate(-50%, -50%);
		transition:
			width 0.6s,
			height 0.6s;
	}

	.cta-primary::before {
		background: rgba(255, 255, 255, 0.2);
	}

	.cta-secondary::before {
		background: rgba(255, 245, 235, 0.1);
	}

	.cta-primary:hover::before,
	.cta-secondary:hover::before {
		width: 300px;
		height: 300px;
	}

	.cta-primary:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 25px rgba(203, 110, 95, 0.4);
	}

	.cta-secondary:hover {
		background: rgba(255, 245, 235, 0.1);
		border-color: rgba(255, 245, 235, 0.6);
		transform: translateY(-3px);
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.hero-content {
			grid-template-columns: 350px 1fr;
			gap: 40px;
		}

		.image-container {
			height: 450px;
		}
	}

	@media (max-width: 768px) {
		.sobre-mi-section {
			padding: 60px 15px;
		}

		.hero-content {
			grid-template-columns: 1fr;
			gap: 40px;
			text-align: center;
		}

		.image-container {
			max-width: 350px;
			height: 400px;
			margin: 0 auto;
		}

		.title-section h2 {
			font-size: 2.5rem;
		}

		.subtitle-wrapper {
			justify-content: center;
		}

		.cta-section {
			padding: 40px 30px;
		}

		.cta-content h3 {
			font-size: 1.7rem;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
		}

		.cta-primary,
		.cta-secondary {
			width: 100%;
			max-width: 300px;
		}

		.floating-element {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.title-section h2 {
			font-size: 2rem;
		}

		.subtitle-wrapper h3 {
			font-size: 1.5rem;
		}

		.philosophy-section {
			padding: 30px 20px;
		}

		.cta-section {
			padding: 30px 20px;
		}

		.credentials-list li {
			padding: 12px;
		}

		.credential-icon {
			font-size: 1.3rem;
		}
	}

	/* Animation de entrada */
	.sobre-mi-content {
		animation: fadeInUp 0.8s ease-out;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Animaciones escalonadas para las cards */
</style>

<script>
	// Intersection Observer para animar elementos cuando entran en viewport
	document.addEventListener("DOMContentLoaded", () => {
		const observerOptions = {
			threshold: 0.1,
			rootMargin: "0px 0px -50px 0px",
		}

		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add("animate-in")
				}
			})
		}, observerOptions)

		// Observar elementos animables
		const animatableElements = document.querySelectorAll(".credentials-list li")

		animatableElements.forEach((el) => {
			observer.observe(el)
		})
	})
</script>

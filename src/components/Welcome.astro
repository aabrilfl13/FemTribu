---
import Layout from "../layouts/Layout.astro"
import { fade } from "astro:transitions"

const images = ["/images/hands-together.webp", "/images/pregnant-woman.webp"]

const description =
	"Apoyando a las madres en su camino con un cuidado compasivo y una fuerza inquebrantable."
---

<Layout title="Femm Tribu">
	<div class="background-overlay"></div>
	<div class="w-full h-screen overflow-hidden relative">
		{
			images.map((image, index) => (
				<img
					src={image}
					alt={`Background image ${index + 1}`}
					class="absolute top-0 left-0 w-full h-screen object-cover transition-opacity duration-[2s] ease-in-out"
					class:list={{
						"opacity-100": index === 0,
						"opacity-0": index !== 0,
						"object-[38%_center] sm:object-center": image.includes("pregnant-woman"),
					}}
					data-index={index}
					transition:animate={fade()}
				/>
			))
		}
	</div>
	<div
		class="absolute top-0 left-0 w-full h-full flex flex-col items-center justify-center text-white text-center z-100"
	>
		<!-- Logo centered in screen -->
		<img
			src="/images/logos/logo_principal_fullcolor.svg"
			alt="Femm Tribu Logo"
			class="logo"
			style="max-width: min(500px, 90vw); width: 100%; height: auto;"
		/>

		<!-- Social Media Icons positioned above scroll indicator -->
		<div class="absolute bottom-24 md:bottom-35 left-1/2 transform -translate-x-1/2 flex gap-6">
			<a
				href="https://www.instagram.com/matronamery"
				target="_blank"
				rel="noopener noreferrer"
				class="social-icon"
				aria-label="Instagram"
			>
				<svg
					width="32"
					height="32"
					viewBox="0 0 24 24"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
						fill="currentColor"></path>
				</svg>
			</a>
			<a
				href="https://www.tiktok.com/@merypebe"
				target="_blank"
				rel="noopener noreferrer"
				class="social-icon"
				aria-label="TikTok"
			>
				<svg
					width="32"
					height="32"
					viewBox="0 0 24 24"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-.04-.1z"
						fill="currentColor"></path>
				</svg>
			</a>
		</div>

		<!-- Scroll indicator -->
		<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 scroll-indicator">
			<div class="flex items-center gap-3">
				<p class="text-lg font-[questrial] tracking-wide">Descubrir más</p>
				<div class="arrow-down">
					<svg
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M7 10L12 15L17 10"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</div>
			</div>
		</div>
	</div>
</Layout>

<script>
	const images = document.querySelectorAll("img[data-index]")
	let currentIndex = 0

	function changeBackground() {
		// Hide current image
		images[currentIndex].classList.remove("opacity-100")
		images[currentIndex].classList.add("opacity-0")

		// Move to next image
		currentIndex = (currentIndex + 1) % images.length

		// Show next image
		images[currentIndex].classList.remove("opacity-0")
		images[currentIndex].classList.add("opacity-100")
	}

	setTimeout(() => {
		setInterval(changeBackground, 6000)
	}, 500)
</script>
<script>
	import { animate } from "animejs"
	// Relaxed sleeping heartbeat at 55 BPM (~1090ms per beat)
	animate(".logo", {
		scale: [
			{ to: 1.05, duration: 100, ease: "easeOutQuad" }, // first strong thump
			{ to: 0.98, duration: 80, ease: "easeInQuad" }, // quick release
			{ to: 1.03, duration: 90, ease: "easeOutQuad" }, // softer second thump
			{ to: 1, duration: 230, ease: "easeInOutQuad" }, // return to rest
		],
		loop: true,
		loopDelay: 500, // adjust so total ~900–1000ms (≈60–70 bpm)
	})
</script>
<script>
	// Scroll functionality for the discover more indicator
	document.addEventListener("DOMContentLoaded", function () {
		const scrollIndicator = document.querySelector(".scroll-indicator")

		if (scrollIndicator) {
			scrollIndicator.addEventListener("click", function () {
				window.scrollTo({
					top: window.innerHeight,
					behavior: "smooth",
				})
			})
		}
	})
</script>

<style>
	.background-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100lvh;
		background: linear-gradient(
			45deg,
			rgba(245, 213, 184, 0.7) 0%,
			rgba(232, 196, 160, 0.5) 50%,
			rgba(245, 213, 184, 0.3) 100%
		);
		backdrop-filter: blur(1px);
		z-index: 20;
	}

	.scroll-indicator {
		animation: fadeInUp 2s ease-out 1s both;
		cursor: pointer;
		transition: transform 0.3s ease;
	}

	.scroll-indicator:hover {
		transform: translateX(-50%) translateY(-5px);
	}

	.social-icon {
		color: white;
		transition: all 0.3s ease;
		padding: 8px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.2);
		animation: fadeInUp 2s ease-out 1s both;
	}

	.social-icon:hover {
		transform: translateY(-3px);
		background: rgba(255, 255, 255, 0.2);
		box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
	}

	.arrow-down {
		animation: bounce 2s infinite;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateX(-50%) translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateX(-50%) translateY(0);
		}
	}

	@keyframes bounce {
		0%,
		20%,
		50%,
		80%,
		100% {
			transform: translateY(0);
		}
		40% {
			transform: translateY(-5px);
		}
		60% {
			transform: translateY(-3px);
		}
	}
</style>

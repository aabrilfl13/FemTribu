---
/**
 * Person Schema - María Belenguer
 * Defines María as a healthcare professional (Midwife)
 */

import { BUSINESS_INFO, getSchemaAddress, getImageUrls } from "@/data/business-info"

const siteUrl = Astro.site?.toString() || BUSINESS_INFO.siteUrl
const images = getImageUrls(siteUrl)

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"@id": `${siteUrl}#person`,
	name: BUSINESS_INFO.founder.name,
	givenName: BUSINESS_INFO.founder.givenName,
	familyName: BUSINESS_INFO.founder.familyName,

	// Profession
	jobTitle: BUSINESS_INFO.founder.jobTitle,
	hasOccupation: {
		"@type": "Occupation",
		name: BUSINESS_INFO.founder.jobTitle,
		occupationLocation: {
			"@type": "Country",
			name: "España",
		},
		occupationalCategory: "CNO-11:2123",
		description:
			"Matrona especializada en salud femenina integral, lactancia, preparación al parto, menopausia y salud hormonal",
	},

	// Affiliation
	worksFor: {
		"@id": `${siteUrl}#organization`,
	},

	// Image
	image: images.founderPortrait,

	// Location
	address: getSchemaAddress(false),

	// Expertise
	knowsAbout: BUSINESS_INFO.founder.expertise,

	// Description
	description: BUSINESS_INFO.founder.description,

	// URL
	url: `${siteUrl}/sobre-mi`,
	mainEntityOfPage: `${siteUrl}/sobre-mi`,

	// Social Media
	sameAs: BUSINESS_INFO.socialLinks,
}
---

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

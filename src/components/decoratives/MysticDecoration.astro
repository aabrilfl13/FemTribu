---
// src/components/MysticDecoration.astro
interface Props {
	iconName: string
	animationType: "spiral" | "organic" | "fluid" | "side-flow" | "frame-dance" | "bg"
	className?: string
	size?: "small" | "medium" | "large" | "xlarge"
	position?: {
		top?: string
		bottom?: string
		left?: string
		right?: string
	}
	opacity?: number
	animationDuration?: string
	animationDirection?: "normal" | "reverse"
}

const {
	iconName,
	animationType,
	className = "",
	size = "medium",
	position = {},
	opacity = 0.08,
	animationDuration = "40s",
	animationDirection = "normal",
} = Astro.props

// Size mappings
const sizeMap = {
	small: "100px",
	medium: "150px",
	large: "200px",
	xlarge: "300px",
}

// Generate unique animation name based on props
const animationName = `mystic-${animationType}-${animationDirection === "reverse" ? "reverse" : "normal"}`

// Generate position styles
const positionStyles = Object.entries(position)
	.map(([key, value]) => `${key}: ${value}`)
	.join("; ")

const elementSize = sizeMap[size]
---

<div
	class={`mystic-decoration ${className}`}
	style={`
		width: ${elementSize}; 
		height: ${elementSize}; 
		${positionStyles}; 
		opacity: ${opacity};
		animation: ${animationName} ${animationDuration} ease-in-out infinite ${animationDirection === "reverse" ? "reverse" : ""};
	`}
>
	<img src={`/images/decoratives/ilustracion-negro_${iconName}.svg`} alt="" />
</div>

<style>
	.mystic-decoration {
		position: absolute;
		pointer-events: none;
		z-index: 0;
		transition: opacity 0.4s ease;
		transform-origin: center center;
	}

	.mystic-decoration img {
		width: 100%;
		height: 100%;
		fill: #6a8067;
		filter: sepia(0.4) hue-rotate(90deg) saturate(0.8);
	}

	/* Mystic animations */
	@keyframes mystic-spiral-normal {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.08;
		}
		25% {
			transform: translate(15px, -10px) rotate(90deg) scale(1.1);
			opacity: 0.12;
		}
		50% {
			transform: translate(-8px, 12px) rotate(180deg) scale(0.95);
			opacity: 0.06;
		}
		75% {
			transform: translate(12px, 8px) rotate(270deg) scale(1.05);
			opacity: 0.1;
		}
	}

	@keyframes mystic-spiral-reverse {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.08;
		}
		25% {
			transform: translate(-15px, 10px) rotate(-90deg) scale(1.1);
			opacity: 0.12;
		}
		50% {
			transform: translate(8px, -12px) rotate(-180deg) scale(0.95);
			opacity: 0.06;
		}
		75% {
			transform: translate(-12px, -8px) rotate(-270deg) scale(1.05);
			opacity: 0.1;
		}
	}

	@keyframes mystic-organic-normal {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.08;
		}
		20% {
			transform: translate(8px, -15px) rotate(72deg) scale(1.08);
			opacity: 0.1;
		}
		40% {
			transform: translate(-12px, 5px) rotate(144deg) scale(0.92);
			opacity: 0.06;
		}
		60% {
			transform: translate(10px, 18px) rotate(216deg) scale(1.12);
			opacity: 0.12;
		}
		80% {
			transform: translate(-5px, -8px) rotate(288deg) scale(0.98);
			opacity: 0.04;
		}
	}

	@keyframes mystic-organic-reverse {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.08;
		}
		20% {
			transform: translate(-8px, 15px) rotate(-72deg) scale(1.08);
			opacity: 0.1;
		}
		40% {
			transform: translate(12px, -5px) rotate(-144deg) scale(0.92);
			opacity: 0.06;
		}
		60% {
			transform: translate(-10px, -18px) rotate(-216deg) scale(1.12);
			opacity: 0.12;
		}
		80% {
			transform: translate(5px, 8px) rotate(-288deg) scale(0.98);
			opacity: 0.04;
		}
	}

	@keyframes mystic-fluid-normal {
		0% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.08;
		}
		25% {
			transform: translate(20px, -25px) rotate(90deg) scale(1.15);
			opacity: 0.14;
		}
		50% {
			transform: translate(-15px, 20px) rotate(180deg) scale(0.85);
			opacity: 0.04;
		}
		75% {
			transform: translate(25px, 15px) rotate(270deg) scale(1.2);
			opacity: 0.16;
		}
		100% {
			transform: translate(0, 0) rotate(360deg) scale(1);
			opacity: 0.08;
		}
	}

	@keyframes mystic-fluid-reverse {
		0% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.08;
		}
		25% {
			transform: translate(-20px, 25px) rotate(-90deg) scale(1.15);
			opacity: 0.14;
		}
		50% {
			transform: translate(15px, -20px) rotate(-180deg) scale(0.85);
			opacity: 0.04;
		}
		75% {
			transform: translate(-25px, -15px) rotate(-270deg) scale(1.2);
			opacity: 0.16;
		}
		100% {
			transform: translate(0, 0) rotate(-360deg) scale(1);
			opacity: 0.08;
		}
	}

	@keyframes mystic-side-flow-normal {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.06;
		}
		33% {
			transform: translate(8px, -12px) rotate(120deg) scale(1.05);
			opacity: 0.1;
		}
		66% {
			transform: translate(-5px, 15px) rotate(240deg) scale(0.95);
			opacity: 0.04;
		}
	}

	@keyframes mystic-side-flow-reverse {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.06;
		}
		33% {
			transform: translate(-8px, 12px) rotate(-120deg) scale(1.05);
			opacity: 0.1;
		}
		66% {
			transform: translate(5px, -15px) rotate(-240deg) scale(0.95);
			opacity: 0.04;
		}
	}

	@keyframes mystic-frame-dance-normal {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.05;
		}
		25% {
			transform: translate(12px, -8px) rotate(90deg) scale(1.08);
			opacity: 0.08;
		}
		50% {
			transform: translate(-8px, 10px) rotate(180deg) scale(0.92);
			opacity: 0.03;
		}
		75% {
			transform: translate(10px, 12px) rotate(270deg) scale(1.12);
			opacity: 0.09;
		}
	}

	@keyframes mystic-frame-dance-reverse {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.05;
		}
		25% {
			transform: translate(-12px, 8px) rotate(-90deg) scale(1.08);
			opacity: 0.08;
		}
		50% {
			transform: translate(8px, -10px) rotate(-180deg) scale(0.92);
			opacity: 0.03;
		}
		75% {
			transform: translate(-10px, -12px) rotate(-270deg) scale(1.12);
			opacity: 0.09;
		}
	}

	@keyframes mystic-bg-normal {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.04;
		}
		50% {
			transform: translate(10px, -15px) rotate(180deg) scale(1.1);
			opacity: 0.08;
		}
	}

	@keyframes mystic-bg-reverse {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg) scale(1);
			opacity: 0.04;
		}
		50% {
			transform: translate(-10px, 15px) rotate(-180deg) scale(1.1);
			opacity: 0.08;
		}
	}
</style>

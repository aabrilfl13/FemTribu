---
// src/components/IconDecoration.astro
interface Props {
	iconName: string
	size?: "small" | "medium" | "large"
	className?: string
	position?: {
		top?: string
		bottom?: string
		left?: string
		right?: string
	}
}

const {
	iconName,
	size = "medium",
	className = "",
	position = { bottom: "-25px", right: "-25px" },
} = Astro.props

// Size mappings
const sizeMap = {
	small: { container: "70px", icon: "40px" },
	medium: { container: "90px", icon: "55px" },
	large: { container: "110px", icon: "70px" },
}

// Generate position styles
const positionStyles = Object.entries(position)
	.map(([key, value]) => `${key}: ${value}`)
	.join("; ")

const sizes = sizeMap[size]
---

<div
	class={`icon-decoration ${className}`}
	style={`
		width: ${sizes.container}; 
		height: ${sizes.container}; 
		${positionStyles}
	`}
>
	<img
		src={`/images/decoratives/ilustracion-negro_${iconName}.svg`}
		alt=""
		style={`width: ${sizes.icon}; height: ${sizes.icon}`}
	/>
</div>

<style>
	.icon-decoration {
		position: absolute;
		background: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 15px 40px rgba(55, 68, 58, 0.2);
		animation: icon-mystic-pulse 4s ease-in-out infinite;
		overflow: hidden;
		z-index: 2;
	}

	.icon-decoration::before {
		content: "";
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle, rgba(203, 110, 95, 0.1) 0%, transparent 70%);
		animation: mystic-glow 8s linear infinite;
		pointer-events: none;
	}

	.icon-decoration img {
		filter: sepia(0.3) hue-rotate(20deg) saturate(1.2);
		z-index: 1;
		position: relative;
	}

	@keyframes icon-mystic-pulse {
		0%,
		100% {
			transform: scale(1) rotate(0deg);
			box-shadow: 0 15px 40px rgba(55, 68, 58, 0.2);
		}
		50% {
			transform: scale(1.08) rotate(2deg);
			box-shadow: 0 20px 50px rgba(203, 110, 95, 0.3);
		}
	}

	@keyframes mystic-glow {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}
</style>

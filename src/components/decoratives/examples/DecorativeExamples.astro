---
// src/components/examples/DecorativeExamples.astro
// This file shows examples of how to use the decorative components
import MysticDecoration from "../MysticDecoration.astro"
import IconDecoration from "../IconDecoration.astro"
import DecorativeContainer from "../DecorativeContainer.astro"
---

<!-- Example 1: Basic floating decorations -->
<section class="example-section">
	<DecorativeContainer class="example-container has-floating-decorations">
		<MysticDecoration
			iconName="01"
			animationType="spiral"
			size="medium"
			position={{ top: "10%", right: "5%" }}
		/>
		<MysticDecoration
			iconName="25"
			animationType="organic"
			size="small"
			position={{ bottom: "10%", left: "5%" }}
			animationDirection="reverse"
		/>

		<div class="content">
			<h2>Content with Floating Decorations</h2>
			<p>This content has mystic decorations floating in the background.</p>
		</div>
	</DecorativeContainer>
</section>

<!-- Example 2: Positioned decorations for testimonials -->
<section class="testimonials-example">
	<MysticDecoration
		iconName="31"
		animationType="frame-dance"
		size="large"
		position={{ top: "-30px", left: "-50px" }}
		opacity={0.04}
	/>
	<MysticDecoration
		iconName="33"
		animationType="frame-dance"
		size="medium"
		position={{ bottom: "-40px", right: "-60px" }}
		animationDirection="reverse"
		opacity={0.04}
	/>

	<h3>Testimonials Section</h3>
	<!-- Your testimonial cards here -->
</section>

<!-- Example 3: Icon decoration for images -->
<div class="image-with-decoration">
	<img src="/images/example.jpg" alt="Example" />
	<IconDecoration iconName="24" size="large" position={{ bottom: "-30px", right: "-30px" }} />
</div>

<!-- Example 4: Different animation types showcase -->
<section class="animations-showcase">
	<h2>Animation Types</h2>

	<!-- Spiral animation -->
	<div class="animation-demo">
		<MysticDecoration
			iconName="01"
			animationType="spiral"
			size="small"
			position={{ top: "0", left: "0" }}
		/>
		<span>Spiral Animation</span>
	</div>

	<!-- Organic animation -->
	<div class="animation-demo">
		<MysticDecoration
			iconName="25"
			animationType="organic"
			size="small"
			position={{ top: "0", left: "0" }}
		/>
		<span>Organic Animation</span>
	</div>

	<!-- Fluid animation -->
	<div class="animation-demo">
		<MysticDecoration
			iconName="27"
			animationType="fluid"
			size="small"
			position={{ top: "0", left: "0" }}
		/>
		<span>Fluid Animation</span>
	</div>

	<!-- Side flow animation -->
	<div class="animation-demo">
		<MysticDecoration
			iconName="29-29"
			animationType="side-flow"
			size="small"
			position={{ top: "0", left: "0" }}
		/>
		<span>Side Flow Animation</span>
	</div>

	<!-- Frame dance animation -->
	<div class="animation-demo">
		<MysticDecoration
			iconName="31"
			animationType="frame-dance"
			size="small"
			position={{ top: "0", left: "0" }}
		/>
		<span>Frame Dance Animation</span>
	</div>
</section>

<style>
	.example-section {
		padding: 60px 20px;
		background: #f8f9fa;
		margin-bottom: 40px;
	}

	.example-container {
		max-width: 800px;
		margin: 0 auto;
		background: white;
		padding: 40px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
	}

	.testimonials-example {
		position: relative;
		padding: 40px;
		background: white;
		border-radius: 20px;
		margin: 40px 0;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
	}

	.image-with-decoration {
		position: relative;
		display: inline-block;
		margin: 20px;
	}

	.image-with-decoration img {
		width: 200px;
		height: 200px;
		object-fit: cover;
		border-radius: 15px;
	}

	.animations-showcase {
		padding: 40px;
		background: #f8f9fa;
		border-radius: 20px;
		margin: 40px 0;
	}

	.animation-demo {
		position: relative;
		display: inline-block;
		width: 150px;
		height: 100px;
		background: white;
		border-radius: 10px;
		margin: 10px;
		padding: 20px;
		text-align: center;
		box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
	}

	.animation-demo span {
		position: absolute;
		bottom: 10px;
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.8rem;
		color: #666;
	}
</style>

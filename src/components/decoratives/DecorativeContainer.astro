---
// src/components/DecorativeContainer.astro
interface Props {
	class?: string
	children?: any
}

const { class: className = "" } = Astro.props
---

<div class={`decorative-container ${className}`}>
	<slot />
</div>

<style>
	.decorative-container {
		position: relative;
		overflow: hidden;
	}

	/* Utility classes for common decoration positioning */
	.decorative-container.has-floating-decorations {
		z-index: 1;
	}

	.decorative-container.has-floating-decorations > :global(.mystic-decoration) {
		z-index: 0;
	}

	.decorative-container.has-floating-decorations > :global(.content) {
		position: relative;
		z-index: 2;
	}

	/* Responsive adjustments */
	@media (max-width: 768px) {
		.decorative-container :global(.mystic-decoration) {
			display: none;
		}
	}
</style>

---
import Icon from "../assets/iconos/ilustracion-negro_24.svg"
---

<div id="email-overlay" class="overlay">
	<div class="overlay-content email-content">
		<div class="overlay-container">
			<div class="overlay-icon email-icon">
				<Icon />
			</div>

			<h2>Accede a nuestro contenido exclusivo</h2>
			<p>
				Introduce tu email para desbloquear todos nuestros recursos y acompañarte en tu viaje
				maternal
			</p>

			<form id="email-form" class="overlay-form">
				<div class="form-group">
					<input
						type="email"
						id="email"
						name="email"
						placeholder="tu@email.com"
						required
						class="overlay-input"
					/>
					<button type="submit" class="overlay-button primary">
						<span class="button-text">Acceder</span>
						<span class="button-loader hidden">
							<svg class="spinner" viewBox="0 0 50 50">
								<circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
							</svg>
						</span>
					</button>
				</div>
				<div id="error-message" class="error-message hidden"></div>
				<div id="success-message" class="success-message hidden"></div>
			</form>

			<p class="overlay-note privacy-note">
				Respetamos tu privacidad. Tu email será usado únicamente para enviarte el acceso a nuestros
				recursos.
			</p>
		</div>
	</div>
</div>

<style>
	@import url("../styles/overlayStyles.css");
	.email-icon {
		width: 80px;
		height: 80px;
	}
	.email-icon svg {
		width: 80px;
		height: 80px;
		animation: pulse 3s linear infinite;
	}

	@keyframes pulse {
		0%,
		100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.05);
		}
	}
</style>

<script>
	import EmailVerificationManager from "../utils/emailVerification.ts"

	document.addEventListener("DOMContentLoaded", () => {
		const manager = new EmailVerificationManager()
		const form = document.getElementById("email-form") as HTMLFormElement
		const emailInput = document.getElementById("email") as HTMLInputElement
		const errorMessage = document.getElementById("error-message")
		const successMessage = document.getElementById("success-message")
		const submitButton = form.querySelector(".overlay-button") as HTMLButtonElement
		const buttonText = submitButton.querySelector(".button-text")
		const buttonLoader = submitButton.querySelector(".button-loader")

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()

			// Reset messages
			errorMessage?.classList.add("hidden")
			successMessage?.classList.add("hidden")

			// Show loading state
			submitButton.disabled = true
			buttonText?.classList.add("hidden")
			buttonLoader?.classList.remove("hidden")

			const email = emailInput.value

			try {
				const response = await fetch("/api/send-email", {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({ email }),
				})

				if (!response.ok) {
					throw new Error("Error al procesar tu solicitud")
				}

				const result = await response.json()
				console.log("Email send response:", result)
				// Check if there's a redirect URL in the response
				if (result.code) {
					// Show brief success message before redirecting
					if (successMessage) {
						successMessage.textContent = result.message || "Procesando tu solicitud..."
						successMessage.classList.remove("hidden")
					}

					// Store pending verification with longer expiration if redirecting
					const expirationTime = Date.now() + 60 * 60 * 1000 // 1 hour for redirect flow
					manager.setPendingVerification(email, result.code, expirationTime)

					// Get current URL and append code as query param and videos hash
					const currentUrl = new URL(window.location.href)
					currentUrl.hash = "videos"
					currentUrl.searchParams.set("code", result.code)

					// Redirect after a short delay to show the success message
					setTimeout(() => {
						window.location.href = currentUrl.toString()
					}, 1500)
				} else {
					// Original flow - show success message and set pending
					if (successMessage) {
						successMessage.textContent =
							result.message ||
							"Te hemos enviado un email con tu código de acceso. Por favor, revisa tu bandeja de entrada."
						successMessage.classList.remove("hidden")
					}

					// Use the verification manager to set pending status
					const expirationTime = Date.now() + 30 * 60 * 1000 // 30 minutes
					manager.setPendingVerification(email, null, expirationTime)
				}
			} catch (error) {
				// Show error message
				if (errorMessage) {
					errorMessage.textContent =
						error instanceof Error
							? error.message
							: "Ocurrió un error. Por favor, intenta de nuevo."
					errorMessage.classList.remove("hidden")
				}
			} finally {
				// Reset loading state
				submitButton.disabled = false
				buttonText?.classList.remove("hidden")
				buttonLoader?.classList.add("hidden")
			}
		})
	})
</script>

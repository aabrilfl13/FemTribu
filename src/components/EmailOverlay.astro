<div id="email-overlay" class="email-overlay">
	<div class="overlay-content">
		<div class="form-container">
			<!-- Decorative icon -->
			<div class="icon-wrapper">
				<img src="/src/assets/iconos/ilustracion-negro_25.svg" alt="Decorative icon" />
			</div>

			<h2>Accede a nuestro contenido exclusivo</h2>
			<p>
				Introduce tu email para desbloquear todos nuestros recursos y acompañarte en tu viaje
				maternal
			</p>

			<form id="email-form" class="email-form">
				<div class="form-group">
					<input
						type="email"
						id="email"
						name="email"
						placeholder="tu@email.com"
						required
						class="email-input"
					/>
					<button type="submit" class="submit-button">
						<span class="button-text">Acceder</span>
						<span class="button-loader hidden">
							<svg class="spinner" viewBox="0 0 50 50">
								<circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
							</svg>
						</span>
					</button>
				</div>
				<div id="error-message" class="error-message hidden"></div>
				<div id="success-message" class="success-message hidden"></div>
			</form>

			<p class="privacy-note">
				Respetamos tu privacidad. Tu email será usado únicamente para enviarte el acceso a nuestros
				recursos.
			</p>
		</div>
	</div>
</div>

<style>
	.email-overlay {
		position: absolute;
		top: -20px;
		left: -20px;
		right: -20px;
		bottom: -20px;
		backdrop-filter: blur(5px);
		z-index: 100;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		animation: fadeIn 0.3s ease forwards;
		border-radius: 40px;
		overflow: hidden;
		box-shadow:
			inset 0 0 80px rgba(255, 245, 235, 0.6),
			inset 0 0 120px rgba(255, 245, 235, 0.4);
	}

	.email-overlay.hidden {
		display: none;
	}

	@keyframes fadeIn {
		to {
			opacity: 1;
		}
	}

	.overlay-content {
		width: 100%;
		max-width: 500px;
		padding: 20px;
		position: relative;
		z-index: 1;
	}

	.form-container {
		background: white;
		padding: 50px 40px;
		border-radius: 30px;
		box-shadow: 0 20px 60px rgba(55, 68, 58, 0.15);
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	/* Decorative background pattern */
	.form-container::before {
		content: "";
		position: absolute;
		top: -50%;
		right: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle, rgba(203, 110, 95, 0.03) 0%, transparent 70%);
		animation: rotate 30s linear infinite;
		pointer-events: none;
	}

	@keyframes rotate {
		from {
			transform: rotate(0deg);
		}
		to {
			transform: rotate(360deg);
		}
	}

	.icon-wrapper {
		width: 80px;
		height: 80px;
		margin: 0 auto 20px;
		position: relative;
		z-index: 1;
	}

	.icon-wrapper img {
		width: 100%;
		height: 100%;
		opacity: 0.6;
		filter: sepia(0.3);
	}

	h2 {
		font-size: 1.8rem;
		color: #37443a;
		margin-bottom: 15px;
		font-weight: 300;
		letter-spacing: 0.5px;
		position: relative;
		z-index: 1;
	}

	p {
		color: #6a8067;
		font-size: 1rem;
		line-height: 1.6;
		margin-bottom: 30px;
		position: relative;
		z-index: 1;
	}

	.email-form {
		position: relative;
		z-index: 1;
	}

	.form-group {
		display: flex;
		gap: 10px;
		margin-bottom: 15px;
	}

	.email-input {
		flex: 1;
		padding: 15px 20px;
		border: 2px solid rgba(106, 128, 103, 0.2);
		border-radius: 50px;
		font-size: 1rem;
		color: #37443a;
		background: rgba(255, 245, 235, 0.5);
		transition: all 0.3s ease;
		outline: none;
	}

	.email-input::placeholder {
		color: rgba(106, 128, 103, 0.6);
	}

	.email-input:focus {
		border-color: #cb6e5f;
		background: white;
		box-shadow: 0 0 0 4px rgba(203, 110, 95, 0.1);
	}

	.email-input:invalid:not(:placeholder-shown) {
		border-color: #e74c3c;
	}

	.submit-button {
		padding: 15px 35px;
		background: linear-gradient(135deg, #cb6e5f 0%, #d5a18e 100%);
		color: white;
		border: none;
		border-radius: 50px;
		font-size: 1rem;
		font-weight: 500;
		letter-spacing: 0.5px;
		cursor: pointer;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
		min-width: 120px;
	}

	.submit-button::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		width: 0;
		height: 0;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.3);
		transform: translate(-50%, -50%);
		transition:
			width 0.6s,
			height 0.6s;
	}

	.submit-button:hover::before {
		width: 300px;
		height: 300px;
	}

	.submit-button:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 20px rgba(203, 110, 95, 0.3);
	}

	.submit-button:disabled {
		opacity: 0.7;
		cursor: not-allowed;
	}

	.button-text,
	.button-loader {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.button-loader.hidden {
		display: none;
	}

	.spinner {
		animation: spin 1s linear infinite;
		width: 20px;
		height: 20px;
	}

	.spinner .path {
		stroke: white;
		stroke-linecap: round;
		animation: dash 1.5s ease-in-out infinite;
	}

	@keyframes spin {
		100% {
			transform: rotate(360deg);
		}
	}

	@keyframes dash {
		0% {
			stroke-dasharray: 1, 150;
			stroke-dashoffset: 0;
		}
		50% {
			stroke-dasharray: 90, 150;
			stroke-dashoffset: -35;
		}
		100% {
			stroke-dasharray: 90, 150;
			stroke-dashoffset: -124;
		}
	}

	.error-message,
	.success-message {
		padding: 10px;
		border-radius: 10px;
		font-size: 0.9rem;
		margin-top: 10px;
		animation: slideIn 0.3s ease;
	}

	.error-message {
		background: rgba(231, 76, 60, 0.1);
		color: #e74c3c;
		border: 1px solid rgba(231, 76, 60, 0.2);
	}

	.success-message {
		background: rgba(106, 128, 103, 0.1);
		color: #6a8067;
		border: 1px solid rgba(106, 128, 103, 0.2);
	}

	.hidden {
		display: none;
	}

	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.privacy-note {
		font-size: 0.85rem;
		color: rgba(106, 128, 103, 0.7);
		margin-top: 20px;
		margin-bottom: 0;
	}

	/* Mobile responsive */
	@media (max-width: 640px) {
		.form-container {
			padding: 40px 25px;
		}

		h2 {
			font-size: 1.5rem;
		}

		.form-group {
			flex-direction: column;
		}

		.submit-button {
			width: 100%;
		}
	}
</style>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const overlay = document.getElementById("email-overlay")
		const form = document.getElementById("email-form") as HTMLFormElement
		const emailInput = document.getElementById("email") as HTMLInputElement
		const errorMessage = document.getElementById("error-message")
		const successMessage = document.getElementById("success-message")
		const submitButton = form.querySelector(".submit-button") as HTMLButtonElement
		const buttonText = submitButton.querySelector(".button-text")
		const buttonLoader = submitButton.querySelector(".button-loader")

		// Check if user already has access (you can modify this logic)
		const hasAccess = localStorage.getItem("videoAccess")
		if (hasAccess) {
			overlay?.classList.add("hidden")
		}

		form?.addEventListener("submit", async (e) => {
			e.preventDefault()

			// Reset messages
			errorMessage?.classList.add("hidden")
			successMessage?.classList.add("hidden")

			// Show loading state
			submitButton.disabled = true
			buttonText?.classList.add("hidden")
			buttonLoader?.classList.remove("hidden")

			const email = emailInput.value

			try {
				// Call your endpoint to create a code for this email
				const response = await fetch("/api/create-access-code", {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({ email }),
				})

				if (!response.ok) {
					throw new Error("Error al procesar tu solicitud")
				}

				const data = await response.json()

				// Show success message
				if (successMessage) {
					successMessage.textContent =
						"Te hemos enviado un email con tu código de acceso. Por favor, revisa tu bandeja de entrada."
					successMessage.classList.remove("hidden")
				}

				// Hide overlay after a delay
				setTimeout(() => {
					overlay?.classList.add("hidden")
					// Store access in localStorage (temporary - you should validate with the code)
					localStorage.setItem("videoAccess", "pending")
				}, 3000)
			} catch (error) {
				// Show error message
				if (errorMessage) {
					errorMessage.textContent =
						error instanceof Error
							? error.message
							: "Ocurrió un error. Por favor, intenta de nuevo."
					errorMessage.classList.remove("hidden")
				}
			} finally {
				// Reset loading state
				submitButton.disabled = false
				buttonText?.classList.remove("hidden")
				buttonLoader?.classList.add("hidden")
			}
		})
	})
</script>

---
import MobileMenu from "@/components/includes/MobileMenu.astro"

const navItems = [
	{ label: "Inicio", href: "/" },
	{ label: "Servicios", href: "/#servicios" },
	{ label: "Sobre mí", href: "/#sobre-mi" },
	{ label: "Cursos", href: "/cursos/curso-lactancia" },
]
---

<header
	id="main-nav"
	class="fixed top-0 left-0 right-0 z-[1000] bg-transparent transition-all duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)] py-5 [&.scrolled]:bg-background/95 [&.scrolled]:backdrop-blur-[20px] [&.scrolled]:shadow-[0_4px_30px_rgba(55,68,58,0.08)] [&.scrolled]:py-3"
>
	<div class="container mx-auto px-4 lg:px-8">
		<div class="flex items-center justify-between h-15">
			{/* Logo */}
			<a href="/" class="flex items-center relative z-[1001] transition-all duration-300 group">
				<img
					src="/images/logos/logo_icono.svg"
					alt="Femm Tribu"
					class="h-[60px] w-auto transition-all duration-[400ms] drop-shadow-[0_2px_8px_rgba(55,68,58,0.15)] group-hover:scale-105 group-hover:drop-shadow-[0_4px_12px_rgba(203,110,95,0.3)] [.scrolled_&]:h-[50px] opacity-0 [.scrolled_&]:opacity-100"
				/>
				<div class="block opacity-0 [.scrolled_&]:opacity-100 transition-opacity duration-[400ms]">
					<span class="font-display text-2xl text-primary">Femm</span>
					<span class="font-display text-2xl text-accent">tribu</span>
				</div>
			</a>

			{/* Desktop Navigation */}
			<nav class="hidden md:flex items-center gap-10">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="nav-link text-base text-[#fff5eb] no-underline relative py-2 transition-all duration-300 font-medium tracking-[0.5px] [text-shadow:0_2px_4px_rgba(55,68,58,0.3)] [.scrolled_&]:text-[#37443a] [.scrolled_&]:[text-shadow:none] hover:text-[#cb6e5f] hover:[text-shadow:0_2px_8px_rgba(203,110,95,0.3)] after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-gradient-to-r after:from-[#cb6e5f] after:to-[#d5a18e] after:transition-[width] after:duration-300 hover:after:w-full"
						>
							{item.label}
						</a>
					))
				}
			</nav>

			{/* CTA Button */}
			<div class="hidden md:block">
				<a
					href={import.meta.env.CALENDLY_URL}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center px-6 py-3 bg-accent text-accent-foreground font-medium rounded-full hover:bg-accent/90 transition-colors duration-300 opacity-0 [.scrolled_&]:opacity-100 transition-opacity duration-[400ms]"
				>
					Reserva tu cita
				</a>
			</div>

			<MobileMenu navItems={navItems} />
		</div>
	</div>
</header>

<style>
	/* CSS Custom Properties for MobileMenu communication */
	#main-nav {
		--hamburger-color: #fff5eb;
		--hamburger-shadow: 0 2px 4px rgba(55, 68, 58, 0.2);
	}

	#main-nav.scrolled {
		--hamburger-color: #37443a;
		--hamburger-shadow: none;
	}
</style>

<script>
	// Navigation scroll behavior
	function initNav() {
		const nav = document.getElementById("main-nav")
		const mobileMenuButton = document.querySelector(".mobile-menu-button")
		const mobileMenu = document.querySelector(".mobile-menu")

		if (!nav) return

		// Handle scroll to add background
		let lastScroll = 0
		const handleScroll = () => {
			const currentScroll = window.pageYOffset

			console.log("Scroll position:", currentScroll)

			// Add scrolled class for background
			if (currentScroll > 100) {
				console.log("Adding scrolled class")
				nav.classList.add("scrolled")
			} else {
				console.log("Removing scrolled class")
				nav.classList.remove("scrolled")
			}

			// Hide/show nav based on scroll direction
			if (currentScroll > lastScroll && currentScroll > 100) {
				// Scrolling down & past threshold
				nav.style.transform = "translateY(-100%)"
			} else {
				// Scrolling up or at top
				nav.style.transform = "translateY(0)"
			}

			lastScroll = currentScroll
		}

		// Mobile menu toggle (if mobile menu exists)
		if (mobileMenuButton && mobileMenu) {
			const toggleMobileMenu = () => {
				const isActive = mobileMenuButton.classList.toggle("active")
				mobileMenu.classList.toggle("active")
				mobileMenuButton.setAttribute("aria-expanded", isActive.toString())

				if (isActive) {
					document.body.style.overflow = "hidden"
				} else {
					document.body.style.overflow = ""
				}
			}

			const closeMobileMenu = () => {
				mobileMenuButton.classList.remove("active")
				mobileMenu.classList.remove("active")
				mobileMenuButton.setAttribute("aria-expanded", "false")
				document.body.style.overflow = ""
			}

			mobileMenuButton.addEventListener("click", toggleMobileMenu)

			mobileMenu.addEventListener("click", (e) => {
				if (e.target === mobileMenu) {
					closeMobileMenu()
				}
			})

			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape" && mobileMenuButton.classList.contains("active")) {
					closeMobileMenu()
				}
			})

			const mobileLinks = document.querySelectorAll(".mobile-link")
			mobileLinks.forEach((link) => {
				link.addEventListener("click", (e) => {
					const href = link.getAttribute("href")

					// Handle hash links on same page
					if (href && href.startsWith("#")) {
						e.preventDefault()
						const targetElement = document.querySelector(href)

						if (targetElement) {
							const navHeight = nav.offsetHeight
							const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset
							const offsetPosition = targetPosition - navHeight - 20

							window.scrollTo({
								top: offsetPosition,
								behavior: "smooth",
							})

							closeMobileMenu()
						}
					}
					// Handle links to home sections from other pages (like /#servicios)
					else if (href && href.includes("#")) {
						closeMobileMenu()
						// Let the browser handle the navigation naturally
					}
					// Handle regular page links
					else {
						closeMobileMenu()
					}
				})
			})
		}

		// Smooth scroll for desktop nav links
		const navLinks = document.querySelectorAll(".nav-link")
		navLinks.forEach((link) => {
			link.addEventListener("click", (e) => {
				const href = link.getAttribute("href")

				// Only prevent default for hash links on the same page
				if (href && href.startsWith("#")) {
					e.preventDefault()
					const targetElement = document.querySelector(href)

					if (targetElement) {
						const navHeight = nav.offsetHeight
						const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset
						const offsetPosition = targetPosition - navHeight - 20

						window.scrollTo({
							top: offsetPosition,
							behavior: "smooth",
						})
					}
				}
				// For links like "/#servicios" or regular page links, let them navigate naturally
			})
		})

		window.addEventListener("scroll", handleScroll, { passive: true })
		handleScroll()
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initNav)
	} else {
		initNav()
	}
</script>

---
import { BUSINESS_INFO } from "@/data/business-info"

const whatsappUrl = `https://wa.me/${BUSINESS_INFO.phone.replace("+", "")}`
const emailUrl = `mailto:${BUSINESS_INFO.email}`
const calendlyUrl = import.meta.env.CALENDLY_URL
---

<!-- Floating CTA Button -->
<div id="floating-cta" class="floating-cta">
	<!-- Action buttons (hidden by default) -->
	<div id="floating-cta-actions" class="floating-cta-actions">
		<a
			href={calendlyUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="floating-cta-action"
			aria-label="Reservar cita"
		>
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
				<line x1="16" y1="2" x2="16" y2="6"></line>
				<line x1="8" y1="2" x2="8" y2="6"></line>
				<line x1="3" y1="10" x2="21" y2="10"></line>
			</svg>
			<span>Reservar cita</span>
		</a>
		<a href={emailUrl} class="floating-cta-action" aria-label="Enviar email">
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
				></path>
				<polyline points="22,6 12,13 2,6"></polyline>
			</svg>
			<span>Email</span>
		</a>
		<a
			href={whatsappUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="floating-cta-action"
			aria-label="Escribir por WhatsApp"
		>
			<svg viewBox="0 0 24 24" fill="currentColor">
				<path
					d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
				></path>
			</svg>
			<span>WhatsApp</span>
		</a>
	</div>

	<!-- Main toggle button -->
	<button
		id="floating-cta-toggle"
		class="floating-cta-toggle"
		aria-label="Contactar"
		aria-expanded="false"
	>
		<svg
			class="floating-cta-icon-open"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
		</svg>
		<svg
			class="floating-cta-icon-close"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<line x1="18" y1="6" x2="6" y2="18"></line>
			<line x1="6" y1="6" x2="18" y2="18"></line>
		</svg>
	</button>
</div>

<style>
	.floating-cta {
		position: fixed;
		bottom: 20px;
		right: 20px;
		z-index: 998;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 12px;
	}

	/* Actions container */
	.floating-cta-actions {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 10px;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		pointer-events: none;
	}

	.floating-cta.open .floating-cta-actions {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
		pointer-events: auto;
	}

	/* Individual action buttons */
	.floating-cta-action {
		display: flex;
		align-items: center;
		gap: 10px;
		background: white;
		color: var(--color-primary);
		border: 1px solid rgba(106, 128, 103, 0.15);
		border-radius: 50px;
		padding: 10px 18px;
		font-family: "Questrial", sans-serif;
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		white-space: nowrap;
		box-shadow: 0 4px 15px rgba(55, 68, 58, 0.12);
		transition: all 0.3s ease;
		opacity: 0;
		transform: translateY(10px) scale(0.95);
	}

	.floating-cta.open .floating-cta-action {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.floating-cta.open .floating-cta-action:nth-child(1) {
		transition-delay: 0.05s;
	}
	.floating-cta.open .floating-cta-action:nth-child(2) {
		transition-delay: 0.1s;
	}
	.floating-cta.open .floating-cta-action:nth-child(3) {
		transition-delay: 0.15s;
	}

	.floating-cta-action:hover {
		transform: translateY(-2px) scale(1.02);
		box-shadow: 0 6px 20px rgba(55, 68, 58, 0.2);
		border-color: rgba(203, 110, 95, 0.3);
		color: var(--color-accent);
	}

	.floating-cta-action svg {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
	}

	/* Main toggle button */
	.floating-cta-toggle {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		background: linear-gradient(135deg, #cb6e5f 0%, #d5a18e 100%);
		color: white;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 20px rgba(203, 110, 95, 0.4);
		transition: all 0.3s ease;
		position: relative;
	}

	.floating-cta-toggle:hover {
		transform: scale(1.08);
		box-shadow: 0 6px 25px rgba(203, 110, 95, 0.5);
	}

	.floating-cta-toggle svg {
		width: 24px;
		height: 24px;
		transition: all 0.3s ease;
		position: absolute;
	}

	.floating-cta-icon-open {
		opacity: 1;
		transform: rotate(0deg);
	}

	.floating-cta-icon-close {
		opacity: 0;
		transform: rotate(-90deg);
	}

	.floating-cta.open .floating-cta-icon-open {
		opacity: 0;
		transform: rotate(90deg);
	}

	.floating-cta.open .floating-cta-icon-close {
		opacity: 1;
		transform: rotate(0deg);
	}

	.floating-cta.open .floating-cta-toggle {
		background: var(--color-primary);
	}
</style>

<script>
	import { trackEvent } from "@/utils/analytics"

	function initFloatingCTA() {
		const cta = document.getElementById("floating-cta")
		const toggle = document.getElementById("floating-cta-toggle")

		if (!cta || !toggle) return

		toggle.addEventListener("click", () => {
			const isOpen = cta.classList.toggle("open")
			toggle.setAttribute("aria-expanded", String(isOpen))
		})

		cta.querySelectorAll(".floating-cta-action").forEach((action) => {
			action.addEventListener("click", () => {
				const label = action.getAttribute("aria-label") || "unknown"
				trackEvent("cta_click", {
					cta_type: "floating",
					cta_label: label,
					page: window.location.pathname,
				})
			})
		})

		// Close when clicking outside
		document.addEventListener("click", (e) => {
			if (!cta.contains(e.target as Node)) {
				cta.classList.remove("open")
				toggle.setAttribute("aria-expanded", "false")
			}
		})

		// Close on Escape key
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape") {
				cta.classList.remove("open")
				toggle.setAttribute("aria-expanded", "false")
			}
		})
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initFloatingCTA)
	} else {
		initFloatingCTA()
	}
</script>

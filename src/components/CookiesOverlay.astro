---

<div id="cookies-overlay" class="cookies-overlay hidden">
	<div class="cookies-content">
		<div class="cookies-container">
			<!-- Cookie icon -->
			<div class="cookies-icon">
				<img src="/images/icons/cookie.svg" alt="Icono de galleta" width="24" height="24" />
			</div>

			<!-- Main content -->
			<div class="cookies-text">
				<h3>Respetamos tu privacidad</h3>
				<p>
					Utilizamos cookies esenciales para el funcionamiento del sitio web y cookies opcionales
					para mejorar tu experiencia. Puedes elegir qué cookies aceptar.
				</p>
			</div>

			<!-- Quick actions -->
			<div class="cookies-actions-quick">
				<button id="accept-all-cookies" class="cookies-button primary"> Aceptar todas </button>
				<button id="reject-optional-cookies" class="cookies-button secondary">
					Solo esenciales
				</button>
			</div>

			<!-- Advanced options toggle -->
			<div class="cookies-advanced-toggle">
				<button id="show-cookie-settings" class="cookies-link"> Personalizar configuración </button>
				<span class="cookies-divider">·</span>
				<a href="/privacy" class="cookies-link" target="_blank"> Política de privacidad </a>
			</div>
		</div>

		<!-- Advanced settings (hidden by default) -->
		<div id="cookies-advanced" class="cookies-advanced hidden">
			<div class="cookies-advanced-container">
				<h4>Configuración de cookies</h4>
				<p class="cookies-advanced-description">
					Gestiona tus preferencias de cookies. Las cookies esenciales no se pueden desactivar ya
					que son necesarias para el funcionamiento del sitio.
				</p>

				<div class="cookies-categories">
					<!-- Essential cookies -->
					<div class="cookie-category">
						<div class="cookie-category-header">
							<div class="cookie-category-info">
								<h5>Cookies Esenciales</h5>
								<p>Necesarias para el funcionamiento básico del sitio web.</p>
							</div>
							<div class="cookie-toggle">
								<input type="checkbox" id="essential-cookies" checked disabled />
								<label for="essential-cookies" class="toggle-label">
									<span class="toggle-switch"></span>
								</label>
								<span class="toggle-status">Siempre activas</span>
							</div>
						</div>
						<div class="cookie-details">
							<ul>
								<li>
									<strong>localStorage:</strong> Control de acceso temporal a videos (30 minutos)
								</li>
								<li><strong>Cookies de sesión:</strong> Mantener tu estado de navegación</li>
							</ul>
						</div>
					</div>

					<!-- Analytics cookies -->
					<div class="cookie-category">
						<div class="cookie-category-header">
							<div class="cookie-category-info">
								<h5>Cookies de Análisis</h5>
								<p>Nos ayudan a entender cómo utilizas el sitio web.</p>
							</div>
							<div class="cookie-toggle">
								<input type="checkbox" id="analytics-cookies" />
								<label for="analytics-cookies" class="toggle-label">
									<span class="toggle-switch"></span>
								</label>
							</div>
						</div>
						<div class="cookie-details">
							<ul>
								<li><strong>Google Analytics:</strong> Análisis de uso del sitio web</li>
								<li><strong>Métricas de rendimiento:</strong> Optimización de la experiencia</li>
							</ul>
						</div>
					</div>

					<!-- YouTube cookies -->
					<div class="cookie-category">
						<div class="cookie-category-header">
							<div class="cookie-category-info">
								<h5>Cookies de Terceros</h5>
								<p>Servicios externos embebidos como videos de YouTube.</p>
							</div>
							<div class="cookie-toggle">
								<input type="checkbox" id="youtube-cookies" />
								<label for="youtube-cookies" class="toggle-label">
									<span class="toggle-switch"></span>
								</label>
							</div>
						</div>
						<div class="cookie-details">
							<ul>
								<li><strong>YouTube:</strong> Reproducción de videos educativos</li>
								<li>
									<strong>Preferencias de reproducción:</strong> Mejora la experiencia de video
								</li>
							</ul>
						</div>
					</div>
				</div>

				<!-- Advanced actions -->
				<div class="cookies-advanced-actions">
					<button id="save-cookie-preferences" class="cookies-button primary">
						Guardar preferencias
					</button>
					<button id="cancel-cookie-settings" class="cookies-button secondary"> Cancelar </button>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Cookie settings button (floating, visible after initial consent) -->
<button id="cookie-settings-btn" class="cookie-settings-floating hidden">
	<svg viewBox="0 0 24 24" fill="currentColor">
		<path

---
import { BUSINESS_INFO } from "@/data/business-info"
import type { CollectionEntry } from "astro:content"

interface Props {
	post: CollectionEntry<"blog">
	url: string
}

const { post, url } = Astro.props
const { title, description, pubDate, updatedDate, author, heroImage } = post.data

const siteUrl = Astro.site?.toString() || BUSINESS_INFO.siteUrl
const fullImageUrl = heroImage ? new URL(heroImage, siteUrl).toString() : undefined

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: title,
	description: description,
	image: fullImageUrl,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate || pubDate).toISOString(),
	author: {
		"@type": "Person",
		name: author.name,
		jobTitle: author.role,
		image: author.image ? new URL(author.image, siteUrl).toString() : undefined,
	},
	publisher: {
		"@type": "Organization",
		"@id": `${siteUrl}#organization`,
		name: "Femm Tribu",
		logo: {
			"@type": "ImageObject",
			url: `${siteUrl}/favicon.svg`,
		},
	},
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": url,
	},
}
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

---
interface Props {
	name: string
	role: string
	image?: string
	showRole?: boolean
	class?: string
}

const { name, role, image, showRole = true, class: className = "" } = Astro.props
---

<div class={`flex items-center gap-3 ${className}`}>
	{
		image && (
			<img
				src={image}
				alt={name}
				class="h-10 w-10 rounded-full object-cover ring-2 ring-primary/10"
			/>
		)
	}
	<div class="flex flex-col">
		<span class="text-primary text-sm font-medium">{name}</span>
		{showRole && <span class="text-muted-foreground text-xs">{role}</span>}
	</div>
</div>

---
import "@/styles/global.css"
import "@/styles/snow.css"

import Analytics from "@vercel/analytics/astro"
import SpeedInsights from "@vercel/speed-insights/astro"

import CookiesOverlay from "@/components/CookiesOverlay.astro"
import GoogleAnalytics from "@/components/GoogleAnalytics.astro"
import Footer from "@/components/layout/Footer.astro"
import Nav from "@/components/layout/Nav.astro"
import MicrosoftClarity from "@/components/MicrosoftClarity.astro"
import AnnouncementModal from "@/components/modals/AnnouncementModal.astro"
import LocalBusinessSchema from "@/components/schema/LocalBusinessSchema.astro"
import OrganizationSchema from "@/components/schema/OrganizationSchema.astro"
import PersonSchema from "@/components/schema/PersonSchema.astro"
import SEO from "@/components/SEO.astro"

export interface Props {
	title?: string
	description?: string
	image?: string
	type?: "website" | "article"
	noindex?: boolean
	navScrolled?: boolean
}
const { title, description, image, type, noindex = false, navScrolled = false } = Astro.props
const isDevelopment = import.meta.env.ENV === "development"
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<meta name="generator" content={Astro.generator} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			rel="icon"
			media="(prefers-color-scheme: light)"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: light)"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: light)"
			type="image/x-icon"
			href="/favicon.ico"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: dark)"
			type="image/png"
			sizes="32x32"
			href="/favicon-dark-32x32.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: dark)"
			type="image/png"
			sizes="16x16"
			href="/favicon-dark-16x16.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: dark)"
			type="image/x-icon"
			href="/favicon-dark.ico"
		/>

		<!-- Keep SVG for browsers that support it -->
		<!-- SEO and Social Meta -->
		<SEO title={title} description={description} image={image} type={type} noindex={noindex} />
		<meta
			name="keywords"
			content="maternidad, lactancia, embarazo, matrona, mujer, mujeres, salud femenina, María Belenguer"
		/>

		<!-- Structured Data (Schema.org) -->
		<OrganizationSchema />
		<PersonSchema />
		<LocalBusinessSchema />

		<!-- Fonts preload -->
		<link
			rel="preload"
			href="/fonts/Questrial-Regular.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Zodiak-VariableItalic.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Zodiak-Variable.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<!-- Analytics placeholder (will be loaded based on cookie consent) -->
		{!isDevelopment && <GoogleAnalytics />}
		{!isDevelopment && <MicrosoftClarity />}
		<script is:inline>
			function handleConsent(preferences) {
				// Si se aceptan analíticas, cargamos los servicios
				if (preferences && preferences.analytics) {
					console.log("Consentimiento recibido: Cargando Analytics y Clarity...")

					// Disparamos un evento que los componentes específicos escucharán
					window.dispatchEvent(new CustomEvent("load-analytics-services"))
				}
			}

			// 1. Escuchar cambios en tiempo real
			window.addEventListener("cookie-consent-updated", (event) => {
				handleConsent(event.detail)
			})

			// 2. Comprobar al cargar la página si ya existía consentimiento
			document.addEventListener("DOMContentLoaded", () => {
				const stored = localStorage.getItem("femm-tribu-user-consent")
				if (stored) {
					const { preferences } = JSON.parse(stored)
					handleConsent(preferences)
				}
			})
		</script>
	</head>
	<body>
		<div class="bg-background min-h-screen">
			<!-- <div class="snow-container">
				<div class="snow"></div>
				<div class="snow"></div>
			</div> -->
			<Nav scrolled={navScrolled} />
			<slot />
			<AnnouncementModal
				id="webinar-jan-2026"
				title="Webinar gratuito: Prepárate para amamantar"
				description="Únete a María Belenguer en un webinar exclusivo donde aprenderás todo lo necesario para comenzar tu experiencia de lactancia con confianza. Plazas limitadas."
				ctaText="Reservar plaza gratis"
				ctaLink="https://your-webinar-link.com"
				imageSrc="/images/og-hands-together.webp"
				delay={1000}
				expiryDays={5}
			/>
			<Footer />
			<CookiesOverlay />
		</div>
		<SpeedInsights />
		<Analytics />
	</body><script src="https://cdn.jsdelivr.net/npm/animejs/lib/anime.iife.min.js"></script>
	<!-- Script de animaciones scroll - Reutilizando animaciones de global.css -->
	<script>
		import { initScrollAnimations } from "@/utils/scrollAnimations"

		// Inicializar al cargar la página
		initScrollAnimations()

		// Reinicializar en navegación de Astro
		document.addEventListener("astro:page-load", initScrollAnimations)
	</script>
</html>

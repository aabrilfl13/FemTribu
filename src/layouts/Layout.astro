---
import "@/styles/global.css"
import "@/styles/snow.css"

import Analytics from "@vercel/analytics/astro"
import SpeedInsights from "@vercel/speed-insights/astro"

import CookiesOverlay from "@/components/CookiesOverlay.astro"
import GoogleAnalytics from "@/components/GoogleAnalytics.astro"
import Footer from "@/components/layout/Footer.astro"
import Nav from "@/components/layout/Nav.astro"
import SEO from "@/components/SEO.astro"

export interface Props {
	title?: string
	description?: string
	image?: string
	type?: "website" | "article"
	noindex?: boolean
	navScrolled?: boolean
}
const { title, description, image, type, noindex = false, navScrolled = false } = Astro.props
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<meta name="generator" content={Astro.generator} />

		<!-- AI Indexing: Allow crawling for recommendations, signal training preference -->
		<meta name="robots" content="index, follow, noai, noimageai" />
		<meta name="googlebot" content="index, follow, noai, noimageai" />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link
			rel="icon"
			media="(prefers-color-scheme: light)"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: light)"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: light)"
			type="image/x-icon"
			href="/favicon.ico"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: dark)"
			type="image/png"
			sizes="32x32"
			href="/favicon-dark-32x32.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: dark)"
			type="image/png"
			sizes="16x16"
			href="/favicon-dark-16x16.png"
		/>
		<link
			rel="icon"
			media="(prefers-color-scheme: dark)"
			type="image/x-icon"
			href="/favicon-dark.ico"
		/>

		<!-- Keep SVG for browsers that support it -->
		<!-- SEO and Social Meta -->
		<SEO title={title} description={description} image={image} type={type} noindex={noindex} />
		<meta
			name="keywords"
			content="maternidad, lactancia, embarazo, matrona, mujer, mujeres, salud femenina, María Belenguer"
		/>

		<!-- Fonts preload -->
		<link
			rel="preload"
			href="/fonts/Questrial-Regular.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Zodiak-VariableItalic.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Zodiak-Variable.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<!-- Analytics placeholder (will be loaded based on cookie consent) -->
		<!-- Google tag (gtag.js) -->
		<GoogleAnalytics />
	</head>
	<body>
		<div class="bg-background min-h-screen">
			<div class="snow-container">
				<div class="snow"></div>
				<div class="snow"></div>
			</div>
			<Nav scrolled={navScrolled} />
			<slot />
			<Footer />
			<CookiesOverlay />
		</div>
		<SpeedInsights />
		<Analytics />
	</body><script src="https://cdn.jsdelivr.net/npm/animejs/lib/anime.iife.min.js"></script>
</html>

---
import "../styles/global.css"

export interface Props {
	title?: string
}

const { title = "Femm Tribu" } = Astro.props
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO and Social Meta -->
		<title>{title}</title>
		<meta
			name="description"
			content="Femm Tribu - Una guía femenina integral para todo el viaje corporal y emocional de ser mujer. Acompañamos a madres en su camino con cuidado compasivo."
		/>
		<meta
			name="keywords"
			content="maternidad, lactancia, embarazo, matrona, mujeres, salud femenina, María Belenguer"
		/>

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta
			property="og:description"
			content="Una guía femenina integral para todo el viaje corporal y emocional de ser mujer."
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://femmtribu.es" />
		<meta property="og:image" content="/images/og-hands-together.jpg" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta
			name="twitter:description"
			content="Una guía femenina integral para todo el viaje corporal y emocional de ser mujer."
		/>
		<meta name="twitter:image" content="/images/og-hands-together.jpg" />

		<!-- Fonts preload -->
		<link
			rel="preload"
			href="/fonts/Questrial-Regular.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Fontspring-DEMO-theseasons-reg.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<!-- Analytics placeholder (will be loaded based on cookie consent) -->
		<script type="text/plain" data-cookie-consent="analytics">
			// Google Analytics will be loaded here when analytics cookies are accepted
			// Example implementation:
			// window.gtag = window.gtag || function(){dataLayer.push(arguments);};
			// gtag('js', new Date());
			// gtag('config', 'GA_MEASUREMENT_ID');
		</script>
	</head>
	<body>
		<slot />
	</body>
	<script src="https://cdn.jsdelivr.net/npm/animejs/lib/anime.iife.min.js"></script>
</html>

---
import VideoGrid from "@/components/course/VideoGrid"
import CTA from "@/components/sections/cta/CTA.astro"
import Layout from "@/layouts/Layout.astro"
import { getAssetUrl } from "@/services/directus"
import { listVideos, type Video } from "@/videos"

// Check if user has access to FemM Barre
const user = Astro.locals.user

if (!user) {
	// Not logged in - redirect to login with next parameter
	const nextUrl = encodeURIComponent(Astro.url.pathname + Astro.url.search)
	return Astro.redirect(`/auth/login?next=${nextUrl}`)
}

if (!user.hasActiveFemmBarre) {
	// Logged in but no access - redirect to access page
	return Astro.redirect("/cursos")
}

// Fetch videos for this course
const videosResult = await listVideos()
const videos: Video[] = videosResult.data ?? []

// Sort videos by creation date (most recent first)
const sortedVideos = [...videos].sort(
	(a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
)

// Get the most recent video for the hero
const latestVideo = sortedVideos[0]
const previousVideos = sortedVideos.slice(1)

// Helper to format duration
function formatDuration(seconds: number): string {
	const mins = Math.floor(seconds / 60)
	return `${mins} min`
}

const seoData = {
	title: "FemmBarre Maternity - Tu biblioteca de clases | Femm tribu",
	description:
		"Accede a todas las clases de FemmBarre Maternity. Entrena a tu ritmo con sesiones adaptadas a cada trimestre del embarazo.",
	type: "website" as const,
	robots: "noindex, nofollow", // Don't index authenticated content
}
---

<Layout navScrolled={true} {...seoData}>
	<main id="main-content" class="pt-22">
		<!-- Hero Section with Latest Video -->
		<section class="bg-background relative container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="relative z-10 container mx-auto px-4 lg:px-8">
				<!-- Header -->
				<div class="mb-8 text-center lg:text-left">
					<h1
						class="font-display text-primary mb-3 text-3xl sm:text-4xl lg:text-5xl"
						data-animate="animate-fade-up"
						data-animate-duration="1s"
					>
						FemmBarre <span class="text-accent">Maternity</span>
					</h1>
					<p
						class="text-muted-foreground mx-auto max-w-2xl text-lg lg:mx-0"
						data-animate="animate-fade-up"
						data-animate-duration="1s"
						data-animate-delay="0.1s"
					>
						Tu biblioteca de clases. Entrena cuando quieras, a tu ritmo.
					</p>
				</div>

				<!-- Latest Video Card -->
				{
					latestVideo ? (
						<div
							class="bg-card from-accent/5 to-coral/5 border-accent/20 shadow-warm overflow-hidden rounded-3xl border bg-gradient-to-br"
							data-animate="animate-fade-up"
							data-animate-duration="1s"
							data-animate-delay="0.2s"
						>
							<div class="grid gap-8 p-6 lg:grid-cols-2 lg:p-10">
								{/* Video Thumbnail */}
								<div class="relative">
									<div class="group relative overflow-hidden rounded-2xl">
										<img
											src={latestVideo.thumbnailUrl}
											alt={latestVideo.title}
											class="aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-105"
										/>
										<div class="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 transition-opacity group-hover:opacity-100">
											<div class="bg-accent flex h-16 w-16 items-center justify-center rounded-full shadow-lg">
												<svg class="h-8 w-8 text-white" fill="currentColor" viewBox="0 0 24 24">
													<path d="M8 5v14l11-7z" />
												</svg>
											</div>
										</div>
										<div class="bg-accent absolute top-4 left-4 rounded-full px-3 py-1 text-xs font-semibold text-white shadow-md">
											Más reciente
										</div>
									</div>
								</div>

								{/* Video Info */}
								<div class="flex flex-col justify-center">
									<h2 class="font-display text-primary mb-3 text-2xl lg:text-3xl">
										{latestVideo.title}
									</h2>
									<p class="text-muted-foreground mb-4 leading-relaxed">
										{latestVideo.description}
									</p>
									<div class="mb-6 flex flex-wrap gap-3">
										<span class="bg-accent/10 text-accent inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm">
											<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path
													stroke-linecap="round"
													stroke-linejoin="round"
													stroke-width="2"
													d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
												/>
											</svg>
											{formatDuration(latestVideo.duration)}
										</span>
										{latestVideo.metadata?.trimester && (
											<span class="bg-secondary/10 text-secondary inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm">
												<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path
														stroke-linecap="round"
														stroke-linejoin="round"
														stroke-width="2"
														d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
													/>
												</svg>
												{latestVideo.metadata.trimester}
											</span>
										)}
									</div>
									<a
										href={`/cursos/femmbarre-maternity/${latestVideo.id}`}
										class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-[#B85440] to-[#D88B7D] px-8 py-3 font-semibold text-white shadow-md transition-all hover:scale-[1.02] hover:shadow-lg"
									>
										<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
											<path d="M8 5v14l11-7z" />
										</svg>
										Ver clase
									</a>
								</div>
							</div>
						</div>
					) : (
						<div class="bg-muted/30 rounded-3xl p-12 text-center">
							<p class="text-muted-foreground">No hay clases disponibles todavía.</p>
						</div>
					)
				}
			</div>

			<!-- Decorative elements -->
			<div
				class="bg-accent/10 shape-organic absolute top-20 right-0 h-96 w-96 translate-x-1/2 -translate-y-1/2"
			>
			</div>
			<div
				class="bg-coral/10 shape-blob absolute bottom-0 left-0 h-64 w-64 -translate-x-1/2 translate-y-1/2"
			>
			</div>
		</section>

		<!-- Previous Videos Grid -->
		{
			previousVideos.length > 0 && (
				<section class="py-12 lg:py-16">
					<div class="container mx-auto px-4 lg:px-8">
						<h2
							class="font-display text-primary mb-8 text-2xl lg:text-3xl"
							data-animate="animate-fade-up"
							data-animate-duration="1s"
						>
							Clases anteriores
						</h2>

						<VideoGrid videos={previousVideos} courseSlug="femmbarre-maternity" client:load />
					</div>
				</section>
			)
		}

		<!-- Empty state if no videos at all -->
		{
			videos.length === 0 && (
				<section class="py-20">
					<div class="container mx-auto px-4 text-center lg:px-8">
						<div
							class="bg-muted/30 mx-auto max-w-md rounded-3xl p-12"
							data-animate="animate-fade-up"
							data-animate-duration="1s"
						>
							<div class="bg-accent/10 mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full">
								<svg
									class="text-accent h-10 w-10"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
									/>
								</svg>
							</div>
							<h3 class="font-display text-primary mb-3 text-xl">Próximamente</h3>
							<p class="text-muted-foreground">
								Las clases estarán disponibles pronto. ¡Mantente atenta!
							</p>
						</div>
					</div>
				</section>
			)
		}

		<!-- Info Section -->
		<CTA
			title="¿Tienes dudas?"
			description="Si necesitas ayuda o quieres saber más sobre las clases, estamos aquí para ti."
			serviceName="FemmBarre Maternity"
		/>
	</main>
</Layout>

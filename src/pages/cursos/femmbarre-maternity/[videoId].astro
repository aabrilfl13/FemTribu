---
import { VideoPlayerFactory } from "@videos/components/VideoPlayerFactory"

import Layout from "@/layouts/Layout.astro"
import { getVideo, listVideos, type Video } from "@/videos"

// Get the video ID from the URL
const { videoId } = Astro.params

if (!videoId) {
	return Astro.redirect("/cursos/femmbarre-maternity")
}

// Check if user has access to FemM Barre
const user = Astro.locals.user

if (!user) {
	// Not logged in - redirect to login with next parameter
	const nextUrl = encodeURIComponent(Astro.url.pathname + Astro.url.search)
	return Astro.redirect(`/auth/login?next=${nextUrl}`)
}

if (!user.hasActiveFemmBarre) {
	// Logged in but no access - redirect to access page
	return Astro.redirect("/cursos")
}

// Fetch the specific video
const videoResult = await getVideo(videoId)
if (!videoResult.data) {
	return Astro.redirect("/404")
}

const video = videoResult.data

// Fetch all videos from this course for the playlist
const videosResult = await listVideos({ courseId: "femmbarre-maternity" })
const allVideos: Video[] = videosResult.data ?? []
const sortedVideos = [...allVideos].sort(
	(a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
)

// Helper to format duration
function formatDuration(seconds: number): string {
	const mins = Math.floor(seconds / 60)
	const secs = seconds % 60
	return `${mins}:${secs.toString().padStart(2, "0")}`
}

const seoData = {
	title: `${video.title} - FemmBarre Maternity | Femm tribu`,
	description: video.description || `Disfruta de la clase "${video.title}" de FemmBarre Maternity.`,
	robots: "noindex, nofollow", // Don't index authenticated content
}
---

<Layout navScrolled={true} {...seoData}>
	<main id="main-content" class="pt-22">
		<section
			id="femm-tribu"
			class="bg-background container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8"
		>
			<div class="mx-auto max-w-6xl">
				<!-- Back button -->
				<a
					href="/cursos/femmbarre-maternity"
					class="text-muted-foreground hover:text-primary mb-6 inline-flex items-center gap-2 text-sm transition-colors"
				>
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M15 19l-7-7 7-7"></path>
					</svg>
					Volver a las clases
				</a>

				<div class="grid gap-8 lg:grid-cols-3">
					<!-- Main Content -->
					<div class="lg:col-span-2">
						<!-- Video Player -->
						<div
							class="shadow-warm mb-6 overflow-hidden rounded-2xl border border-gray-100 bg-black"
						>
							<VideoPlayerFactory
								provider={video.provider}
								url={video.url}
								title={video.title}
								client:load
							/>
						</div>

						<!-- Video Info -->
						<div class="rounded-2xl border border-gray-100 bg-white p-6 lg:p-8">
							<h1 class="font-display text-primary mb-3 text-2xl lg:text-3xl">
								{video.title}
							</h1>

							<div class="mb-4 flex flex-wrap gap-3">
								<span
									class="bg-accent/10 text-accent inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm"
								>
									<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
									</svg>
									{formatDuration(video.duration)}
								</span>
								{
									video.metadata?.instructor && (
										<span class="inline-flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-700">
											<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path
													stroke-linecap="round"
													stroke-linejoin="round"
													stroke-width="2"
													d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
												/>
											</svg>
											{video.metadata.instructor}
										</span>
									)
								}
							</div>

							<p class="text-muted-foreground leading-relaxed">
								{video.description}
							</p>
						</div>
					</div>

					<!-- Playlist Sidebar -->
					<div class="lg:col-span-1">
						<div class="rounded-2xl border border-gray-100 bg-white p-6">
							<h2 class="font-display text-primary mb-4 text-lg">
								Más clases ({sortedVideos.length})
							</h2>
							<div class="space-y-3">
								{
									sortedVideos.map((v) => (
										<a
											href={`/cursos/femmbarre-maternity/${v.id}`}
											class={`group block rounded-xl border p-3 transition-all ${
												v.id === video.id
													? "border-[#B85440] bg-[#B85440]/5"
													: "border-gray-100 hover:border-[#B85440]/50 hover:bg-gray-50"
											}`}
										>
											<div class="flex gap-3">
												<div class="relative h-16 w-24 flex-shrink-0 overflow-hidden rounded-lg">
													<img
														src={v.thumbnailUrl}
														alt={v.title}
														class="h-full w-full object-cover"
													/>
													{v.id === video.id && (
														<div class="absolute inset-0 flex items-center justify-center bg-black/40">
															<div class="flex h-6 w-6 items-center justify-center rounded-full bg-[#B85440]">
																<svg
																	class="h-3 w-3 text-white"
																	fill="currentColor"
																	viewBox="0 0 24 24"
																>
																	<path d="M8 5v14l11-7z" />
																</svg>
															</div>
														</div>
													)}
												</div>
												<div class="flex-1">
													<h3
														class={`mb-1 line-clamp-2 text-sm font-semibold ${
															v.id === video.id
																? "text-[#B85440]"
																: "text-gray-900 group-hover:text-[#B85440]"
														}`}
													>
														{v.title}
													</h3>
													<p class="text-muted-foreground text-xs">{formatDuration(v.duration)}</p>
												</div>
											</div>
										</a>
									))
								}
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

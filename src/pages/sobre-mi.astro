---
import BreadcrumbSchema from "@/components/schema/BreadcrumbSchema.astro"
import Layout from "@/layouts/Layout.astro"

export const prerender = true

const pillars = [
	{
		icon: "/images/decoratives/nurse-person.svg",
		title: "Ciencia",
		description: "Basado en evidencia científica actualizada y práctica clínica real.",
	},
	{
		icon: "/images/decoratives/nurse-person.svg",
		title: "Espiritualidad",
		description: "Conectando con tu esencia femenina y los ciclos naturales de la vida.",
	},
	{
		icon: "/images/decoratives/nurse-person.svg",
		title: "Autocuidado",
		description: "Herramientas prácticas para cuidarte en cada etapa de tu camino.",
	},
]

const credentials = [
	{
		icon: "/images/decoratives/nurse-person.svg",
		heigh: "5",
		width: "5",
		title: "Graduada en Enfermería",
		place: "Escuela de Enfermería La Fe",
		year: "2023",
	},
	{
		icon: "/images/decoratives/ilustracion-negro_07.svg",
		title: "Especialización en Obstetricia y Ginecología (Matrona)",
		place: "Hospital Can Misses de Ibiza",
		year: "2025",
	},
	{
		icon: "/images/decoratives/ilustracion-negro_05.svg",
		title: "Máster en Lactancia Materna Avanzada",
		place: "IFSES",
		year: "2025",
	},
	{
		icon: "/images/decoratives/dancer-outline.svg",
		title: "Instructora de Barre",
		place: "The Barre Lab",
		year: "2025",
	},
	{
		icon: "/images/decoratives/exercise-health-fitness.svg",
		title: "Máster en Entrenamiento, Nutrición y Salud en la Mujer",
		place: "ENFAF",
		current: true,
	},
]
---

<Layout
	title="Sobre Femm tribu | Matrona en Valencia y Online"
	description="Femm tribu es un proyecto de acompañamiento integral a mujeres en cada etapa de su vida. Ciencia, autocuidado y comunidad de la mano de la matrona María Belenguer."
	navScrolled={true}
>
	<BreadcrumbSchema items={[{ name: "Sobre nosotras" }]} />
	<main id="main-content" class="pt-22">
		<section
			id="femm-tribu"
			class="bg-background container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8"
		>
			<div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
				<div class="order-2 lg:order-1">
					<span
						class="bg-coral-light/30 text-primary mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm"
						data-animate="animate-slide-in-right"
						data-animate-duration="1s"
					>
						<img
							src="/images/icons/illustrations/ilustracion-negro_14.svg"
							alt=""
							class="text-accent h-4 w-4"
						/>
						Sobre Femm tribu
					</span>
					<h1
						class="font-display text-primary mb-8 text-4xl sm:text-5xl lg:text-6xl"
						data-animate="animate-slide-in-left"
						data-animate-duration="1s"
					>
						María Belenguer, <span class="text-accent">Matrona</span> en <span
							class="text-secondary">Valencia</span
						>
					</h1>
					<div
						class="mb-16 space-y-6"
						data-animate="animate-slide-in-right"
						data-animate-duration="1s"
					>
						<p class="text-muted-foreground mb-8 text-lg leading-relaxed lg:text-xl">
							Femm tribu nace de una necesidad que veía una y otra vez: mujeres que se sienten
							acompañadas solo a medias. Acompañadas en lo físico, en lo médico, pero no siempre en
							lo que realmente importa: <strong class="text-primary"
								>cómo se sienten, qué viven, qué necesitan en cada etapa.</strong
							>
						</p>
						<p class="text-muted-foreground mx-auto max-w-3xl leading-relaxed">
							De ahí surge esta tribu: un espacio para mirar a la mujer de forma completa. Porque no
							somos solo un cuerpo, ni un diagnóstico, ni una etapa concreta de la vida. Somos todo
							eso y mucho más: <strong class="text-primary"
								>emociones, historia, entorno, ritmos, cambios, intuición.</strong
							>
						</p>
					</div>
				</div>
				{/* Hero Image */}
				<div
					class="relative order-1 lg:order-2"
					data-animate="animate-scale-in"
					data-animate-duration="1s"
				>
					<div class="shadow-organic relative overflow-hidden rounded-3xl">
						<img
							src="/images/mujeres-circulo.webp"
							alt="Grupo de mujeres en círculo compartiendo experiencias"
							class="aspect-[4/3] h-auto w-full object-cover"
							loading="lazy"
						/>
					</div>
				</div>
			</div>
			<div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2 lg:gap-8">
				<!-- Card 1 -->
				<div
					class="group hover:border-accent/30 rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
					data-animate="animate-slide-in-diagonal-down-right"
					data-animate-duration="1s"
				>
					<div
						class="bg-coral-light/20 mb-6 flex h-16 w-16 items-center justify-center rounded-full transition-transform duration-300 group-hover:scale-110"
					>
						<img
							src="/images/icons/illustrations/ilustracion-negro_01.svg"
							alt="Ilustración mujeres unidas"
							class="h-12 w-12"
						/>
					</div>
					<p class="text-muted-foreground mx-auto mt-8 max-w-3xl leading-relaxed">
						En Femm tribu te acompañamos a lo largo de todo tu camino como mujer (desde tu ciclo
						menstrual hasta la menopausia, pasando por el embarazo, el posparto y la lactancia) con
						una mirada <strong class="text-primary font-semibold">integral y humana</strong>.
					</p>
				</div>

				<!-- Card 2 -->
				<div
					class="group hover:border-secondary/30 rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
					data-animate="animate-slide-in-diagonal-down-left"
					data-animate-duration="1s"
				>
					<div
						class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-purple-50/50 transition-transform duration-300 group-hover:scale-110"
					>
						<img
							src="/images/icons/illustrations/ilustracion-negro_02.svg"
							alt="Ilustración mujer reflexionando"
							class="h-12 w-12"
						/>
					</div>
					<p class="text-muted-foreground text-base leading-relaxed">
						Queremos ayudarte a <strong class="text-primary font-semibold"
							>reconectar con tu cuerpo</strong
						>, entender sus señales y cuidar de tu salud desde un lugar de amor, presencia y
						conocimiento.
					</p>
				</div>
				<!-- Card 3 -->
				<div
					class="group hover:border-accent/30 rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
					data-animate="animate-slide-in-diagonal-up-right"
					data-animate-duration="1s"
				>
					<div
						class="bg-coral-light/20 mb-6 flex h-16 w-16 items-center justify-center rounded-full transition-transform duration-300 group-hover:scale-110"
					>
						<img
							src="/images/icons/illustrations/ilustracion-negro_04.svg"
							alt="Ilustración grupo de mujeres"
							class="h-12 w-12"
						/>
					</div>
					<p class="text-muted-foreground text-base leading-relaxed">
						Más que un servicio, somos una <strong class="text-primary font-semibold"
							>comunidad</strong
						>. Una tribu de mujeres que se apoyan, se inspiran y se recuerdan que no están solas en
						este viaje.
					</p>
				</div>

				<!-- Card 4 -->
				<div
					class="group hover:border-secondary/30 rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
					data-animate="animate-slide-in-diagonal-up-left"
					data-animate-duration="1s"
				>
					<div
						class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-purple-50/50 transition-transform duration-300 group-hover:scale-110"
					>
						<img
							src="/images/icons/illustrations/ilustracion-negro_11.svg"
							alt="Ilustración autocuidado"
							class="h-12 w-12"
						/>
					</div>
					<p class="text-muted-foreground text-base leading-relaxed">
						Femm tribu es un punto de encuentro entre <strong class="text-primary font-semibold"
							>ciencia y alma</strong
						>, entre acompañamiento profesional y vínculo real. Un lugar donde puedes ser tú, sin
						juicios, y donde cada paso cuenta.
					</p>
				</div>
			</div>
		</section>

		<section id="nuestra-mision" class="bg-primary/5 py-8 lg:py-12">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="grid items-center gap-12 lg:grid-cols-2">
					<div class="order-2 space-y-6 lg:order-1">
						<div
							class="text-accent inline-flex items-center gap-2"
							data-animate="animate-slide-in-left"
							data-animate-duration="1s"
						>
							<!-- <Target class="h-5 w-5" /> -->
							<span class="text-sm font-medium tracking-wider uppercase">Nuestra Misión</span>
						</div>
						<h2
							class="font-display text-primary text-2xl lg:text-3xl"
							data-animate="animate-slide-in-left"
							data-animate-duration="1s"
							data-animate-delay="0.2s"
						>
							Devolver al cuerpo su lugar de sabiduría
						</h2>

						<div
							class="space-y-5"
							data-animate="animate-slide-in-left"
							data-animate-duration="1s"
							data-animate-delay="0.3s"
						>
							<p class="text-muted-foreground leading-relaxed">
								En Femm tribu queremos devolver al cuerpo su lugar de sabiduría. Nuestra misión es
								acompañar a las mujeres en cada una de sus etapas vitales, ofreciéndoles
								información, sostén y comunidad desde una mirada respetuosa, cercana y humana.
							</p>
							<p class="text-muted-foreground leading-relaxed">
								Creamos espacios que inspiran y transforman: asesorías, cursos, encuentros y
								experiencias donde la salud, el autocuidado y la conexión se entrelazan.
							</p>
							<p class="text-primary font-medium">
								Queremos que cada mujer se sienta acompañada en su proceso, libre de vivir su propio
								ritmo, y segura dentro de una tribu que la entiende, la respeta y la abraza.
							</p>
						</div>
					</div>

					<div class="relative order-1 lg:order-2">
						<div class="relative overflow-hidden rounded-3xl bg-transparent opacity-30">
							<img
								src="/images/decoratives/ilustracion-negro_04.svg"
								alt=""
								class="aspect-[4/3] h-auto w-full object-contain mix-blend-multiply"
								data-animate="animate-slide-in-right"
								data-animate-duration="1s"
								data-animate-delay="0.3s"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>
		<section class="bg-muted/30 py-16 lg:py-24" id="detras-de-femm-tribu">
			<div class="container mx-auto px-4 lg:px-8">
				<div
					class="mb-12 text-center"
					data-animate="animate-slide-in-left"
					data-animate-duration="1s"
				>
					<h2 class="font-display text-primary text-2xl lg:text-3xl">
						¿Qué hay detrás de Femm tribu?
					</h2>
				</div>

				<div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-20">
					{/* Image */}
					<div class="relative">
						<div class="bg-gradient-organic shape-blob absolute -inset-6 opacity-10"></div>
						<div class="shadow-organic relative overflow-hidden rounded-3xl">
							<img
								src="/images/about-me/mery-portrait.jpg"
								alt="María Belenguer, matrona, CEO y Fundadora de Femm tribu"
								class="aspect-[4/5] h-auto w-full object-cover"
								loading="lazy"
								data-animate="animate-fade-up"
								data-animate-duration="1s"
							/>
							<div
								class="from-primary/30 absolute inset-0 bg-gradient-to-t via-transparent to-transparent"
							>
							</div>
						</div>
						<div
							class="bg-background shadow-warm absolute -bottom-6 left-6 rounded-2xl px-6 py-4 lg:left-8"
							data-animate="animate-fade-up"
							data-animate-duration="1s"
							data-animate-delay="0.5s"
						>
							<p class="font-display text-primary text-xl">María Belenguer</p>
							<p class="text-accent flex items-center gap-2 text-sm font-medium">
								<img class="h-4 w-4" src="/images/decoratives/ilustracion-negro_24.svg" alt="" />

								CEO & Fundadora
							</p>
						</div>
					</div>

					{/* Content */}
					<div class="space-y-6">
						<p
							class="text-muted-foreground text-lg leading-relaxed"
							data-animate="animate-slide-in-left"
							data-animate-duration="1s"
							data-animate-delay="0.2s"
						>
							Soy <strong class="text-primary">María Belenguer</strong>, matrona y la creadora de
							Femm tribu. Después de años acompañando a mujeres en hospitales, sentí la necesidad de
							crear un espacio donde el cuidado fuera más allá de lo clínico.
						</p>
						<p
							class="text-muted-foreground leading-relaxed"
							data-animate="animate-slide-in-left"
							data-animate-duration="1s"
							data-animate-delay="0.3s"
						>
							Para mí, lo importante es que cada mujer se sienta <strong class="text-primary"
								>escuchada, acompañada y empoderada en cada etapa de su vida.</strong
							> Femm tribu es la materialización de todo esto.
						</p>

						{/* Credentials Grid */}
						<div class="grid grid-cols-2 gap-3 pt-4">
							{
								credentials.map((credential, index) => (
									<div
										class="bg-background shadow-soft rounded-xl p-4"
										data-animate="animate-slide-in-left"
										data-animate-duration="1s"
										data-animate-delay={`0.${index + 2}s`}
									>
										<div class="bg-accent/20 mb-2 flex h-8 w-8 items-center justify-center rounded-lg">
											<img
												src={credential.icon}
												alt={`Icono de ${credential.title}`}
												class={`text-accent h-${credential.heigh || 6} w-${credential.width || 6}`}
											/>
										</div>
										<h3 class="font-display text-primary mb-1 text-sm">{credential.title}</h3>
										<p class="text-muted-foreground text-xs">{credential.place}</p>
										{credential.year && (
											<span class="bg-muted text-muted-foreground mt-1 inline-block rounded-full px-2 py-0.5 text-xs">
												{credential.year}
											</span>
										)}
										{credential.current && (
											<span class="bg-accent/20 text-accent mt-1 inline-block rounded-full px-2 py-0.5 text-xs">
												Actualmente
											</span>
										)}
									</div>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

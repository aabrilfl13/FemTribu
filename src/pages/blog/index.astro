---
import PostCard from "@/components/blog/PostCard.astro"
import BreadcrumbSchema from "@/components/schema/BreadcrumbSchema.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts } from "@/services/directus"

export const prerender = true

const posts = await getPosts()

const seoData = {
	title: "Blog | Matrona Valencia | Femm tribu",
	description:
		"Consejos de matrona sobre lactancia, embarazo, menopausia y salud hormonal. Artículos de María Belenguer y profesionales colaboradores.",
}
---

<Layout {...seoData} navScrolled={true}>
	<BreadcrumbSchema items={[{ name: "Blog" }]} />
	<main class="pt-21">
		{/* Hero Section */}
		<section class="bg-background container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="mx-auto max-w-4xl text-center">
				<span
					class="bg-coral-light/30 text-primary mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm"
					data-animate="animate-fade-up"
					data-animate-duration="1s"
				>
					<svg
						class="h-4 w-4"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
						stroke-width="2"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
						></path>
					</svg>
					Blog de Salud Femenina
				</span>

				<h1
					class="font-display text-primary mb-6 text-4xl sm:text-5xl lg:text-6xl"
					data-animate="animate-fade-up"
					data-animate-duration="1s"
					data-animate-delay="0.1s"
				>
					Consejos de <span class="text-accent">Matrona</span>
				</h1>

				<p
					class="text-muted-foreground mx-auto max-w-3xl text-lg lg:text-xl"
					data-animate="animate-fade-up"
					data-animate-duration="1s"
					data-animate-delay="0.2s"
				>
					Artículos sobre lactancia, embarazo, menopausia y salud hormonal escritos por María
					Belenguer y profesionales colaboradores.
				</p>
			</div>
		</section>

		{/* Blog Posts Grid */}
		<section class="bg-muted/30 py-16 lg:py-24">
			<div class="container mx-auto px-4 lg:px-8">
				{
					posts.length === 0 ? (
						<div class="text-muted-foreground mx-auto max-w-2xl text-center">
							<p class="text-lg">No hay artículos publicados todavía. ¡Vuelve pronto!</p>
						</div>
					) : (
						<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
							{posts.map((post, index) => (
								<PostCard post={post} index={index} />
							))}
						</div>
					)
				}
			</div>
		</section>
	</main>
</Layout>

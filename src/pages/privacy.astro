---
import Layout from "@/layouts/Layout.astro"

const seoData = {
	title: "Política de Privacidad | Femm tribu",
	description:
		"Consulta nuestra Política de Privacidad para entender cómo recopilamos, usamos y protegemos tus datos personales en Femm tribu.",
}
---

<Layout {...seoData} navScrolled={true}>
	<main class="animate-fade-up mt-21">
		<div class="privacy-page">
			<div class="privacy-container">
				<header class="privacy-header">
					<div class="header-content">
						<a href="/" class="back-link">
							<svg viewBox="0 0 24 24" fill="currentColor"
								><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.42-1.41L7.83 13H20v-2z"></path></svg
							>
							Volver al inicio
						</a>
						<h1>Política de Privacidad</h1>
						<p class="last-updated">
							Última actualización: <time datetime="2024-05-20">20 de mayo de 2024</time>
						</p>
					</div>
				</header>

				<main class="privacy-content">
					<div class="content-wrapper">
						<aside class="table-of-contents">
							<h2>Contenido</h2>
							<nav>
								<ul>
									<li><a href="#responsable">1. Responsable</a></li>
									<li><a href="#datos-recopilamos">2. Datos que Recopilamos</a></li>
									<li><a href="#finalidad">3. Finalidad del Tratamiento</a></li>
									<li><a href="#base-legal">4. Base Jurídica</a></li>
									<li><a href="#destinatarios">5. Destinatarios y Herramientas</a></li>
									<li><a href="#derechos">6. Tus Derechos</a></li>
								</ul>
							</nav>
						</aside>

						<article class="policy-content">
							<section id="responsable">
								<h2>1. Responsable del Tratamiento</h2>
								<p>
									El responsable de tus datos es <strong>Femm Tribu</strong>. Para cualquier duda,
									puedes contactarnos en <a href="mailto:info@femmtribu.com">info@femmtribu.com</a>.
								</p>
							</section>

							<section id="datos-recopilamos">
								<h2>2. Datos que Recopilamos</h2>
								<div class="info-box">
									<p>Recogemos información a través de tres vías principales:</p>
									<ul>
										<li>
											<strong>Formularios de Talleres/Webinars:</strong> Nombre, apellidos, email y perfil
											de red social.
										</li>
										<li><strong>Newsletter:</strong> Dirección de correo electrónico.</li>
										<li>
											<strong>Navegación Técnica:</strong> Datos analíticos (IP anonimizada, comportamiento
											en web) a través de Google Analytics y Microsoft Clarity.
										</li>
									</ul>
								</div>
							</section>

							<section id="finalidad">
								<h2>3. Finalidad del Tratamiento</h2>
								<p>Tratamos tus datos para:</p>
								<ul>
									<li>Gestionar tu inscripción y participación en nuestros talleres y webinars.</li>
									<li>
										Enviar nuestra newsletter semanal con contenido sobre maternidad y salud
										femenina.
									</li>
									<li>
										Crear perfiles de "leads" en nuestro CRM para ofrecerte información relevante
										según tus intereses.
									</li>
									<li>
										Optimizar la web mediante el análisis de mapas de calor y métricas de
										rendimiento.
									</li>
								</ul>
							</section>

							<section id="base-legal">
								<h2>4. Base Jurídica</h2>
								<p>
									La base legal para tratar tus datos es el <strong>consentimiento explícito</strong
									> que nos otorgas al marcar la casilla de aceptación en nuestros formularios y en el
									banner de cookies. Puedes retirar este consentimiento en cualquier momento.
								</p>
							</section>

							<section id="destinatarios">
								<h2>5. Destinatarios y Herramientas</h2>
								<p>
									Tus datos no se venden a terceros, pero utilizamos servicios de confianza para
									operar:
								</p>
								<ul>
									<li>
										<strong>Vercel:</strong> Alojamiento de la web y analíticas de rendimiento.
									</li>
									<li><strong>Google Analytics:</strong> Análisis de audiencia.</li>
									<li><strong>Microsoft Clarity:</strong> Análisis de experiencia de usuario.</li>
									<li>
										<strong>CRM (Gestión de Leads):</strong> Para la administración de inscripciones
										y envíos de emails.
									</li>
								</ul>
							</section>

							<section id="derechos">
								<h2>6. Tus Derechos</h2>
								<p>
									Tienes derecho a acceder, rectificar, suprimir tus datos y otros derechos
									detallados en el RGPD. Para ejercerlos, envía un email a <a
										href="mailto:info@femmtribu.com">info@femmtribu.com</a
									> acompañando copia de tu DNI o documento identificativo.
								</p>
							</section>
						</article>
					</div>
				</main>
			</div>
		</div>
	</main>
</Layout>

<style>
	.privacy-page {
		min-height: 100vh;
		background: #fff5eb;
		font-family: "Questrial", sans-serif;
	}

	.privacy-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Header */
	.privacy-header {
		padding: 40px 0 60px;
		background: linear-gradient(135deg, #37443a 0%, #6a8067 100%);
		color: #fff5eb;
		margin: 0 -20px;
	}

	.header-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: rgba(255, 245, 235, 0.8);
		text-decoration: none;
		font-size: 0.9rem;
		margin-bottom: 20px;
		transition: all 0.3s ease;
	}

	.back-link:hover {
		color: #fff5eb;
		transform: translateX(-5px);
	}

	.back-link svg {
		width: 20px;
		height: 20px;
	}

	.privacy-header h1 {
		font-family: "The Seasons", serif;
		font-size: 3rem;
		font-weight: 300;
		margin-bottom: 15px;
		letter-spacing: 1px;
	}

	.last-updated {
		font-size: 0.9rem;
		color: rgba(255, 245, 235, 0.8);
		font-style: italic;
	}

	/* Content Layout */
	.privacy-content {
		padding: 40px 0 80px;
	}

	.content-wrapper {
		display: grid;
		grid-template-columns: 280px 1fr;
		gap: 60px;
		align-items: start;
	}

	/* Table of Contents */
	.table-of-contents {
		position: sticky;
		top: 40px;
		background: white;
		padding: 30px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(55, 68, 58, 0.08);
		border: 1px solid rgba(106, 128, 103, 0.1);
	}

	.table-of-contents h2 {
		font-family: "The Seasons", serif;
		font-size: 1.2rem;
		color: #37443a;
		margin-bottom: 20px;
		font-weight: 400;
	}

	.table-of-contents nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.table-of-contents nav li {
		margin-bottom: 8px;
	}

	.table-of-contents nav a {
		color: #6a8067;
		text-decoration: none;
		font-size: 0.85rem;
		line-height: 1.4;
		transition: all 0.3s ease;
		display: block;
		padding: 5px 0;
		border-left: 2px solid transparent;
		padding-left: 10px;
	}

	.table-of-contents nav a:hover {
		color: #37443a;
		border-left-color: #cb6e5f;
		transform: translateX(5px);
	}

	.table-of-contents nav a.active {
		color: #37443a;
		border-left-color: #cb6e5f;
		font-weight: 500;
		background: rgba(203, 110, 95, 0.05);
		border-radius: 5px;
		margin-left: -10px;
		padding-left: 15px;
	}

	/* Main Content */
	.policy-content {
		background: white;
		padding: 50px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(55, 68, 58, 0.08);
		line-height: 1.7;
	}

	.policy-content h2 {
		font-family: "The Seasons", serif;
		font-size: 1.8rem;
		color: #37443a;
		margin: 40px 0 20px 0;
		font-weight: 400;
		letter-spacing: 0.5px;
		border-bottom: 2px solid rgba(203, 110, 95, 0.2);
		padding-bottom: 10px;
	}

	.policy-content h2:first-child {
		margin-top: 0;
	}

	.policy-content h3 {
		font-family: "The Seasons", serif;
		font-size: 1.3rem;
		color: #37443a;
		margin: 30px 0 15px 0;
		font-weight: 400;
	}

	.policy-content h4 {
		font-family: "The Seasons", serif;
		font-size: 1.1rem;
		color: #37443a;
		margin: 20px 0 10px 0;
		font-weight: 400;
	}

	.policy-content p {
		color: #4a5a4d;
		margin-bottom: 15px;
		text-align: justify;
	}

	.policy-content ul,
	.policy-content ol {
		margin: 15px 0;
		padding-left: 25px;
	}

	.policy-content li {
		color: #4a5a4d;
		margin-bottom: 8px;
	}

	.policy-content strong {
		color: #37443a;
		font-weight: 500;
	}

	.policy-content a {
		color: #cb6e5f;
		text-decoration: none;
		border-bottom: 1px solid rgba(203, 110, 95, 0.3);
		transition: all 0.3s ease;
	}

	.policy-content a:hover {
		color: #37443a;
		border-bottom-color: #37443a;
	}

	.policy-content code {
		background: rgba(203, 110, 95, 0.1);
		padding: 2px 6px;
		border-radius: 4px;
		font-size: 0.9rem;
		color: #a22f11;
		font-family: monospace;
	}

	/* Info Box */
	.info-box {
		background: rgba(203, 110, 95, 0.05);
		padding: 25px;
		border-radius: 15px;
		border-left: 4px solid #cb6e5f;
		margin: 20px 0;
	}

	.info-box p:last-child {
		margin-bottom: 0;
	}

	/* Purposes Grid */
	.purposes-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 20px;
		margin: 25px 0;
	}

	.purpose-item {
		padding: 25px;
		border-radius: 15px;
		border-left: 4px solid;
	}

	.purpose-item.essential {
		background: rgba(46, 204, 113, 0.05);
		border-left-color: #2ecc71;
	}

	.purpose-item.not-used {
		background: rgba(231, 76, 60, 0.05);
		border-left-color: #e74c3c;
	}

	.purpose-item h4 {
		margin: 0 0 15px 0;
		color: #37443a;
		font-size: 1.1rem;
	}

	/* Legal Bases */
	.legal-bases {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 20px;
		margin: 25px 0;
	}

	.legal-basis-item {
		padding: 20px;
		border-radius: 15px;
		border-left: 4px solid;
	}

	.legal-basis-item.consent {
		background: rgba(52, 152, 219, 0.05);
		border-left-color: #3498db;
	}

	.legal-basis-item.contract {
		background: rgba(46, 204, 113, 0.05);
		border-left-color: #2ecc71;
	}

	.legal-basis-item.legitimate {
		background: rgba(155, 89, 182, 0.05);
		border-left-color: #9b59b6;
	}

	.legal-basis-item h4 {
		margin: 0 0 10px 0;
		color: #37443a;
		font-size: 1rem;
	}

	.legal-basis-item ul {
		margin: 0;
		padding-left: 20px;
	}

	/* Tables */
	.retention-table,
	.current-tech-table {
		margin: 20px 0;
		overflow-x: auto;
	}

	.retention-table table,
	.current-tech-table table {
		width: 100%;
		border-collapse: collapse;
		border: 1px solid rgba(106, 128, 103, 0.2);
		border-radius: 10px;
		overflow: hidden;
	}

	.retention-table th,
	.current-tech-table th {
		background: linear-gradient(135deg, #6a8067 0%, #37443a 100%);
		color: white;
		padding: 15px 12px;
		text-align: left;
		font-weight: 500;
		font-size: 0.9rem;
	}

	.retention-table td,
	.current-tech-table td {
		padding: 12px;
		border-bottom: 1px solid rgba(106, 128, 103, 0.1);
		vertical-align: top;
		font-size: 0.9rem;
	}

	.retention-table tr:last-child td,
	.current-tech-table tr:last-child td {
		border-bottom: none;
	}

	.retention-table tr:nth-child(even),
	.current-tech-table tr:nth-child(even) {
		background: rgba(106, 128, 103, 0.02);
	}

	/* No Sale Box */
	.no-sale-box {
		background: linear-gradient(135deg, rgba(203, 110, 95, 0.1), rgba(213, 161, 142, 0.1));
		padding: 25px;
		border-radius: 15px;
		border: 1px solid rgba(203, 110, 95, 0.2);
		margin: 20px 0;
		text-align: center;
	}

	.no-sale-box p {
		margin: 0;
		color: #37443a;
	}

	.no-sale-box p:last-child {
		margin-top: 10px;
		font-size: 0.95rem;
	}

	/* Providers Grid */
	.providers-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 20px;
		margin: 25px 0;
	}

	.provider-item {
		background: rgba(106, 128, 103, 0.05);
		padding: 20px;
		border-radius: 15px;
		border-left: 4px solid #6a8067;
	}

	.provider-item h4 {
		margin: 0 0 10px 0;
		color: #37443a;
		font-size: 1rem;
	}

	.provider-item ul {
		margin: 0;
		padding-left: 20px;
	}

	/* Rights Grid */
	.rights-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 15px;
		margin: 25px 0;
	}

	.right-item {
		background: rgba(106, 128, 103, 0.05);
		padding: 20px;
		border-radius: 15px;
		border-left: 4px solid #6a8067;
		text-align: center;
	}

	.right-item h4 {
		margin: 0 0 10px 0;
		color: #37443a;
		font-size: 1rem;
	}

	.right-item p {
		margin: 0;
		font-size: 0.9rem;
		color: #4a5a4d;
	}

	/* Exercise Rights */
	.exercise-rights {
		background: rgba(203, 110, 95, 0.05);
		padding: 25px;
		border-radius: 15px;
		border-left: 4px solid #cb6e5f;
		margin: 20px 0;
	}

	.exercise-rights ol {
		background: white;
		padding: 15px 20px 15px 35px;
		border-radius: 10px;
		margin: 0;
	}

	/* Contact Grid */
	.contact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 20px;
		margin: 25px 0;
	}

	.contact-item {
		background: rgba(203, 110, 95, 0.05);
		padding: 25px;
		border-radius: 15px;
		border-left: 4px solid #cb6e5f;
	}

	.contact-item h4 {
		margin: 0 0 15px 0;
		color: #37443a;
		font-size: 1.1rem;
	}

	.contact-item ul {
		margin: 0;
		padding-left: 20px;
	}

	/* FAQ Section */
	.faq-section {
		margin-top: 50px;
		padding-top: 40px;
		border-top: 2px solid rgba(106, 128, 103, 0.1);
	}

	.faq-item {
		background: rgba(106, 128, 103, 0.05);
		padding: 25px;
		border-radius: 15px;
		margin-bottom: 20px;
		border-left: 4px solid #6a8067;
	}

	.faq-item h3 {
		font-family: "The Seasons", serif;
		font-size: 1.1rem;
		color: #37443a;
		margin: 0 0 10px 0;
		font-weight: 400;
	}

	.faq-item p {
		margin: 0;
		color: #4a5a4d;
	}

	/* Legal Note */
	.legal-note {
		background: linear-gradient(135deg, rgba(203, 110, 95, 0.1), rgba(213, 161, 142, 0.1));
		padding: 25px;
		border-radius: 15px;
		border: 1px solid rgba(203, 110, 95, 0.2);
		margin-top: 40px;
		text-align: center;
	}

	.legal-note p {
		margin: 0;
		color: #37443a;
		font-size: 0.95rem;
		line-height: 1.6;
	}

	/* Section Spacing */
	.policy-content section {
		scroll-margin-top: 100px;
	}

	/* Responsive Design */
	@media (max-width: 1024px) {
		.content-wrapper {
			grid-template-columns: 250px 1fr;
			gap: 40px;
		}

		.policy-content {
			padding: 40px 30px;
		}

		.table-of-contents {
			padding: 25px;
		}
	}

	@media (max-width: 768px) {
		.privacy-container {
			padding: 0 15px;
		}

		.privacy-header {
			margin: 0 -15px;
		}

		.privacy-header h1 {
			font-size: 2.2rem;
		}

		.content-wrapper {
			grid-template-columns: 1fr;
			gap: 30px;
		}

		.table-of-contents {
			position: static;
			order: 1;
			margin-top: 40px;
		}

		.policy-content {
			padding: 30px 20px;
			order: 2;
		}

		.policy-content h2 {
			font-size: 1.5rem;
		}

		.policy-content h3 {
			font-size: 1.2rem;
		}

		.purposes-grid,
		.legal-bases,
		.providers-grid,
		.rights-grid,
		.contact-grid {
			grid-template-columns: 1fr;
		}

		.retention-table table,
		.current-tech-table table {
			font-size: 0.8rem;
		}

		.retention-table th,
		.retention-table td,
		.current-tech-table th,
		.current-tech-table td {
			padding: 8px;
		}
	}

	@media (max-width: 480px) {
		.privacy-header h1 {
			font-size: 1.8rem;
		}

		.policy-content {
			padding: 25px 15px;
		}

		.table-of-contents {
			padding: 20px;
		}

		.info-box,
		.purpose-item,
		.legal-basis-item,
		.provider-item,
		.right-item,
		.exercise-rights,
		.contact-item,
		.faq-item,
		.legal-note,
		.no-sale-box {
			padding: 20px;
		}
	}

	/* Smooth scroll */
	html {
		scroll-behavior: smooth;
	}

	/* Print styles */
	@media print {
		.privacy-header,
		.table-of-contents,
		.back-link {
			display: none;
		}

		.content-wrapper {
			grid-template-columns: 1fr;
		}

		.policy-content {
			box-shadow: none;
			padding: 0;
		}
	}
</style>

<script>
	// Smooth scrolling for table of contents links
	document.addEventListener("DOMContentLoaded", () => {
		const tocLinks = document.querySelectorAll('.table-of-contents a[href^="#"]')

		tocLinks.forEach((link) => {
			link.addEventListener("click", (e) => {
				e.preventDefault()
				const targetId = link.getAttribute("href")
				const targetElement = document.querySelector(targetId)

				if (targetElement) {
					targetElement.scrollIntoView({
						behavior: "smooth",
						block: "start",
					})
				}
			})
		})

		// Highlight current section in table of contents
		const sections = document.querySelectorAll(".policy-content section[id]")
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						// Remove active class from all links
						tocLinks.forEach((link) => link.classList.remove("active"))

						// Add active class to current link
						const activeLink = document.querySelector(
							`.table-of-contents a[href="#${entry.target.id}"]`
						)
						if (activeLink) {
							activeLink.classList.add("active")
						}
					}
				})
			},
			{
				rootMargin: "-20% 0px -80% 0px",
			}
		)

		sections.forEach((section) => {
			observer.observe(section)
		})
	})
</script>

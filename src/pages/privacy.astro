---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Política de Privacidad - Femm Tribu">
	<div class="privacy-page">
		<div class="privacy-container">
			<!-- Header -->
			<header class="privacy-header">
				<div class="header-content">
					<a href="/" class="back-link">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.42-1.41L7.83 13H20v-2z"></path>
						</svg>
						Volver al inicio
					</a>
					<h1>Política de Privacidad</h1>
					<p class="last-updated">
						Última actualización: <time datetime="2025-01-17">17 de enero de 2025</time>
					</p>
				</div>
			</header>

			<!-- Content -->
			<main class="privacy-content">
				<div class="content-wrapper">
					<!-- Table of Contents -->
					<aside class="table-of-contents">
						<h2>Contenido</h2>
						<nav>
							<ul>
								<li><a href="#responsable">1. Responsable</a></li>
								<li><a href="#datos-recopilamos">2. Datos que Recopilamos</a></li>
								<li><a href="#como-utilizamos">3. Cómo Utilizamos tu Información</a></li>
								<li><a href="#base-legal">4. Base Legal</a></li>
								<li><a href="#conservacion">5. Conservación de Datos</a></li>
								<li><a href="#compartir">6. Compartir Información</a></li>
								<li><a href="#cookies">7. Cookies y localStorage</a></li>
								<li><a href="#tus-derechos">8. Tus Derechos</a></li>
								<li><a href="#seguridad">9. Seguridad</a></li>
								<li><a href="#contacto">10. Contacto</a></li>
							</ul>
						</nav>
					</aside>

					<!-- Main Content -->
					<article class="policy-content">
						<section id="responsable">
							<h2>1. Responsable del Tratamiento</h2>
							<div class="info-box">
								<p><strong>María Belenguer</strong> (Femm Tribu)</p>
								<ul>
									<li>
										<strong>Actividad:</strong> Servicios de matrona y educación en maternidad
									</li>
									<li><strong>Ubicación:</strong> Valencia, España</li>
									<li>
										<strong>Email:</strong>
										<a href="mailto:info@femmtribu.com">info@femmtribu.com</a>
									</li>
									<li><strong>Web:</strong> www.femmtribu.es</li>
								</ul>
							</div>
						</section>

						<section id="datos-recopilamos">
							<h2>2. Datos que Recopilamos</h2>

							<h3>2.1 Información que Proporcionas</h3>
							<ul>
								<li><strong>Email:</strong> Para acceder al curso "Prepárate para amamantar"</li>
								<li><strong>Nombre:</strong> Si lo proporcionas voluntariamente al registrarte</li>
								<li>
									<strong>Consultas:</strong> Mensajes que nos envíes por email o redes sociales
								</li>
							</ul>

							<h3>2.2 Información Técnica Automática</h3>
							<ul>
								<li><strong>Datos de navegación:</strong> Páginas visitadas, tiempo en el sitio</li>
								<li>
									<strong>Información técnica:</strong> Dirección IP, navegador, dispositivo (logs básicos
									del servidor)
								</li>
							</ul>

							<h3>2.3 Servicios de Terceros</h3>
							<ul>
								<li><strong>YouTube:</strong> Datos de reproducción de videos del curso</li>
								<li>
									<strong>Vercel (hosting):</strong> Logs de servidor para funcionamiento técnico
								</li>
							</ul>
						</section>

						<section id="como-utilizamos">
							<h2>3. Cómo Utilizamos tu Información</h2>

							<div class="purposes-grid">
								<div class="purpose-item essential">
									<h4>✅ SÍ utilizamos para:</h4>
									<ul>
										<li>Proporcionar acceso al curso gratuito "Prepárate para amamantar"</li>
										<li>Enviar códigos de verificación por email</li>
										<li>Responder a consultas sobre maternidad y lactancia</li>
										<li>Funcionamiento técnico del sitio web</li>
										<li>Prevenir spam y accesos no autorizados</li>
									</ul>
								</div>

								<div class="purpose-item not-used">
									<h4>❌ NO utilizamos para:</h4>
									<ul>
										<li>Vender tus datos a terceros</li>
										<li>Marketing agresivo o spam</li>
										<li>Seguimiento entre sitios web</li>
										<li>Perfilado comercial detallado</li>
										<li>Publicidad personalizada externa</li>
									</ul>
								</div>
							</div>
						</section>

						<section id="base-legal">
							<h2>4. Base Legal del Tratamiento</h2>

							<div class="legal-bases">
								<div class="legal-basis-item consent">
									<h4>Consentimiento (Art. 6.1.a RGPD)</h4>
									<ul>
										<li>Registro al curso educativo</li>
										<li>Comunicaciones por email</li>
										<li>Cookies de YouTube</li>
									</ul>
								</div>

								<div class="legal-basis-item contract">
									<h4>Ejecución de Contrato (Art. 6.1.b RGPD)</h4>
									<ul>
										<li>Proporcionar acceso al curso gratuito</li>
										<li>Envío de códigos de verificación</li>
									</ul>
								</div>

								<div class="legal-basis-item legitimate">
									<h4>Interés Legítimo (Art. 6.1.f RGPD)</h4>
									<ul>
										<li>Seguridad del sitio web</li>
										<li>Análisis básico de funcionamiento</li>
										<li>Prevención de fraudes</li>
									</ul>
								</div>
							</div>
						</section>

						<section id="conservacion">
							<h2>5. Conservación de Datos</h2>

							<div class="retention-table">
								<table>
									<thead>
										<tr>
											<th>Tipo de Dato</th>
											<th>Duración</th>
											<th>Motivo</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td>Email del curso</td>
											<td>Hasta solicitar baja</td>
											<td>Acceso continuado al contenido</td>
										</tr>
										<tr>
											<td>localStorage (navegador)</td>
											<td>Acceso a videos</td>
										</tr>
										<tr>
											<td>Logs del servidor</td>
											<td>30 días</td>
											<td>Mantenimiento técnico</td>
										</tr>
										<tr>
											<td>Consultas por email</td>
											<td>2 años</td>
											<td>Historial de atención</td>
										</tr>
									</tbody>
								</table>
							</div>
						</section>

						<section id="compartir">
							<h2>6. Compartir Información</h2>

							<div class="no-sale-box">
								<p><strong>🔒 Compromiso: Nunca vendemos tus datos</strong></p>
								<p>
									No vendemos, alquilamos ni intercambiamos tu información personal con terceros
									para fines comerciales.
								</p>
							</div>

							<h3>6.1 Proveedores de Servicios Necesarios</h3>
							<div class="providers-grid">
								<div class="provider-item">
									<h4>Vercel (Hosting)</h4>
									<ul>
										<li><strong>Ubicación:</strong> Estados Unidos</li>
										<li><strong>Datos:</strong> Logs de acceso, métricas técnicas</li>
										<li><strong>Protección:</strong> Decisión de adecuación UE-US</li>
									</ul>
								</div>

								<div class="provider-item">
									<h4>YouTube (Videos)</h4>
									<ul>
										<li><strong>Finalidad:</strong> Reproducción de videos educativos</li>
										<li><strong>Datos:</strong> Interacciones con videos</li>
										<li><strong>Control:</strong> Configurable en tu cuenta Google</li>
									</ul>
								</div>
							</div>
						</section>

						<section id="cookies">
							<h2>7. Cookies y Almacenamiento Local</h2>

							<h3>7.1 Tecnologías Actuales</h3>
							<div class="current-tech-table">
								<table>
									<thead>
										<tr>
											<th>Tecnología</th>
											<th>Finalidad</th>
											<th>Duración</th>
											<th>Tipo</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td><code>videoAccess</code> (localStorage)</td>
											<td>Control de acceso a videos</td>
											<td>Esencial</td>
										</tr>
										<tr>
											<td>Cookies de YouTube</td>
											<td>Reproducción de videos embebidos</td>
											<td>Variable</td>
											<td>Terceros</td>
										</tr>
										<tr>
											<td>Cookies de sesión</td>
											<td>Funcionamiento básico</td>
											<td>Hasta cerrar navegador</td>
											<td>Esencial</td>
										</tr>
									</tbody>
								</table>
							</div>

							<p>
								<strong>Para más detalles:</strong> Consulta nuestra <a href="/cookies"
									>Política de Cookies completa</a
								>.
							</p>
						</section>

						<section id="tus-derechos">
							<h2>8. Tus Derechos bajo el RGPD</h2>

							<div class="rights-grid">
								<div class="right-item">
									<h4>📄 Acceso</h4>
									<p>Solicitar copia de todos tus datos</p>
								</div>

								<div class="right-item">
									<h4>✏️ Rectificación</h4>
									<p>Corregir datos inexactos</p>
								</div>

								<div class="right-item">
									<h4>🗑️ Supresión</h4>
									<p>Eliminar tus datos ("derecho al olvido")</p>
								</div>

								<div class="right-item">
									<h4>⏸️ Limitación</h4>
									<p>Restringir el procesamiento</p>
								</div>

								<div class="right-item">
									<h4>📦 Portabilidad</h4>
									<p>Llevarte tus datos a otro servicio</p>
								</div>

								<div class="right-item">
									<h4>🚫 Oposición</h4>
									<p>Oponerte al tratamiento</p>
								</div>
							</div>

							<h3>8.1 Cómo Ejercer tus Derechos</h3>
							<div class="exercise-rights">
								<ol>
									<li>Envía email a <a href="mailto:info@femmtribu.com">info@femmtribu.com</a></li>
									<li>Indica claramente qué derecho quieres ejercer</li>
									<li>Incluye información para identificarte (email usado)</li>
									<li>Te responderemos en máximo 30 días</li>
								</ol>
							</div>
						</section>

						<section id="seguridad">
							<h2>9. Seguridad de los Datos</h2>

							<h3>9.1 Medidas Técnicas</h3>
							<ul>
								<li><strong>Cifrado HTTPS:</strong> Todas las comunicaciones cifradas</li>
								<li><strong>Hosting seguro:</strong> Infraestructura certificada de Vercel</li>
								<li><strong>Minimización:</strong> Solo recopilamos datos necesarios</li>
							</ul>

							<h3>9.2 En Caso de Incidente</h3>
							<ul>
								<li>Notificaremos a la AEPD dentro de 72 horas</li>
								<li>Te informaremos si hay riesgo para tus derechos</li>
								<li>Aplicaremos medidas correctivas inmediatas</li>
							</ul>
						</section>

						<section id="contacto">
							<h2>10. Contacto</h2>

							<div class="contact-grid">
								<div class="contact-item">
									<h4>Para Ejercer tus Derechos</h4>
									<ul>
										<li>
											<strong>Email:</strong>
											<a href="mailto:info@femmtribu.com">info@femmtribu.com</a>
										</li>
										<li><strong>Asunto:</strong> "Derechos RGPD"</li>
										<li><strong>Respuesta:</strong> Máximo 30 días</li>
									</ul>
								</div>

								<div class="contact-item">
									<h4>Si No Estás Satisfecha</h4>
									<ul>
										<li>
											<strong>AEPD:</strong>
											<a href="https://www.aepd.es" target="_blank">www.aepd.es</a>
										</li>
										<li><strong>Teléfono:</strong> 901 100 099</li>
										<li>
											<strong>Sede:</strong>
											<a href="https://sedeagpd.gob.es" target="_blank">sedeagpd.gob.es</a>
										</li>
									</ul>
								</div>
							</div>
						</section>

						<!-- FAQ Section -->
						<section class="faq-section">
							<h2>Preguntas Frecuentes</h2>

							<div class="faq-item">
								<h3>¿Qué datos necesito proporcionar para el curso?</h3>
								<p>Solo tu email. No necesitas teléfono, dirección ni otros datos personales.</p>
							</div>

							<div class="faq-item">
								<h3>¿Vais a vender mi email a otras empresas?</h3>
								<p>
									Nunca. Tu email se usa únicamente para darte acceso a nuestro contenido educativo.
								</p>
							</div>

							<div class="faq-item">
								<h3>¿Cómo elimino todos mis datos?</h3>
								<p>
									Envía un email a info@femmtribu.com con "Eliminar datos" en el asunto. Lo haremos
									en 5 días laborables.
								</p>
							</div>

							<div class="faq-item">
								<h3>¿Qué pasa si borro las cookies de mi navegador?</h3>
								<p>
									Perderás el acceso temporal a los videos, pero puedes solicitarlo de nuevo con tu
									email sin problema.
								</p>
							</div>
						</section>

						<!-- Legal Note -->
						<div class="legal-note">
							<p>
								<strong>Esta política cumple con:</strong><br />
								• Reglamento General de Protección de Datos (RGPD) - UE 2016/679<br />
								• Ley Orgánica 3/2018 de Protección de Datos (LOPDGDD)<br />
								• Directiva 2002/58/CE sobre privacidad electrónica
							</p>
						</div>
					</article>
				</div>
			</main>
		</div>
	</div>
</Layout>

<style>
	.privacy-page {
		min-height: 100vh;
		background: #fff5eb;
		font-family: "Questrial", sans-serif;
	}

	.privacy-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;
	}

	/* Header */
	.privacy-header {
		padding: 40px 0 60px;
		background: linear-gradient(135deg, #37443a 0%, #6a8067 100%);
		color: #fff5eb;
		margin: 0 -20px;
	}

	.header-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: rgba(255, 245, 235, 0.8);
		text-decoration: none;
		font-size: 0.9rem;
		margin-bottom: 20px;
		transition: all 0.3s ease;
	}

	.back-link:hover {
		color: #fff5eb;
		transform: translateX(-5px);
	}

	.back-link svg {
		width: 20px;
		height: 20px;
	}

	.privacy-header h1 {
		font-family: "The Seasons", serif;
		font-size: 3rem;
		font-weight: 300;
		margin-bottom: 15px;
		letter-spacing: 1px;
	}

	.last-updated {
		font-size: 0.9rem;
		color: rgba(255, 245, 235, 0.8);
		font-style: italic;
	}

	/* Content Layout */
	.privacy-content {
		padding: 40px 0 80px;
	}

	.content-wrapper {
		display: grid;
		grid-template-columns: 280px 1fr;
		gap: 60px;
		align-items: start;
	}

	/* Table of Contents */
	.table-of-contents {
		position: sticky;
		top: 40px;
		background: white;
		padding: 30px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(55, 68, 58, 0.08);
		border: 1px solid rgba(106, 128, 103, 0.1);
	}

	.table-of-contents h2 {
		font-family: "The Seasons", serif;
		font-size: 1.2rem;
		color: #37443a;
		margin-bottom: 20px;
		font-weight: 400;
	}

	.table-of-contents nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.table-of-contents nav li {
		margin-bottom: 8px;
	}

	.table-of-contents nav a {
		color: #6a8067;
		text-decoration: none;
		font-size: 0.85rem;
		line-height: 1.4;
		transition: all 0.3s ease;
		display: block;
		padding: 5px 0;
		border-left: 2px solid transparent;
		padding-left: 10px;
	}

	.table-of-contents nav a:hover {
		color: #37443a;
		border-left-color: #cb6e5f;
		transform: translateX(5px);
	}

	.table-of-contents nav a.active {
		color: #37443a;
		border-left-color: #cb6e5f;
		font-weight: 500;
		background: rgba(203, 110, 95, 0.05);
		border-radius: 5px;
		margin-left: -10px;
		padding-left: 15px;
	}

	/* Main Content */
	.policy-content {
		background: white;
		padding: 50px;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(55, 68, 58, 0.08);
		line-height: 1.7;
	}

	.policy-content h2 {
		font-family: "The Seasons", serif;
		font-size: 1.8rem;
		color: #37443a;
		margin: 40px 0 20px 0;
		font-weight: 400;
		letter-spacing: 0.5px;
		border-bottom: 2px solid rgba(203, 110, 95, 0.2);
		padding-bottom: 10px;
	}

	.policy-content h2:first-child {
		margin-top: 0;
	}

	.policy-content h3 {
		font-family: "The Seasons", serif;
		font-size: 1.3rem;
		color: #37443a;
		margin: 30px 0 15px 0;
		font-weight: 400;
	}

	.policy-content h4 {
		font-family: "The Seasons", serif;
		font-size: 1.1rem;
		color: #37443a;
		margin: 20px 0 10px 0;
		font-weight: 400;
	}

	.policy-content p {
		color: #4a5a4d;
		margin-bottom: 15px;
		text-align: justify;
	}

	.policy-content ul,
	.policy-content ol {
		margin: 15px 0;
		padding-left: 25px;
	}

	.policy-content li {
		color: #4a5a4d;
		margin-bottom: 8px;
	}

	.policy-content strong {
		color: #37443a;
		font-weight: 500;
	}

	.policy-content a {
		color: #cb6e5f;
		text-decoration: none;
		border-bottom: 1px solid rgba(203, 110, 95, 0.3);
		transition: all 0.3s ease;
	}

	.policy-content a:hover {
		color: #37443a;
		border-bottom-color: #37443a;
	}

	.policy-content code {
		background: rgba(203, 110, 95, 0.1);
		padding: 2px 6px;
		border-radius: 4px;
		font-size: 0.9rem;
		color: #a22f11;
		font-family: monospace;
	}

	/* Info Box */
	.info-box {
		background: rgba(203, 110, 95, 0.05);
		padding: 25px;
		border-radius: 15px;
		border-left: 4px solid #cb6e5f;
		margin: 20px 0;
	}

	.info-box p:last-child {
		margin-bottom: 0;
	}

	/* Purposes Grid */
	.purposes-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 20px;
		margin: 25px 0;
	}

	.purpose-item {
		padding: 25px;
		border-radius: 15px;
		border-left: 4px solid;
	}

	.purpose-item.essential {
		background: rgba(46, 204, 113, 0.05);
		border-left-color: #2ecc71;
	}

	.purpose-item.not-used {
		background: rgba(231, 76, 60, 0.05);
		border-left-color: #e74c3c;
	}

	.purpose-item h4 {
		margin: 0 0 15px 0;
		color: #37443a;
		font-size: 1.1rem;
	}

	/* Legal Bases */
	.legal-bases {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 20px;
		margin: 25px 0;
	}

	.legal-basis-item {
		padding: 20px;
		border-radius: 15px;
		border-left: 4px solid;
	}

	.legal-basis-item.consent {
		background: rgba(52, 152, 219, 0.05);
		border-left-color: #3498db;
	}

	.legal-basis-item.contract {
		background: rgba(46, 204, 113, 0.05);
		border-left-color: #2ecc71;
	}

	.legal-basis-item.legitimate {
		background: rgba(155, 89, 182, 0.05);
		border-left-color: #9b59b6;
	}

	.legal-basis-item h4 {
		margin: 0 0 10px 0;
		color: #37443a;
		font-size: 1rem;
	}

	.legal-basis-item ul {
		margin: 0;
		padding-left: 20px;
	}

	/* Tables */
	.retention-table,
	.current-tech-table {
		margin: 20px 0;
		overflow-x: auto;
	}

	.retention-table table,
	.current-tech-table table {
		width: 100%;
		border-collapse: collapse;
		border: 1px solid rgba(106, 128, 103, 0.2);
		border-radius: 10px;
		overflow: hidden;
	}

	.retention-table th,

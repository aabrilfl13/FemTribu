---
import Layout from "@/layouts/Layout.astro"

export const prerender = false
---

<Layout title="Cerrando sesión | Femm tribu" navScrolled={true} noindex={true}>
	<main
		class="flex min-h-[calc(100vh-5.5rem)] items-center justify-center bg-gradient-to-br from-[#FAF7F5] to-[#7A9582]/10 pt-22"
	>
		<div class="w-full max-w-md px-6 text-center">
			<div class="mb-8">
				<div class="relative mx-auto h-24 w-24">
					<img
						src="/images/logos/logo_icono.svg"
						alt="Femm tribu"
						class="h-full w-full animate-pulse"
					/>
				</div>
			</div>

			<h1 class="font-display text-primary mb-4 text-3xl lg:text-4xl">Cerrando sesión...</h1>

			<p class="text-muted-foreground mb-8 text-sm">Estás saliendo de tu cuenta de forma segura</p>

			<div
				id="logout-status"
				class="mx-auto max-w-sm rounded-2xl border border-gray-100 bg-white p-6 shadow-sm"
			>
				<div class="flex items-center justify-center gap-3">
					<svg
						class="h-5 w-5 animate-spin text-[#B85440]"
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
					>
						<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"
						></circle>
						<path
							class="opacity-75"
							fill="currentColor"
							d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
						></path>
					</svg>
					<span class="text-sm text-gray-600">Procesando...</span>
				</div>
			</div>

			<div class="mt-8">
				<a
					href="/"
					class="text-muted-foreground inline-flex items-center gap-2 text-sm transition-colors hover:text-[#B85440]"
				>
					<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M15 19l-7-7 7-7"></path>
					</svg>
					Volver al inicio
				</a>
			</div>
		</div>
	</main>
</Layout>

<script>
	async function handleLogout() {
		const statusDiv = document.getElementById("logout-status")
		console.log("Iniciando proceso de logout...")
		try {
			const response = await fetch("/api/auth/signout", {
				method: "POST",
			})

			if (response.ok) {
				// Success state
				if (statusDiv) {
					statusDiv.innerHTML = `
						<div class="flex items-center justify-center gap-3 text-[#7A9582]">
							<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
							</svg>
							<span class="text-sm font-medium">Sesión cerrada correctamente</span>
						</div>
					`
				}

				// Redirect after a brief delay
				setTimeout(() => {
					window.location.href = "/"
				}, 1000)
			} else {
				throw new Error("Error al cerrar sesión")
			}
		} catch (error) {
			// Error state
			if (statusDiv) {
				statusDiv.innerHTML = `
					<div class="text-center">
						<div class="mb-3 flex items-center justify-center gap-3 text-[#B85440]">
							<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
							</svg>
							<span class="text-sm font-medium">Error al cerrar sesión</span>
						</div>
						<a href="/" class="text-sm text-[#B85440] hover:underline">Ir al inicio</a>
					</div>
				`
			}

			console.error("Logout failed:", error)
		}
	}

	// Auto-execute on page load
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", handleLogout)
	} else {
		handleLogout()
	}
</script>

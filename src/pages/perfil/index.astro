---
import UserCourses from "@/components/profile/UserCourses"
import Layout from "@/layouts/Layout.astro"

const user = Astro.locals.user
const displayName = user?.displayName || user?.email?.split("@")[0] || "Usuario"
const initials = displayName
	? displayName
			.split(" ")
			.map((n) => n[0])
			.join("")
			.toUpperCase()
			.slice(0, 2)
	: "U"

const memberSince = user?.createdAt
	? new Date(user.createdAt).toLocaleDateString("es-ES", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: new Date().toLocaleDateString("es-ES", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
---

<Layout navScrolled={true}>
	<main class="min-h-screen bg-gradient-to-br from-[#FAF7F5] via-white to-[#7A9582]/5 pt-21">
		<!-- Hero Header -->
		<div
			class="relative overflow-hidden bg-gradient-to-r from-[#2D3E2F] to-[#7A9582] py-16 lg:py-20"
		>
			<!-- Decorative spiral pattern -->
			<div class="absolute inset-0 opacity-5">
				<div class="absolute top-0 right-0 h-64 w-64 translate-x-1/4 -translate-y-1/4">
					<img
						src="/images/logos/logo_icono.svg"
						alt=""
						class="h-full w-full"
						style="filter: brightness(0) invert(1);"
					/>
				</div>
			</div>

			<div class="relative z-10 container mx-auto px-4 lg:px-8">
				<div
					class="flex flex-col items-center gap-6 text-center text-white lg:flex-row lg:text-left"
				>
					<!-- Profile Avatar -->
					<div
						class="relative flex h-24 w-24 flex-shrink-0 items-center justify-center overflow-hidden rounded-full bg-white/10 shadow-xl ring-4 ring-white/20 backdrop-blur-sm lg:h-28 lg:w-28"
					>
						<span class="font-display text-3xl font-bold text-white lg:text-4xl">{initials}</span>
						<div class="absolute inset-0 bg-gradient-to-br from-[#B85440]/20 to-[#D88B7D]/20"></div>
					</div>

					<!-- Profile Info -->
					<div class="flex-1">
						<h1 class="font-display mb-2 text-4xl lg:text-5xl">
							Hola, {displayName}
						</h1>
						<p class="text-lg text-white/90">Bienvenida de nuevo a tu tribu</p>
					</div>

					<!-- Logout Button -->
					<a
						href="/auth/logout"
						class="inline-flex items-center gap-2 rounded-full border-2 border-white/30 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20 lg:px-8"
					>
						<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
							></path>
						</svg>
						Cerrar sesión
					</a>
				</div>
			</div>
		</div>

		<!-- Main Content -->
		<div class="container mx-auto px-4 py-12 lg:px-8 lg:py-16">
			<div class="mx-auto max-w-5xl">
				<!-- Profile Details Grid -->
				<div class="mb-8 grid gap-6 lg:grid-cols-2">
					<!-- Account Information Card -->
					<div
						class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:shadow-md lg:p-8"
					>
						<div class="mb-6 flex items-center gap-3">
							<div class="rounded-full bg-[#7A9582]/10 p-3">
								<svg
									class="h-6 w-6 text-[#7A9582]"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
								</svg>
							</div>
							<h2 class="font-display text-primary text-2xl">Información de cuenta</h2>
						</div>

						<div class="space-y-4">
							<div>
								<label
									class="text-muted-foreground mb-1 block text-xs font-semibold tracking-wide uppercase"
								>
									Email
								</label>
								<p class="text-primary flex items-center gap-2 text-base">
									{user?.email}
									{
										user?.emailVerified && (
											<span class="inline-flex items-center gap-1 rounded-full bg-[#7A9582]/10 px-2 py-0.5 text-xs font-medium text-[#7A9582]">
												<svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
													<path
														fill-rule="evenodd"
														d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
														clip-rule="evenodd"
													/>
												</svg>
												Verificado
											</span>
										)
									}
								</p>
							</div>

							{
								user?.displayName && (
									<div>
										<label class="text-muted-foreground mb-1 block text-xs font-semibold tracking-wide uppercase">
											Nombre
										</label>
										<p class="text-primary text-base">{user.displayName}</p>
									</div>
								)
							}

							<div>
								<label
									class="text-muted-foreground mb-1 block text-xs font-semibold tracking-wide uppercase"
								>
									Miembro desde
								</label>
								<p class="text-primary text-base">
									{memberSince}
								</p>
							</div>
						</div>

						<button
							class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-[#B85440] to-[#D88B7D] px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:scale-[1.02] hover:shadow-md"
						>
							<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
								></path>
							</svg>
							Editar perfil
						</button>
					</div>

					<!-- Subscribed Courses -->
					<div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm lg:p-8">
						<div class="mb-6 flex items-center gap-3">
							<div class="rounded-full bg-[#B85440]/10 p-3">
								<svg
									class="h-6 w-6 text-[#B85440]"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
									></path>
								</svg>
							</div>
							<h2 class="font-display text-primary text-2xl">Courses you are in</h2>
						</div>

						<UserCourses client:load />
					</div>
				</div>

				<!-- Quick Actions -->
				<div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm lg:p-8">
					<h2 class="font-display text-primary mb-6 text-2xl">Acciones rápidas</h2>

					<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
						<a
							href="/eventos"
							class="group flex items-start gap-4 rounded-xl border border-gray-100 bg-[#FAF7F5] p-4 transition-all hover:border-[#7A9582] hover:shadow-md"
						>
							<div class="rounded-lg bg-white p-2.5 shadow-sm">
								<svg
									class="h-5 w-5 text-[#7A9582]"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
									></path>
								</svg>
							</div>
							<div>
								<p class="text-primary mb-1 text-sm font-semibold group-hover:text-[#7A9582]">
									Ver eventos
								</p>
								<p class="text-muted-foreground text-xs">Descubre próximos talleres</p>
							</div>
						</a>

						<a
							href="/blog"
							class="group flex items-start gap-4 rounded-xl border border-gray-100 bg-[#FAF7F5] p-4 transition-all hover:border-[#B85440] hover:shadow-md"
						>
							<div class="rounded-lg bg-white p-2.5 shadow-sm">
								<svg
									class="h-5 w-5 text-[#B85440]"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
									></path>
								</svg>
							</div>
							<div>
								<p class="text-primary mb-1 text-sm font-semibold group-hover:text-[#B85440]">
									Ver blog
								</p>
								<p class="text-muted-foreground text-xs">Lee artículos inspiradores</p>
							</div>
						</a>

						<a
							href="/contacto"
							class="group flex items-start gap-4 rounded-xl border border-gray-100 bg-[#FAF7F5] p-4 transition-all hover:border-[#2D3E2F] hover:shadow-md"
						>
							<div class="rounded-lg bg-white p-2.5 shadow-sm">
								<svg
									class="h-5 w-5 text-[#2D3E2F]"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"
									></path>
								</svg>
							</div>
							<div>
								<p class="text-primary mb-1 text-sm font-semibold group-hover:text-[#2D3E2F]">
									Contacto
								</p>
								<p class="text-muted-foreground text-xs">Habla con nosotras</p>
							</div>
						</a>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>

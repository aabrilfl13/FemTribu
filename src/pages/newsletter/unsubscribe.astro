---
import EmailIcon from "@/assets/iconos/email.svg"
import Button from "@/components/ui/Button.astro"
import Input from "@/components/ui/Input.astro"
import Layout from "@/layouts/Layout.astro"
---

<Layout
	title="Cancelar Suscripción - FemTribu"
	description="Cancela tu suscripción a nuestra newsletter."
	navScrolled={true}
	noindex={true}
>
	<main id="main-content" class="to-sage/5 min-h-screen bg-gradient-to-b from-white">
		<section class="relative overflow-hidden py-20 lg:py-32">
			{/* Decorative elements */}
			<div
				class="bg-coral/10 absolute right-0 bottom-0 h-96 w-96 translate-x-1/3 translate-y-1/3 rounded-full blur-3xl"
			>
			</div>
			<div
				class="animate-pulse-soft bg-coral-light/40 absolute top-1/2 left-1/4 h-4 w-4 rounded-full"
			>
			</div>
			<div
				class="animate-pulse-soft bg-sage/40 absolute top-1/3 right-1/4 h-3 w-3 rounded-full"
				style={{ animationDelay: "1s" }}
			>
			</div>

			<div class="relative z-10 container mx-auto px-4">
				<div class="mx-auto max-w-2xl text-center">
					{/* Icon */}
					<div
						class="animate-pulse-soft bg-coral/20 mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full"
					>
						<EmailIcon class="text-coral h-8 w-8" />
					</div>

					{/* Heading */}
					<h1 class="font-display text-sage mb-4 text-4xl font-bold lg:text-5xl">
						Cancelar Suscripción
					</h1>

					<p class="text-sage/80 mb-8 text-lg">
						Sentimos que te vayas. Si deseas cancelar tu suscripción a nuestra newsletter, introduce
						tu email a continuación.
					</p>

					{/* Unsubscribe Form */}
					<form id="unsubscribe-form" class="mx-auto max-w-md space-y-4" data-unsubscribe-form>
						<div class="relative">
							<Input
								type="email"
								name="email"
								id="email"
								placeholder="tu@email.com"
								required
								class="w-full"
							/>
						</div>

						<Button type="submit" variant="hero" class="w-full" data-unsubscribe-button>
							Cancelar Suscripción
						</Button>

						{/* Status messages */}
						<div id="unsubscribe-message" class="mt-3 hidden rounded-lg px-4 py-2 text-sm"></div>
					</form>

					{/* Back to home */}
					<div class="mt-8">
						<a
							href="/"
							class="text-sage hover:text-coral inline-flex items-center gap-2 text-sm transition-colors"
						>
							<svg
								class="h-4 w-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
							</svg>
							Volver a la página principal
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	const form = document.querySelector("[data-unsubscribe-form]") as HTMLFormElement
	const button = document.querySelector("[data-unsubscribe-button]") as HTMLButtonElement
	const messageDiv = document.getElementById("unsubscribe-message") as HTMLDivElement
	const emailInput = document.getElementById("email") as HTMLInputElement

	if (form && button && messageDiv && emailInput) {
		form.addEventListener("submit", async (e) => {
			e.preventDefault()

			const email = emailInput.value.trim()

			if (!email) {
				showMessage("Por favor, introduce tu email.", "error")
				return
			}

			// Disable button and show loading state
			button.disabled = true
			const originalText = button.textContent
			button.textContent = "Procesando..."

			try {
				const response = await fetch("/api/newsletter/unsubscribe", {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
					},
					body: JSON.stringify({ email }),
				})

				const data = await response.json()

				if (data.success) {
					showMessage(
						data.message || "Te has dado de baja correctamente. Sentimos que te vayas.",
						"success"
					)
					form.reset()
				} else {
					showMessage(
						data.message || "Error al procesar tu solicitud. Por favor, intenta de nuevo.",
						"error"
					)
				}
			} catch (error) {
				console.error("Unsubscribe error:", error)
				showMessage(
					"Error al procesar tu solicitud. Por favor, intenta de nuevo más tarde.",
					"error"
				)
			} finally {
				button.disabled = false
				button.textContent = originalText
			}
		})
	}

	function showMessage(message: string, type: "success" | "error") {
		if (!messageDiv) return

		messageDiv.textContent = message
		messageDiv.className = `mt-4 text-sm ${
			type === "success" ? "text-green-700" : "text-red-700"
		} px-4 py-2 rounded-lg`
		messageDiv.classList.remove("hidden")

		// Auto-hide error messages after 5 seconds
		if (type === "error") {
			setTimeout(() => {
				messageDiv.classList.add("hidden")
			}, 5000)
		}
	}

	// Check if email is provided in URL query parameter
	const urlParams = new URLSearchParams(window.location.search)
	const emailParam = urlParams.get("email")
	if (emailParam && emailInput) {
		emailInput.value = emailParam
	}
</script>

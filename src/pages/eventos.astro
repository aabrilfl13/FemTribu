---
import CalendarIcon from "@/assets/iconos/calendar.svg"
import EventCalendar from "@/components/EventCalendar.astro"
import BreadcrumbSchema from "@/components/schema/BreadcrumbSchema.astro"
import EventSchema from "@/components/schema/EventSchema.astro"
import Button from "@/components/ui/Button.astro"
import Layout from "@/layouts/Layout.astro"

export const prerender = true

const upcomingEvents = [
	{
		id: 1,
		title: "No soy yo... es la menopausia",
		date: "14 Enero 2026",
		dateISO: "2026-01-14",
		time: "19:00 - 20:00",
		startTime: "19:00:00",
		endTime: "20:00:00",
		type: "Webinar",
		description:
			"Un webinar gratuito para mujeres que sienten que su cuerpo ha cambiado y nadie les explicó por qué.",
		spots: "Ilimitado",
		price: "Gratuito",
		color: "from-terracotta/20 to-terracotta/5",
		accent: "terracotta",
		route: "https://femmtribu.my.canva.site/",
		image: "/images/decoratives/ilustracion-negro_08.svg",
	},
	{
		id: 2,
		title: "Club de Lectura FEMM Online",
		date: "26 Marzo 2026",
		dateISO: "2026-03-26",
		time: "19:00",
		startTime: "19:00:00",
		endTime: "21:00:00",
		type: "Online",
		description:
			"Club de Lectura FEMM es un espacio para mujeres que quieren profundizar en su salud, su cuerpo y su historia a través de los libros. En esta edición leeremos 'El sexo de las madres' de Sonia Encinas.",
		spots: "Ilimitado",
		price: "Gratuito",
		color: "from-sage/20 to-sage/5",
		accent: "sage",
		route: "/eventos/club-lectura/club-lectura-marzo-2026",
		image: "/images/decoratives/ilustracion-negro_08.svg",
		facilitators: [{ name: "María Belenguer", image: "/images/about-me/mery-portait.webp" }],
	},
	{
		id: 3,
		title: "The Pelvic Glow Experience",
		date: "27 Marzo 2026",
		dateISO: "2026-03-27",
		time: "18:00",
		startTime: "18:00:00",
		endTime: "21:00:00",
		type: "Presencial · Valencia",
		description:
			"Un encuentro pensado para reconectar con tu cuerpo y aprender a cuidar tu salud pélvica desde una mirada cercana y práctica. Combinaremos una charla de fisiosexología y suelo pélvico con Paula Tejedo, merienda juntas y cerraremos con una clase de barre para integrar todo lo aprendido.",
		spots: 15,
		price: "30.25€",
		color: "from-cream/40 to-coral-light/10",
		accent: "cream-light",
		route: "/eventos/pelvic-glow-experience-marzo-2026",
		image: "/images/events/maria-exercise.webp",
		location: "Habitat, Valencia",
		locationAddress: "C/ d'Almassora, 44, Bajo Izquierda, La Zaidía, 46010 València, Valencia",
		facilitators: [
			{ name: "Paula Tejedo", image: "/images/about-me/paula-tejedo.webp" },
			{ name: "María Belenguer", image: "/images/about-me/mery-portait.webp" },
		],
	},
	{
		id: 4,
		title: "Taller de Ciclo Menstrual y Entrenamiento + Clase de Barre",
		date: "18 Abril 2026",
		dateISO: "2026-04-18",
		time: "10:30",
		startTime: "10:30:00",
		endTime: "13:00:00",
		type: "Presencial · Valencia",
		description:
			"Exploraremos cómo funciona el ciclo menstrual, qué ocurre en cada una de sus fases y cómo adaptar el ejercicio a los cambios hormonales para entrenar con más energía, respeto y bienestar. Después del taller disfrutaremos de un almuerzo juntas y cerraremos la mañana con una clase de barre.",
		spots: 8,
		price: "45€",
		color: "from-terracotta/20 to-cream/30",
		accent: "terracotta",
		route: "/eventos/taller-ciclo-menstrual-entrenamiento-abril-2026",
		image: "/images/events/maria-exercise.webp",
		location: "The Sanctuary | Holistic Fitness Studio",
		locationAddress: "Carrer de Martí, 17, L'Eixample, 46005 València, Valencia",
		facilitators: [{ name: "María Belenguer", image: "/images/about-me/mery-portait.webp" }],
	},
	{
		id: 5,
		title: "Curso de Preparación al Parto",
		date: "17 Abril 2026",
		dateISO: "2026-04-17",
		lastDateISO: "2026-05-15",
		sessions: [
			{ date: "17 Abril 2026", dateISO: "2026-04-17" },
			{ date: "24 Abril 2026", dateISO: "2026-04-24" },
			{ date: "8 Mayo 2026", dateISO: "2026-05-08" },
			{ date: "15 Mayo 2026", dateISO: "2026-05-15" },
		],
		time: "A confirmar",
		startTime: "10:00:00",
		endTime: "12:30:00",
		type: "Presencial · Valencia",
		description:
			"Un espacio para acompañarte con calma, información y confianza en el camino hacia el nacimiento de tu bebé. Cuatro sesiones semanales de 2–3 horas para comprender el parto, el postparto y el inicio de la lactancia, con dinámicas en pareja, meditaciones y espacio de comunidad.",
		spots: 8,
		price: "A consultar",
		color: "from-sage/20 to-cream/30",
		accent: "sage",
		route: "/eventos/curso-preparacion-parto-abril-mayo-2026",
		image: "/images/about-me/mery-portait.webp",
		location: "Valencia",
		facilitators: [{ name: "María Belenguer", image: "/images/about-me/mery-portait.webp" }],
	},
]

const seoData = {
	title: "Talleres y Eventos en Valencia y Online 2026 | Femm tribu",
	description:
		"Descubre nuestros talleres presenciales en Valencia y eventos online sobre salud femenina, menopausia, suelo pélvico y bienestar. Plazas limitadas. ¡Reserva tu plaza!",
}

// Function to check if event is past
// For multi-day events, uses lastDateISO so the event stays visible until the final session
const isEventPast = (event: { dateISO: string; lastDateISO?: string }) => {
	const isoToCheck = event.lastDateISO ?? event.dateISO
	const d = new Date(isoToCheck)
	d.setHours(0, 0, 0, 0)
	const today = new Date()
	today.setHours(0, 0, 0, 0)
	return d < today
}

// Separate active and past events
const activeEvents = upcomingEvents.filter((event) => !isEventPast(event))

const monthNamesES = [
	"Enero",
	"Febrero",
	"Marzo",
	"Abril",
	"Mayo",
	"Junio",
	"Julio",
	"Agosto",
	"Septiembre",
	"Octubre",
	"Noviembre",
	"Diciembre",
]

// Sort events by date for proper month grouping
const sortedEvents = [...upcomingEvents].sort(
	(a, b) => new Date(a.dateISO).getTime() - new Date(b.dateISO).getTime()
)
---

<Layout {...seoData} navScrolled={true}>
	<BreadcrumbSchema items={[{ name: "Eventos" }]} />
	{/* Structured Data for Events */}
	{
		activeEvents.map((event) => (
			<EventSchema
				title={event.title}
				description={event.description}
				date={event.date}
				dateISO={event.dateISO}
				time={event.time}
				startTime={event.startTime}
				endTime={event.endTime}
				type={event.type}
				location={event.location}
				locationAddress={event.locationAddress}
				price={event.price}
				spots={event.spots}
				image={event.image}
				facilitators={event.facilitators}
			/>
		))
	}

	{/* Hero Section */}
	<main id="main-content" class="pt-21">
		<section class="container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="relative z-10 container mx-auto max-w-4xl text-center">
				<div
					class="bg-sage/20 mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
				>
					<CalendarIcon class="text-forest h-4 w-4" />
					<span class="font-body text-forest text-sm">Próximos encuentros</span>
				</div>

				<h1
					class="font-display text-forest mb-6 text-4xl md:text-5xl lg:text-6xl"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.2s"
				>
					Talleres y <span class="text-terracotta">Eventos</span> en Valencia y Online
				</h1>

				<p
					class="font-body text-forest/70 mx-auto max-w-2xl text-lg"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.3s"
				>
					Únete a nuestros encuentros, webinars y talleres diseñados para acompañarte en cada etapa
					de tu camino hacia el bienestar femenino.
				</p>
			</div>
		</section>

		{/* Calendar Section */}
		<section class="mb-16 lg:mb-24">
			<div class="container mx-auto px-4 lg:px-8">
				<div
					class="border-sage/20 bg-cream/50 rounded-3xl border p-4 md:p-6"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.4s"
				>
					<EventCalendar
						events={upcomingEvents.flatMap((e) =>
							e.sessions && e.sessions.length > 0
								? e.sessions.map((s, i) => ({
										id: e.id * 100 + i,
										title: e.title,
										date: s.date,
										dateISO: s.dateISO,
										time: e.time,
										type: e.type,
										route: e.route,
										accent: e.accent,
									}))
								: [
										{
											id: e.id,
											title: e.title,
											date: e.date,
											dateISO: e.dateISO,
											time: e.time,
											type: e.type,
											route: e.route,
											accent: e.accent,
										},
									]
						)}
					/>
				</div>
			</div>
		</section>

		{/* Events Grid with Tabs */}
		<section class="pb-24 lg:pb-32" id="events-grid">
			<div class="container mx-auto px-4 lg:px-8">
				{/* Tab buttons */}
				<div
					class="bg-sage/10 mb-8 flex gap-1 rounded-xl p-1"
					role="tablist"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
				>
					<button
						type="button"
						id="tab-upcoming"
						role="tab"
						aria-selected="true"
						aria-controls="tab-panel-upcoming"
						class="font-body bg-cream text-forest flex-1 cursor-pointer rounded-lg px-4 py-2.5 text-sm font-medium shadow-sm transition-all"
					>
						Próximos
						<span
							id="tab-upcoming-count"
							class="bg-sage/20 text-forest/70 ml-1.5 inline-flex h-5 min-w-5 items-center justify-center rounded-full px-1.5 text-xs"
						></span>
					</button>
					<button
						type="button"
						id="tab-past"
						role="tab"
						aria-selected="false"
						aria-controls="tab-panel-past"
						class="font-body text-forest/60 hover:text-forest/80 flex-1 cursor-pointer rounded-lg px-4 py-2.5 text-sm font-medium transition-all"
					>
						Realizados
						<span
							id="tab-past-count"
							class="bg-sage/10 text-forest/50 ml-1.5 inline-flex h-5 min-w-5 items-center justify-center rounded-full px-1.5 text-xs"
						></span>
					</button>
				</div>

				{/* Section title - next 3 months */}
				<h2 id="events-month-title" class="font-display text-forest mb-6 text-xl md:text-2xl"></h2>

				{/* Pre-rendered event cards with data attributes, grouped by month */}
				<div id="events-cards-container">
					{
						(() => {
							let lastMonthKey = ""
							return sortedEvents.map((event, index) => {
								const eventDate = new Date(event.dateISO)
								const isPast = isEventPast(event)
								const monthKey = `${eventDate.getFullYear()}-${eventDate.getMonth()}`
								const showHeader = monthKey !== lastMonthKey
								lastMonthKey = monthKey
								return (
									<>
										{showHeader && (
											<div
												class={`month-group-header border-sage/20 mt-8 mb-4 flex items-center gap-3 border-b pb-3 first:mt-0${isPast ? "hidden" : ""}`}
												data-group-month={eventDate.getMonth()}
												data-group-year={eventDate.getFullYear()}
												data-group-date-iso={event.dateISO}
												data-group-past={isPast ? "true" : "false"}
											>
												<div class="bg-sage/20 flex h-10 w-10 items-center justify-center rounded-xl">
													<svg
														class="text-forest h-5 w-5"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="2"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
														<line x1="16" y1="2" x2="16" y2="6" />
														<line x1="8" y1="2" x2="8" y2="6" />
														<line x1="3" y1="10" x2="21" y2="10" />
													</svg>
												</div>
												<h3 class="font-display text-forest text-lg md:text-xl">
													{monthNamesES[eventDate.getMonth()]} {eventDate.getFullYear()}
												</h3>
											</div>
										)}
										<div
											class={`event-card bg-gradient-to-r ${event.color} border-sage/20 relative mb-6 overflow-hidden rounded-3xl border p-6 transition-all duration-300 hover:shadow-lg md:p-8${isPast ? "hidden" : ""}`}
											data-event-month={eventDate.getMonth()}
											data-event-year={eventDate.getFullYear()}
											data-event-date-iso={event.dateISO}
											data-event-past={isPast ? "true" : "false"}
											data-event-title={event.title}
											data-animate="animate-slide-in-left"
											data-animate-duration="1s"
											data-animate-delay={`${index * 100}ms`}
										>
											{isPast && (
												<div
													class="absolute inset-0 z-20 flex items-center justify-center rounded-3xl"
													style="background: rgba(255, 255, 255, 0.3); backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px); isolation: isolate;"
												>
													<div class="bg-forest text-cream rotate-[-5deg] transform rounded-2xl px-8 py-4 shadow-lg">
														<span class="font-display text-3xl md:text-4xl">Realizado</span>
													</div>
												</div>
											)}

											{event.image && (
												<div class="absolute inset-0 -z-10">
													<div
														class={`bg-${event.accent} h-full w-full opacity-20`}
														style={`-webkit-mask: url(${event.image}) center/cover; mask: url(${event.image}) center/cover;`}
													/>
												</div>
											)}
											<div class="relative z-10 flex flex-col gap-6 lg:flex-row lg:items-center">
												{/* Date Badge */}
												<div class="flex-shrink-0">
													<div class="bg-cream w-24 rounded-2xl p-4 text-center shadow-sm">
														<span class="font-display text-forest block text-2xl">
															{event.date.split(" ")[0]}
														</span>
														<span class="font-body text-forest/70 block text-sm">
															{event.date.split(" ")[1]}
														</span>
														{event.sessions && event.sessions.length > 1 && (
															<span class="font-body text-terracotta mt-1 block text-xs">
																{event.sessions.length} sesiones
															</span>
														)}
													</div>
												</div>

												{/* Event Info */}
												<div class="flex-grow space-y-3">
													<div class="flex flex-wrap items-center gap-3">
														<span
															class="font-body text-forest rounded-full px-3 py-1 text-xs"
															style={`background-color: color-mix(in srgb, ${event.type.includes("Online") ? "var(--color-sage)" : "var(--color-terracotta)"} 30%, white);`}
														>
															{event.type}
														</span>
														<span class="font-body text-forest/70 flex items-center gap-1 text-sm">
															<svg
																class="h-3 w-3"
																viewBox="0 0 24 24"
																fill="none"
																stroke="currentColor"
																stroke-width="2"
																stroke-linecap="round"
																stroke-linejoin="round"
															>
																<circle cx="12" cy="12" r="10" />
																<polyline points="12 6 12 12 16 14" />
															</svg>
															{event.time}
														</span>
													</div>

													<h2 class="font-display text-forest text-2xl md:text-3xl">
														{event.title}
													</h2>

													<p class="font-body text-forest/70 text-sm md:text-base">
														{event.description}
													</p>

													<div class="text-forest/70 flex items-center gap-4 text-sm">
														<span class="flex items-center gap-1">
															<svg
																class="h-4 w-4"
																viewBox="0 0 24 24"
																fill="none"
																stroke="currentColor"
																stroke-width="2"
																stroke-linecap="round"
																stroke-linejoin="round"
															>
																<circle cx="9" cy="7" r="4" />
																<path d="M3 21v-2c0-2.2 1.8-4 4-4h4c2.2 0 4 1.8 4 4v2" />
																<circle cx="16" cy="7" r="3" />
																<path d="M22 21v-2c0-1.7-1.1-3.1-2.6-3.7" />
															</svg>
															{event.spots}
															{typeof event.spots === "number" ? " plazas" : ""}
														</span>
													</div>

													{/* Facilitators thumbnails */}
													{event.facilitators && event.facilitators.length > 0 && (
														<div class="mt-4 flex items-center gap-2">
															<div class="flex -space-x-2">
																{event.facilitators.map((facilitator) => (
																	<div
																		class="bg-cream relative h-8 w-8 overflow-hidden rounded-full border-1 border-white"
																		title={facilitator.name}
																	>
																		<img
																			src={facilitator.image}
																			alt={facilitator.name}
																			class="h-full w-full object-cover"
																			loading="lazy"
																		/>
																	</div>
																))}
															</div>
															<span class="text-forest/70 font-body text-xs">
																{event.facilitators.map((f) => f.name).join(" y ")}
															</span>
														</div>
													)}
												</div>

												{/* Price & CTA */}
												<div class="flex flex-shrink-0 flex-col items-center gap-3">
													<span class="font-display text-forest text-2xl">{event.price}</span>
													<Button
														variant="hero"
														size="lg"
														class="w-full lg:w-auto"
														href={event.route}
														rel="noopener noreferrer"
													>
														Reservar plaza
														<svg
															class="ml-2 h-4 w-4"
															viewBox="0 0 24 24"
															fill="none"
															stroke="currentColor"
															stroke-width="2"
															stroke-linecap="round"
															stroke-linejoin="round"
														>
															<line x1="5" y1="12" x2="19" y2="12" />
															<polyline points="12 5 19 12 12 19" />
														</svg>
													</Button>
												</div>
											</div>
										</div>
									</>
								)
							})
						})()
					}
				</div>

				{/* Empty states (hidden by default, shown via JS) */}
				<div id="empty-upcoming" class="hidden py-12 text-center">
					<p class="font-body text-forest/40 text-lg" id="empty-upcoming-text"></p>
				</div>
				<div id="empty-past" class="hidden py-12 text-center">
					<p class="font-body text-forest/40 text-lg" id="empty-past-text"></p>
				</div>

				{/* Empty state hint */}
				<div class="mt-16 text-center">
					<p
						class="text-forest/70 font-body mb-4"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
						data-animate-delay="0.1s"
					>
						¿Quieres ser la primera en enterarte de nuevos eventos?
					</p>
					<Button
						id="newsletter-modal-triggerr"
						variant="outline"
						size="lg"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
						data-animate-delay="0.2s"
					>
						Únete a la newsletter
					</Button>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	const monthNames = [
		"Enero",
		"Febrero",
		"Marzo",
		"Abril",
		"Mayo",
		"Junio",
		"Julio",
		"Agosto",
		"Septiembre",
		"Octubre",
		"Noviembre",
		"Diciembre",
	]

	function initEventsTabs() {
		const today = new Date()
		today.setHours(0, 0, 0, 0)

		// Calculate 3 months from now
		const threeMonthsLater = new Date(today.getFullYear(), today.getMonth() + 3 + 1, 0)

		let activeTab: "upcoming" | "past" = "upcoming"

		const tabUpcomingBtn = document.getElementById("tab-upcoming")!
		const tabPastBtn = document.getElementById("tab-past")!
		const tabUpcomingCount = document.getElementById("tab-upcoming-count")!
		const tabPastCount = document.getElementById("tab-past-count")!
		const monthTitle = document.getElementById("events-month-title")!
		const cards = document.querySelectorAll<HTMLElement>(".event-card")
		const monthHeaders = document.querySelectorAll<HTMLElement>(".month-group-header")
		const emptyUpcoming = document.getElementById("empty-upcoming")!
		const emptyPast = document.getElementById("empty-past")!
		const emptyUpcomingText = document.getElementById("empty-upcoming-text")!
		const emptyPastText = document.getElementById("empty-past-text")!

		const TAB_ACTIVE =
			"font-body bg-cream text-forest flex-1 cursor-pointer rounded-lg px-4 py-2.5 text-sm font-medium shadow-sm transition-all"
		const TAB_INACTIVE =
			"font-body text-forest/60 hover:text-forest/80 flex-1 cursor-pointer rounded-lg px-4 py-2.5 text-sm font-medium transition-all"

		function getEndMonthName() {
			return monthNames[threeMonthsLater.getMonth()]
		}

		function setActiveTab(tab: "upcoming" | "past") {
			activeTab = tab
			tabUpcomingBtn.className = tab === "upcoming" ? TAB_ACTIVE : TAB_INACTIVE
			tabUpcomingBtn.setAttribute("aria-selected", String(tab === "upcoming"))
			tabPastBtn.className = tab === "past" ? TAB_ACTIVE : TAB_INACTIVE
			tabPastBtn.setAttribute("aria-selected", String(tab === "past"))
			renderCards()
		}

		function renderCards() {
			let upcomingCount = 0
			let pastCount = 0

			// Track which month groups have visible cards
			const visibleMonthGroups = new Set<string>()

			cards.forEach((card) => {
				const cardDateISO = card.dataset.eventDateIso!
				const cardDate = new Date(cardDateISO)
				cardDate.setHours(0, 0, 0, 0)

				// Determine past/future at runtime, not build time
				const cardIsPast = cardDate < today
				const inRange = cardDate >= today && cardDate <= threeMonthsLater

				if (!cardIsPast && inRange) upcomingCount++
				if (cardIsPast) pastCount++

				const showForTab = activeTab === "upcoming" ? inRange : cardIsPast
				card.classList.toggle("hidden", !showForTab)

				if (showForTab) {
					visibleMonthGroups.add(`${cardDate.getFullYear()}-${cardDate.getMonth()}`)
				}
			})

			// Show/hide month group headers
			monthHeaders.forEach((header) => {
				const groupMonth = parseInt(header.dataset.groupMonth!)
				const groupYear = parseInt(header.dataset.groupYear!)
				const key = `${groupYear}-${groupMonth}`
				header.classList.toggle("hidden", !visibleMonthGroups.has(key))
			})

			tabUpcomingCount.textContent = upcomingCount.toString()
			tabPastCount.textContent = pastCount.toString()
			monthTitle.textContent =
				activeTab === "upcoming"
					? `Eventos hasta ${getEndMonthName()} ${threeMonthsLater.getFullYear()}`
					: "Eventos realizados"

			emptyUpcomingText.textContent = "No hay eventos próximos en los próximos 3 meses"
			emptyPastText.textContent = "No hay eventos realizados"
			emptyUpcoming.classList.toggle("hidden", !(activeTab === "upcoming" && upcomingCount === 0))
			emptyPast.classList.toggle("hidden", !(activeTab === "past" && pastCount === 0))
		}

		tabUpcomingBtn.addEventListener("click", () => setActiveTab("upcoming"))
		tabPastBtn.addEventListener("click", () => setActiveTab("past"))

		renderCards()

		// Newsletter modal
		document.getElementById("newsletter-modal-triggerr")?.addEventListener("click", () => {
			window.dispatchEvent(new CustomEvent("open-newsletter-modal"))
		})
	}

	initEventsTabs()
	document.addEventListener("astro:after-swap", initEventsTabs)

	// GA4 event tracking for "Reservar plaza" clicks
	document.querySelectorAll<HTMLElement>(".event-card").forEach((card) => {
		const link = card.querySelector("a[href]")
		if (!link) return
		link.addEventListener("click", () => {
			const title = card.dataset.eventTitle
			if (window.gtag) {
				window.gtag("event", "event_signup_click", {
					event_name: title,
					page: window.location.pathname,
				})
			}
		})
	})
</script>

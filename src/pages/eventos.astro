---
import CalendarIcon from "@/assets/iconos/calendar.svg"
import Button from "@/components/ui/Button.astro"
import Layout from "@/layouts/Layout.astro"

const upcomingEvents = [
	{
		id: 1,
		title: "No soy yo... es la menopausia",
		date: "14 Enero 2026",
		time: "19:00 - 20:00",
		type: "Webinar",
		description:
			"Un webinar gratuito para mujeres que sienten que su cuerpo ha cambiado y nadie les explicó por qué.",
		spots: "Ilimitado",
		price: "Gratuito",
		color: "from-terracotta/20 to-terracotta/5",
		accent: "terracotta",
		route: "https://femmtribu.my.canva.site/",
		image: "/images/decoratives/ilustracion-negro_08.svg",
	},
]

const seoData = {
	title: "Eventos y Talleres | FemTribu",
	description:
		"Únete a nuestros encuentros, webinars y talleres diseñados para acompañarte en cada etapa de tu camino hacia el bienestar femenino.",
	noindex: true,
}
---

<Layout {...seoData} navScrolled={true}>
	{/* Hero Section */}
	<main class="pt-21">
		<section class="container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="relative z-10 container mx-auto max-w-4xl text-center">
				<div class="bg-sage/20 mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2">
					<CalendarIcon class="text-forest h-4 w-4" />
					<span class="font-body text-forest text-sm">Próximos encuentros</span>
				</div>

				<h1 class="font-display text-forest mb-6 text-4xl md:text-5xl lg:text-6xl">
					Eventos y <span class="text-terracotta">Talleres</span>
				</h1>

				<p class="font-body text-forest/70 mx-auto max-w-2xl text-lg">
					Únete a nuestros encuentros, webinars y talleres diseñados para acompañarte en cada etapa
					de tu camino hacia el bienestar femenino.
				</p>
			</div>
		</section>

		{/* Events Grid */}
		<section class="pb-24 lg:pb-32">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="space-y-6">
					{
						upcomingEvents.map((event, index) => (
							<div
								class={`bg-gradient-to-r ${event.color} border-sage/20 relative overflow-hidden rounded-3xl border p-6 transition-all duration-300 hover:shadow-lg md:p-8`}
								data-animate="animate-slide-in-right"
								data-animate-duration="1s"
								data-animate-delay={`${index * 100}ms`}
							>
								{event.image && (
									<div class="absolute inset-0 -z-10">
										<div
											class={`bg-${event.accent} h-full w-full opacity-20`}
											style={`-webkit-mask: url(${event.image}) center/cover; mask: url(${event.image}) center/cover;`}
										/>
									</div>
								)}
								<div class="relative z-10 flex flex-col gap-6 lg:flex-row lg:items-center">
									{/* Date Badge */}
									<div class="flex-shrink-0">
										<div class="bg-cream w-24 rounded-2xl p-4 text-center shadow-sm">
											<span class="font-display text-forest block text-2xl">
												{event.date.split(" ")[0]}
											</span>
											<span class="font-body text-forest/60 block text-sm">
												{event.date.split(" ")[1]}
											</span>
										</div>
									</div>

									{/* Event Info */}
									<div class="flex-grow space-y-3">
										<div class="flex flex-wrap items-center gap-3">
											<span
												class="font-body text-forest rounded-full px-3 py-1 text-xs"
												style={`background-color: color-mix(in srgb, ${event.type.includes("Online") ? "var(--color-sage)" : "var(--color-terracotta)"} 30%, white);`}
											>
												{event.type}
											</span>
											<span class="font-body text-forest/60 flex items-center gap-1 text-sm">
												<svg
													class="h-3 w-3"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<circle cx="12" cy="12" r="10" />
													<polyline points="12 6 12 12 16 14" />
												</svg>
												{event.time}
											</span>
										</div>

										<h2 class="font-display text-forest text-2xl md:text-3xl">{event.title}</h2>

										<p class="font-body text-forest/70 text-sm md:text-base">{event.description}</p>

										<div class="text-forest/60 flex items-center gap-4 text-sm">
											<span class="flex items-center gap-1">
												<svg
													class="h-4 w-4"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<circle cx="9" cy="7" r="4" />
													<path d="M3 21v-2c0-2.2 1.8-4 4-4h4c2.2 0 4 1.8 4 4v2" />
													<circle cx="16" cy="7" r="3" />
													<path d="M22 21v-2c0-1.7-1.1-3.1-2.6-3.7" />
												</svg>
												{event.spots}
												{typeof event.spots === "number" ? " plazas" : ""}
											</span>
										</div>
									</div>

									{/* Price & CTA */}
									<div class="flex flex-shrink-0 flex-col items-center gap-3">
										<span class="font-display text-forest text-2xl">{event.price}</span>
										<Button
											variant="hero"
											size="lg"
											class="w-full lg:w-auto"
											href={event.route}
											rel="noopener noreferrer"
										>
											Reservar plaza
											<svg
												class="ml-2 h-4 w-4"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<line x1="5" y1="12" x2="19" y2="12" />
												<polyline points="12 5 19 12 12 19" />
											</svg>
										</Button>
									</div>
								</div>
							</div>
						))
					}
				</div>

				{/* Empty state hint */}
				<div class="mt-16 text-center">
					<p class="text-forest/60 font-body mb-4">
						¿Quieres ser la primera en enterarte de nuevos eventos?
					</p>
					<Button id="newsletter-modal-triggerr" variant="outline" size="lg">
						Únete a la newsletter
					</Button>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	const newsletterModalTrigger = document.getElementById("newsletter-modal-triggerr")

	newsletterModalTrigger?.addEventListener("click", () => {
		window.dispatchEvent(new CustomEvent("open-newsletter-modal"))
	})
</script>

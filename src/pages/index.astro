---
import FAQ from "@/components/FAQ.astro"
import FAQSchema from "@/components/schema/FAQSchema.astro"
import AboutCompany from "@/components/sections/AboutCompany.astro"
import BrandsSlider from "@/components/sections/BrandsSlider.astro"
import NewsletterSection from "@/components/sections/NewsletterSection.astro"
import Servicies from "@/components/sections/Services.astro"
import Welcome from "@/components/sections/Welcome.astro"
import { HOME_FAQS } from "@/data/faqs"
import Layout from "@/layouts/Layout.astro"

export const prerender = true

const seoData = {
	title: "Matrona Valencia y Online | Salud Integral Femenina | Femm tribu",
	description:
		"En Femm tribu, nos dedicamos a brindar apoyo integral a la salud femenina a través de servicios personalizados y una comunidad solidaria.",
}
---

<Layout navScrolled={false} {...seoData}>
	<main id="main-content">
		<Welcome />
		<AboutCompany />
		<section
			class="from-background to-coral-light/10 flex items-center justify-center bg-gradient-to-b p-0 px-0"
			data-animate="animate-fade-up"
			data-animate-duration="1s"
		>
			<img
				class="h-10 w-100"
				src="/images/decoratives/ilustracion-negro_36.svg"
				alt=""
				loading="lazy"
			/>
		</section>
		<Servicies />
		<section
			class="from-coral-light/10 to-background/10 items-center justify-center bg-gradient-to-b"
			data-animate="animate-fade-up"
			data-animate-duration="1s"
		>
			<BrandsSlider />
		</section>
		<section
			class="to-background from-to-background/10 flex items-center justify-center bg-gradient-to-b p-0 px-0"
			data-animate="animate-fade-up"
			data-animate-duration="1s"
		>
			<img
				class="h-10 w-100"
				src="/images/decoratives/ilustracion-negro_36.svg"
				alt=""
				loading="lazy"
			/>
		</section>
		<NewsletterSection />
		<section id="faq" class="relative overflow-hidden py-10 lg:py-18">
			<FAQ
				faqs={HOME_FAQS}
				title="Preguntas frecuentes"
				subtitle="Resolvemos tus dudas más habituales sobre nuestros servicios de matrona."
			/>
			<FAQSchema faqs={HOME_FAQS} />
		</section>
	</main>
</Layout>

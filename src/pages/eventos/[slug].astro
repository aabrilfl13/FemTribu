---
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import CardContent from "@/components/ui/CardContent.astro"
import CardDescription from "@/components/ui/CardDescription.astro"
import CardHeader from "@/components/ui/CardHeader.astro"
import CardTitle from "@/components/ui/CardTitle.astro"
import EventSchema from "@/components/schema/EventSchema.astro"
import Layout from "@/layouts/Layout.astro"
import {
	fetchEvents,
	generateCalendarLink,
	generateShareLinks,
	generateWhatsAppReservationLink,
	type Event,
} from "@/services/events-service"

export const prerender = true

export async function getStaticPaths() {
	// Fetch events from service (mock data or API)
	const events = await fetchEvents()

	return events.map((event) => ({
		params: { slug: event.slug },
		props: { event },
	}))
}

interface Props {
	event: Event
}

const { event } = Astro.props

const eventDetails = {
	date: event.date,
	time: event.time,
	type: event.type,
	location: event.location,
	duration: event.duration,
	price: event.price,
	spots: event.spots,
	whatsappLink: generateWhatsAppReservationLink(event, event.whatsappNumber),
	calendarLink: generateCalendarLink(event),
}

const shareLinks = generateShareLinks(event)

const seoData = event.seo
---

<Layout {...seoData} navScrolled={true}>
	{/* Structured Data for Event */}
	<EventSchema
		title={event.title}
		description={event.description}
		date={event.date}
		dateISO={event.dateISO}
		time={event.time}
		startTime={event.startTime}
		endTime={event.endTime}
		type={event.type}
		location={event.location}
		locationAddress={event.locationAddress}
		price={event.price}
		spots={event.spots}
		image={event.image}
		facilitators={event.facilitators}
	/>

	<main class="pt-21">
		{/* Back to events link */}
		<div class="container mx-auto px-4 pt-8 lg:px-8">
			<a
				href="/eventos"
				class="text-forest hover:text-terracotta font-body inline-flex items-center gap-2 text-sm transition-colors"
			>
				<svg
					class="h-4 w-4"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<line x1="19" y1="12" x2="5" y2="12"></line>
					<polyline points="12 19 5 12 12 5"></polyline>
				</svg>
				Volver a eventos
			</a>
		</div>

		{/* Hero Section */}
		<section class="container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="relative z-10 container mx-auto max-w-4xl text-center">
				<div
					class="bg-terracotta/20 mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
				>
					<svg
						class="text-terracotta h-4 w-4"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
						<circle cx="12" cy="10" r="3"></circle>
					</svg>
					<span class="font-body text-terracotta text-sm"
						>{event.date} • {event.time} • {event.location}</span
					>
				</div>

				<h1
					class="font-display text-forest mb-6 text-4xl md:text-5xl lg:text-6xl"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.2s"
				>
					{event.title}
				</h1>

				<p
					class="font-body text-forest/70 mx-auto max-w-2xl text-lg"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.3s"
				>
					{event.subtitle}
				</p>

				<div
					class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.4s"
				>
					<Button
						variant="hero"
						size="lg"
						href={eventDetails.whatsappLink}
						target="_blank"
						rel="noopener noreferrer"
					>
						Reservar mi plaza
						<svg
							class="ml-2 h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<line x1="5" y1="12" x2="19" y2="12"></line>
							<polyline points="12 5 19 12 12 19"></polyline>
						</svg>
					</Button>
					<Button
						variant="outline"
						size="lg"
						href={eventDetails.calendarLink}
						target="_blank"
						rel="noopener noreferrer"
					>
						<svg
							class="mr-2 h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
							<line x1="16" y1="2" x2="16" y2="6"></line>
							<line x1="8" y1="2" x2="8" y2="6"></line>
							<line x1="3" y1="10" x2="21" y2="10"></line>
						</svg>
						Añadir a mi calendario
					</Button>
				</div>

				{/* Share Section */}
				<div
					class="mt-12 flex flex-col items-center gap-4"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.5s"
				>
					<p class="font-body text-forest/60 text-sm">Comparte este evento</p>
					<div class="flex flex-wrap items-center justify-center gap-3">
						<a
							href={shareLinks.whatsapp}
							target="_blank"
							rel="noopener noreferrer"
							class="bg-sage/10 hover:bg-sage/20 text-forest flex h-10 w-10 items-center justify-center rounded-full transition-colors"
							aria-label="Compartir en WhatsApp"
						>
							<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
								<path
									d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
								></path>
							</svg>
						</a>
						<button
							id="copy-link-btn"
							class="bg-sage/10 hover:bg-sage/20 text-forest flex h-10 w-10 items-center justify-center rounded-full transition-colors"
							aria-label="Copiar enlace"
							data-url={shareLinks.copyLink}
						>
							<svg
								class="h-5 w-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
								<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
							</svg>
						</button>
					</div>
				</div>
			</div>
		</section>

		{/* Event Details */}
		<section class="pb-16 lg:pb-24">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="mx-auto max-w-5xl">
					<div
						class="from-terracotta/20 to-terracotta/5 border-terracotta/20 rounded-3xl border bg-gradient-to-r p-8"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
					>
						<div class="grid gap-8 md:grid-cols-2">
							<div class="flex flex-col items-start justify-center gap-8">
								<h2 class="font-display text-forest mb-4 text-2xl md:text-3xl">
									Detalles del evento
								</h2>
								<div class="space-y-3">
									<div class="flex items-center gap-3">
										<div
											class="bg-forest/10 flex h-10 w-10 items-center justify-center rounded-full"
										>
											<svg
												class="text-forest h-5 w-5"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
												<line x1="16" y1="2" x2="16" y2="6"></line>
												<line x1="8" y1="2" x2="8" y2="6"></line>
												<line x1="3" y1="10" x2="21" y2="10"></line>
											</svg>
										</div>
										<div>
											<p class="font-body text-forest/60 text-sm">Fecha</p>
											<p class="font-body text-forest font-medium">{eventDetails.date}</p>
										</div>
									</div>
									<div class="flex items-center gap-3">
										<div
											class="bg-forest/10 flex h-10 w-10 items-center justify-center rounded-full"
										>
											<svg
												class="text-forest h-5 w-5"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<circle cx="12" cy="12" r="10"></circle>
												<polyline points="12 6 12 12 16 14"></polyline>
											</svg>
										</div>
										<div>
											<p class="font-body text-forest/60 text-sm">Hora</p>
											<p class="font-body text-forest font-medium">{eventDetails.time}</p>
										</div>
									</div>
									<div class="flex items-center gap-3">
										<div
											class="bg-forest/10 flex h-10 w-10 items-center justify-center rounded-full"
										>
											<svg
												class="text-forest h-5 w-5"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
												<circle cx="12" cy="10" r="3"></circle>
											</svg>
										</div>
										<div>
											<p class="font-body text-forest/60 text-sm">Ubicación</p>
											<p class="font-body text-forest font-medium">{eventDetails.location}</p>
											{event.locationAddress && (
												<a
													href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(event.locationAddress)}`}
													target="_blank"
													rel="noopener noreferrer"
													class="font-body text-forest/70 hover:text-terracotta text-xs underline decoration-dotted transition-colors"
												>
													{event.locationAddress}
												</a>
											)}
										</div>
									</div>
									<div class="flex items-center gap-3">
										<div
											class="bg-forest/10 flex h-10 w-10 items-center justify-center rounded-full"
										>
											<svg
												class="text-forest h-5 w-5"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<circle cx="9" cy="7" r="4"></circle>
												<path d="M3 21v-2c0-2.2 1.8-4 4-4h4c2.2 0 4 1.8 4 4v2"></path>
												<circle cx="16" cy="7" r="3"></circle>
												<path d="M22 21v-2c0-1.7-1.1-3.1-2.6-3.7"></path>
											</svg>
										</div>
										<div>
											<p class="font-body text-forest/60 text-sm">Plazas</p>
											<p class="font-body text-forest font-medium">
												{eventDetails.spots} disponibles
											</p>
										</div>
									</div>
								</div>
							</div>
							<div class="flex items-center justify-center">
								<div class="text-center">
									<div class="mx-auto w-full max-w-[280px]">
										<img
											src={event.image}
											alt={event.title}
											class="h-auto w-full rounded-lg shadow-xl"
											loading="lazy"
										/>
									</div>
									<div class="bg-terracotta mt-6 rounded-2xl px-6 py-4 shadow-sm">
										<p class="text-cream font-body mb-1 text-sm">Precio</p>
										<p class="text-cream font-display text-3xl">{eventDetails.price}</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* About the event */}
		<section class="pb-16 lg:pb-24">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="mx-auto max-w-5xl">
					<h2
						class="font-display text-forest mb-8 text-center text-3xl md:text-4xl"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
					>
						Sobre el evento
					</h2>
					<div
						class="from-sage/20 to-sage/5 border-sage/20 rounded-3xl border bg-gradient-to-r p-8 md:p-12"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
					>
						<p class="text-forest/80 font-body mb-6 text-lg leading-relaxed">
							{event.description}
						</p>

						{
							event.whatYouWillLearn && (
								<>
									<h3 class="font-display text-forest mb-4 text-xl">¿Qué aprenderás?</h3>
									<ul class="space-y-3">
										{event.whatYouWillLearn.map((item) => (
											<li class="flex items-start gap-3">
												<div class="bg-terracotta/20 mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full">
													<svg
														class="text-terracotta h-3 w-3"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="3"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<polyline points="20 6 9 17 4 12" />
													</svg>
												</div>
												<span class="text-forest/80 font-body text-sm">{item}</span>
											</li>
										))}
									</ul>
								</>
							)
						}
					</div>
				</div>
			</div>
		</section>

		{/* Schedule */}
		{
			event.schedule && (
				<section class="pb-16 lg:pb-24">
					<div class="container mx-auto px-4 lg:px-8">
						<div class="mx-auto max-w-5xl">
							<h2
								class="font-display text-forest mb-12 text-center text-3xl md:text-4xl"
								data-animate="animate-fade-in"
								data-animate-duration="1s"
							>
								Programa
							</h2>

							<div class="space-y-6">
								{event.schedule.map((item, index) => (
									<Card
										class="border-sage/20 hover:border-sage/50 transition-all duration-300 hover:shadow-lg"
										data-animate="animate-fade-in"
										data-animate-duration="1s"
										data-animate-delay={`${index * 100}ms`}
									>
										<CardHeader>
											<div class="flex items-center gap-4">
												<div class="bg-terracotta/20 text-terracotta flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full">
													<svg
														class="h-6 w-6"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="2"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<circle cx="12" cy="12" r="10" />
														<polyline points="12 6 12 12 16 14" />
													</svg>
												</div>
												<div>
													<p class="text-terracotta font-body mb-1 text-sm font-medium">
														{item.time}
													</p>
													<CardTitle class="font-display text-forest text-xl">
														{item.activity}
													</CardTitle>
												</div>
											</div>
										</CardHeader>
										{item.description && (
											<CardContent>
												<CardDescription class="text-forest/70 text-sm leading-relaxed">
													{item.description}
												</CardDescription>
											</CardContent>
										)}
									</Card>
								))}
							</div>
						</div>
					</div>
				</section>
			)
		}

		{/* Facilitators */}
		{
			event.facilitators && (
				<section class="pb-16 lg:pb-24">
					<div class="container mx-auto px-4 lg:px-8">
						<div class="mx-auto max-w-5xl">
							<h2
								class="font-display text-forest mb-12 text-center text-3xl md:text-4xl"
								data-animate="animate-fade-in"
								data-animate-duration="1s"
							>
								Facilitadoras
							</h2>

							<div class="grid gap-8 md:grid-cols-2">
								{event.facilitators.map((facilitator, index) => (
									<div
										class="from-sage/20 to-sage/5 border-sage/20 group flex flex-col items-center gap-6 rounded-3xl border bg-gradient-to-br p-6 transition-all duration-300 hover:shadow-lg md:p-8"
										data-animate="animate-fade-in"
										data-animate-duration="1s"
										data-animate-delay={`${index * 200}ms`}
									>
										{/* Circular Image */}
										{facilitator.image && (
											<div class="relative flex-shrink-0">
												<div class="bg-terracotta/20 relative h-32 w-32 overflow-hidden rounded-full p-1 md:h-40 md:w-40">
													<img
														src={facilitator.image}
														alt={facilitator.name}
														class="h-full w-full rounded-full object-cover transition-transform duration-500 group-hover:scale-110"
														loading="lazy"
													/>
												</div>
											</div>
										)}

										{/* Content */}
										<div class="flex flex-1 flex-col items-center text-center">
											<h3 class="font-display text-forest mb-1 text-2xl md:text-3xl">
												{facilitator.name}
											</h3>
											<p class="text-terracotta font-body mb-3 text-sm md:text-base">
												{facilitator.role}
											</p>
											<p class="text-forest/70 font-body mb-4 text-sm leading-relaxed md:text-base">
												{facilitator.bio}
											</p>

											{/* Social media */}
											{facilitator.socialMedia && (
												<div class="flex items-center gap-3">
													{facilitator.socialMedia.instagram && (
														<a
															href={facilitator.socialMedia.instagram}
															target="_blank"
															rel="noopener noreferrer"
															class="bg-terracotta/10 hover:bg-terracotta/20 text-terracotta flex h-10 w-10 items-center justify-center rounded-full transition-colors"
															aria-label={`Instagram de ${facilitator.name}`}
														>
															<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">

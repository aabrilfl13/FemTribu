---
import BreadcrumbSchema from "@/components/schema/BreadcrumbSchema.astro"
import EventSchema from "@/components/schema/EventSchema.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import CardContent from "@/components/ui/CardContent.astro"
import CardDescription from "@/components/ui/CardDescription.astro"
import CardHeader from "@/components/ui/CardHeader.astro"
import CardTitle from "@/components/ui/CardTitle.astro"
import Layout from "@/layouts/Layout.astro"
import {
	fetchEvents,
	generateCalendarLink,
	generateShareLinks,
	isClubLecturaEvent,
	type ClubLecturaEvent,
} from "@events"

export const prerender = true

export async function getStaticPaths() {
	const events = await fetchEvents()

	return events.filter(isClubLecturaEvent).map((event) => ({
		params: { slug: event.slug },
		props: { event },
	}))
}

interface Props {
	event: ClubLecturaEvent
}

const { event } = Astro.props

const eventDetails = {
	date: event.date,
	time: event.time,
	type: "Online",
	duration: event.duration,
	book: event.book.title,
	author: event.book.author,
	whatsappLink: event.whatsappLink,
	calendarLink: generateCalendarLink(event),
}

const bookInfo = {
	title: event.book.title,
	author: event.book.author,
	description: event.book.description,
	topics: event.book.topics,
}

const shareLinks = generateShareLinks(event)

const howItWorks = [
	{
		icon: "book-open",
		title: "Lee a tu ritmo",
		description:
			"Cada participante realiza la lectura de forma individual durante el mes. No hay presión, cada una avanza según su tiempo.",
	},
	{
		icon: "message-circle",
		title: "Compartimos en grupo",
		description:
			"Mientras leemos, compartimos reflexiones y aprendizajes en un grupo privado de WhatsApp. Un espacio seguro para expresar lo que sentimos.",
	},
	{
		icon: "video",
		title: "Encuentro virtual",
		description: `Nos reunimos online el ${event.date} a las ${event.time} para comentar el libro juntas y crear un espacio de conversación, aprendizaje y tribu.`,
	},
]

const seoData = event.seo
---

<Layout {...seoData} navScrolled={true}>
	<BreadcrumbSchema
		items={[
			{ name: "Eventos", href: "/eventos/" },
			{ name: "Club Lectura" },
			{ name: event.title },
		]}
	/>
	{/* Structured Data for Event */}
	<EventSchema
		title={event.title}
		description={event.book.description}
		date={event.date}
		dateISO={event.dateISO}
		time={event.time}
		startTime={event.startTime}
		endTime={event.endTime}
		type="Online"
		price="Gratuito"
		spots="Ilimitado"
		image={event.book.coverImage}
	/>

	<main id="main-content" class="pt-21">
		{/* Back to events link */}
		<div class="container mx-auto px-4 pt-8 lg:px-8">
			<a
				href="/eventos"
				class="text-forest hover:text-terracotta font-body inline-flex items-center gap-2 text-sm transition-colors"
			>
				<svg
					class="h-4 w-4"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<line x1="19" y1="12" x2="5" y2="12"></line>
					<polyline points="12 19 5 12 12 5"></polyline>
				</svg>
				Volver a eventos
			</a>
		</div>

		{/* Hero Section */}
		<section class="container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="relative z-10 container mx-auto max-w-4xl text-center">
				<div
					class="bg-sage/20 mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
				>
					<svg
						class="text-forest h-4 w-4"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
						<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
					</svg>
					<span class="font-body text-forest text-sm">{event.date} • {event.time} • Online</span>
				</div>

				<h1
					class="font-display text-forest mb-6 text-4xl md:text-5xl lg:text-6xl"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.2s"
				>
					{event.title}
					<span class="text-terracotta">{event.subtitle.split(" ")[2]}</span>
				</h1>

				<p
					class="font-body text-forest/70 mx-auto max-w-2xl text-lg"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.3s"
				>
					Un espacio para mujeres que quieren profundizar en su salud, su cuerpo y su historia a
					través de los libros.
				</p>

				<div
					class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.4s"
				>
					<Button
						variant="hero"
						size="lg"
						href={eventDetails.whatsappLink}
						target="_blank"
						rel="noopener noreferrer"
					>
						Unirme al grupo de WhatsApp
						<svg
							class="ml-2 h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<line x1="5" y1="12" x2="19" y2="12"></line>
							<polyline points="12 5 19 12 12 19"></polyline>
						</svg>
					</Button>
					<Button
						variant="outline"
						size="lg"
						href={eventDetails.calendarLink}
						target="_blank"
						rel="noopener noreferrer"
					>
						<svg
							class="mr-2 h-4 w-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
							<line x1="16" y1="2" x2="16" y2="6"></line>
							<line x1="8" y1="2" x2="8" y2="6"></line>
							<line x1="3" y1="10" x2="21" y2="10"></line>
						</svg>
						Añadir a mi calendario
					</Button>
				</div>

				{/* Share Section */}
				<div
					class="mt-12 flex flex-col items-center gap-4"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
					data-animate-delay="0.5s"
				>
					<p class="font-body text-forest/70 text-sm">Comparte este evento</p>
					<div class="flex flex-wrap items-center justify-center gap-3">
						<a
							href={shareLinks.whatsapp}
							target="_blank"
							rel="noopener noreferrer"
							class="bg-sage/10 hover:bg-sage/20 text-forest flex h-11 w-11 items-center justify-center rounded-full transition-colors"
							aria-label="Compartir en WhatsApp"
						>
							<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
								<path
									d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
								></path>
							</svg>
						</a>
						<button
							id="copy-link-btn"
							class="bg-sage/10 hover:bg-sage/20 text-forest flex h-11 w-11 cursor-pointer items-center justify-center rounded-full transition-colors"
							aria-label="Copiar enlace"
							data-url={shareLinks.copyLink}
						>
							<svg
								class="h-5 w-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
								<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
							</svg>
						</button>
					</div>
				</div>
			</div>
		</section>

		{/* Event Details */}
		<section class="pb-16 lg:pb-24">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="mx-auto max-w-5xl">
					<div
						class="from-sage/20 to-sage/5 border-sage/20 rounded-3xl border bg-gradient-to-r p-8"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
					>
						<div class="grid gap-8 md:grid-cols-2">
							<div class="flex flex-col items-start justify-center gap-8">
								<h2 class="font-display text-forest mb-4 text-2xl md:text-3xl">
									{event.subtitle}
								</h2>
								<div class="space-y-3">
									<div class="flex items-center gap-3">
										<div
											class="bg-forest/10 flex h-10 w-10 items-center justify-center rounded-full"
										>
											<svg
												class="text-forest h-5 w-5"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
												<line x1="16" y1="2" x2="16" y2="6"></line>
												<line x1="8" y1="2" x2="8" y2="6"></line>
												<line x1="3" y1="10" x2="21" y2="10"></line>
											</svg>
										</div>
										<div>
											<p class="font-body text-forest/70 text-sm">Fecha</p>
											<p class="font-body text-forest font-medium">{eventDetails.date}</p>
										</div>
									</div>
									<div class="flex items-center gap-3">
										<div
											class="bg-forest/10 flex h-10 w-10 items-center justify-center rounded-full"
										>
											<svg
												class="text-forest h-5 w-5"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<circle cx="12" cy="12" r="10"></circle>
												<polyline points="12 6 12 12 16 14"></polyline>
											</svg>
										</div>
										<div>
											<p class="font-body text-forest/70 text-sm">Hora</p>
											<p class="font-body text-forest font-medium">{eventDetails.time}</p>
										</div>
									</div>
									<div class="flex items-center gap-3">
										<div
											class="bg-forest/10 flex h-10 w-10 items-center justify-center rounded-full"
										>
											<svg
												class="text-forest h-5 w-5"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
												<circle cx="12" cy="10" r="3"></circle>
											</svg>
										</div>
										<div>
											<p class="font-body text-forest/70 text-sm">Modalidad</p>
											<p class="font-body text-forest font-medium">{eventDetails.type}</p>
										</div>
									</div>
								</div>
							</div>
							<div class="flex items-center justify-center">
								<div class="text-center">
									<p class="text-forest/70 font-body mb-4 text-sm">Libro de esta edición</p>
									<div class="mx-auto w-full max-w-[200px]">
										<img
											src={event.book.coverImage}
											alt={`Portada del libro ${event.book.title} de ${event.book.author}`}
											class="h-auto w-full rounded-lg shadow-xl"
											loading="lazy"
										/>
									</div>
									<h3 class="font-display text-forest mt-4 text-xl">{bookInfo.title}</h3>
									<p class="text-terracotta font-body text-base">de {bookInfo.author}</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* How it works */}
		<section class="pb-16 lg:pb-24">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="mx-auto max-w-5xl">
					<h2
						class="font-display text-forest mb-12 text-center text-3xl md:text-4xl"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
					>
						¿Cómo funciona?
					</h2>

					<div class="grid gap-6 md:grid-cols-3">
						{
							howItWorks.map((step, index) => (
								<Card
									class="border-sage/20 hover:border-sage/50 transition-all duration-300 hover:shadow-lg"
									data-animate="animate-fade-in"
									data-animate-duration="1s"
									data-animate-delay={`${index * 200}ms`}
								>
									<CardHeader>
										<div class="text-terracotta mb-4 h-10 w-10">
											{step.icon === "book-open" && (
												<svg
													xmlns="http://www.w3.org/2000/svg"
													width="40"
													height="40"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M12 7v14" />
													<path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z" />
												</svg>
											)}
											{step.icon === "message-circle" && (
												<svg
													xmlns="http://www.w3.org/2000/svg"
													width="40"
													height="40"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z" />
												</svg>
											)}
											{step.icon === "video" && (
												<svg
													xmlns="http://www.w3.org/2000/svg"
													width="40"
													height="40"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5" />
													<rect x="2" y="6" width="14" height="12" rx="2" />
												</svg>
											)}
										</div>
										<CardTitle class="font-display text-forest text-xl">{step.title}</CardTitle>
									</CardHeader>
									<CardContent>
										<CardDescription class="text-forest/70 text-sm leading-relaxed">
											{step.description}
										</CardDescription>
									</CardContent>
								</Card>
							))
						}
					</div>
				</div>
			</div>
		</section>

		{/* Book Info */}
		<section class="pb-24 lg:pb-32">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="mx-auto max-w-6xl">
					<div
						class="from-terracotta/20 to-terracotta/5 border-terracotta/20 rounded-3xl border bg-gradient-to-r p-8 md:p-12"
						data-animate="animate-fade-in"
						data-animate-duration="1s"
					>
						<h2 class="font-display text-forest mb-8 text-center text-3xl md:text-4xl">
							Sobre el libro
						</h2>
						<div class="grid gap-8 md:grid-cols-3 md:gap-8 lg:gap-12">
							{/* Book Cover */}
							<div class="flex items-start justify-center md:justify-end">
								<div class="w-full max-w-[280px]">
									<img
										src={event.book.coverImage}
										alt={`Portada del libro ${event.book.title} de ${event.book.author}`}
										class="h-auto w-full rounded-xl shadow-2xl"
										loading="lazy"
									/>
								</div>
							</div>

							{/* Book Description and Topics */}
							<div class="md:col-span-2">
								<h3 class="font-display text-terracotta mb-3 text-2xl md:text-3xl">
									{bookInfo.title}
								</h3>
								<p class="text-forest/70 font-body mb-4 text-lg">de {bookInfo.author}</p>
								<p class="text-forest/80 font-body mb-8 leading-relaxed">
									{bookInfo.description}
								</p>

								<h4 class="font-display text-forest mb-4 text-xl">Temas que aborda:</h4>
								<ul class="space-y-3">
									{
										bookInfo.topics.map((topic) => (
											<li class="flex items-start gap-3">
												<div class="bg-terracotta/20 mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full">
													<svg
														class="text-terracotta h-3 w-3"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="3"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<polyline points="20 6 9 17 4 12" />
													</svg>
												</div>
												<span class="text-forest/80 font-body text-sm">{topic}</span>
											</li>
										))
									}
								</ul>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		{/* CTA Section */}
		<section class="pb-24 lg:pb-32">
			<div class="container mx-auto px-4 lg:px-8">
				<div
					class="bg-forest mx-auto max-w-4xl rounded-3xl px-8 py-16 text-center"
					data-animate="animate-fade-in"
					data-animate-duration="1s"
				>
					<h2 class="text-cream font-display mb-4 text-3xl md:text-4xl">¿Te unes a nosotras?</h2>
					<p class="text-cream/80 font-body mx-auto mb-8 max-w-2xl text-lg">
						Únete al grupo de WhatsApp para recibir toda la información y empezar a compartir con
						otras mujeres que, como tú, quieren aprender y crecer juntas.
					</p>
					<div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
						<Button
							variant="secondary"
							size="lg"
							href={eventDetails.whatsappLink}
							target="_blank"
							rel="noopener noreferrer"
						>
							Unirme al grupo de WhatsApp
							<svg
								class="ml-2 h-4 w-4"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<line x1="5" y1="12" x2="19" y2="12"></line>
								<polyline points="12 5 19 12 12 19"></polyline>
							</svg>
						</Button>
						<Button
							variant="outline"
							size="lg"
							href={eventDetails.calendarLink}
							target="_blank"
							rel="noopener noreferrer"
							class="border-cream/30 text-cream hover:bg-cream/10"
						>
							<svg
								class="mr-2 h-4 w-4"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
								<line x1="16" y1="2" x2="16" y2="6"></line>
								<line x1="8" y1="2" x2="8" y2="6"></line>
								<line x1="3" y1="10" x2="21" y2="10"></line>
							</svg>
							Añadir a mi calendario
						</Button>
					</div>
					<p class="text-cream/60 font-body mt-6 text-sm">
						Gratuito • Online • Para todas las mujeres
					</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	// Copy link functionality
	const copyLinkBtn = document.getElementById("copy-link-btn")

	copyLinkBtn?.addEventListener("click", async () => {
		const url = copyLinkBtn.getAttribute("data-url")
		if (!url) return

		try {
			await navigator.clipboard.writeText(url)

			// Show feedback
			const originalHTML = copyLinkBtn.innerHTML
			copyLinkBtn.innerHTML = `
				<svg class="h-5 w-5 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="20 6 9 17 4 12"></polyline>
				</svg>
			`

			// Reset after 2 seconds
			setTimeout(() => {
				copyLinkBtn.innerHTML = originalHTML
			}, 2000)
		} catch (err) {
			console.error("Failed to copy:", err)
		}
	})
</script>

---
import ServiceDetail from "@/components/ui/ServiceDetail.astro"
import { SERVICES } from "@/data/services"

export const prerender = true

const service = SERVICES.lactancia
const motif = "/images/icons/illustrations/ilustracion-negro_05.svg"

const aboutBody = [
	"Una especialista en lactancia (matrona y asesora de lactancia) te acompaña de forma individual para que la lactancia materna sea una experiencia tranquila y posible, desde el inicio hasta cualquier etapa del proceso. Es un espacio seguro donde expresar tus dudas, recibir apoyo profesional y encontrar soluciones adaptadas a tu situación.",
	"En la consulta valoramos la toma completa y el agarre del bebé, abordamos el dolor, las grietas o las molestias, y trabajamos la producción de leche, el uso del sacaleches, la lactancia mixta o diferida, la vuelta al trabajo y el destete respetuoso. Cada caso es único y la consulta se adapta a ti.",
	"Puedes hacerla online o presencial en Valencia, y dura 60 minutos.",
]

const work = [
	"Valoración completa de la toma",
	"Evaluación del agarre del bebé",
	"Dolor, grietas o molestias",
	"Producción de leche (aumento o disminución)",
	"Uso de sacaleches",
	"Lactancia mixta o diferida",
	"Vuelta al trabajo",
	"Destete respetuoso",
]

const audience = [
	"Madres recientes",
	"Embarazadas que quieren prepararse",
	"Mujeres con dificultades en la lactancia",
	"Cualquier mamá que necesite acompañamiento",
]

const faqs = [
	{
		question: "¿Cuánto cuesta una asesoría de lactancia en Valencia?",
		answer:
			"La consulta de lactancia cuesta 50 € e incluye 60 minutos de atención personalizada, online o presencial en Valencia.",
	},
	{
		question: "¿Qué incluye una consulta de lactancia con matrona?",
		answer:
			"Incluye la valoración de la toma y del agarre, el abordaje del dolor o las grietas, y el trabajo sobre producción de leche, sacaleches, lactancia mixta, vuelta al trabajo o destete, según lo que necesites.",
	},
	{
		question: "¿Es mejor la asesoría online o presencial?",
		answer:
			"Ambas son eficaces. La presencial permite valorar la toma en directo; la online es muy cómoda y resuelve la gran mayoría de dificultades con apoyo visual. Te ayudo a elegir según tu caso.",
	},
	{
		question: "¿A partir de cuándo puedo pedir cita?",
		answer:
			"Cuando quieras: durante el embarazo para prepararte, en los primeros días si surge cualquier dificultad, o más adelante para la vuelta al trabajo o el destete.",
	},
	{
		question: "¿Atendéis el dolor al amamantar o los problemas de agarre?",
		answer:
			"Sí, son de los motivos de consulta más frecuentes. Valoramos la causa del dolor o del mal agarre y te damos pautas concretas para corregirlo y amamantar sin molestias.",
	},
	{
		question: "¿Ofrecéis packs de seguimiento de lactancia?",
		answer:
			"Ahora el servicio es una consulta única de 50 € que se adapta a cada etapa, con seguimiento posterior por WhatsApp cuando lo necesitas. Si requieres acompañamiento continuado, planificamos juntas las sesiones que precises.",
	},
]

const related = [
	{
		href: "/servicios/preparacion-al-parto",
		title: "Preparación al Parto",
		description: "Prepara el inicio de la lactancia y el posparto antes del nacimiento.",
		price: "50€ · 60 min",
	},
	{
		href: "/servicios/pendientes-bebe",
		title: "Pendientes para Bebés",
		description: "Colocación de pendientes por matrona profesional, en Valencia.",
		price: "60€",
	},
]
---

<ServiceDetail
	service={service}
	serviceName="Lactancia"
	color="sage"
	motif={motif}
	eyebrow="Acompañamiento personalizado"
	h1Accent="Especialista en Lactancia"
	h1Tail="en Valencia y Online"
	intro="Acompañamiento profesional y cercano en Valencia y online para que disfrutes de tu lactancia. Resolvemos tus dudas, superamos dificultades y te sostenemos en cada etapa, desde el inicio hasta el destete respetuoso."
	aboutTitle="¿Qué hace una especialista en lactancia?"
	aboutBody={aboutBody}
	work={work}
	audience={audience}
	priceNote="60 min · Online o presencial · Sesión personalizada"
	faqs={faqs}
	related={related}
/>

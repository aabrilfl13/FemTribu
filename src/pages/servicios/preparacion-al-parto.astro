---
import BreadcrumbSchema from "@/components/schema/BreadcrumbSchema.astro"
import ServiceSchema from "@/components/schema/ServiceSchema.astro"
import AdditionalInfo from "@/components/sections/cta/AdditionalInfo.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import CardContent from "@/components/ui/CardContent.astro"
import CardDescription from "@/components/ui/CardDescription.astro"
import CardFooter from "@/components/ui/CardFooter.astro"
import CardHeader from "@/components/ui/CardHeader.astro"
import CardTitle from "@/components/ui/CardTitle.astro"
import { SERVICES } from "@/data/services"
import Layout from "@/layouts/Layout.astro"

export const prerender = true

const serviceName = "Preparación al Parto"
const serviceData = SERVICES.preparacionParto

const packs = [
	{
		name: "Confía en tu cuerpo",
		subtitle: "Pack Básico",
		price: 90,
		description:
			"Un acompañamiento esencial para comprender la fisiología del parto y trabajar los miedos más comunes. A través de dos sesiones online, aprenderás qué sucede en tu cuerpo durante el parto y descubrirás herramientas prácticas para afrontarlo con seguridad y confianza.",
		features: [
			"Sesión 1: Fisiología del parto — qué ocurre en tu cuerpo, fases, hormonas y señales",
			"Sesión 2: Miedo al parto y herramientas para gestionarlo",
			"Formulario previo para adaptar la preparación a tus necesidades",
		],
		ideal:
			"Estás en tu primer embarazo o quieres una preparación breve pero completa para entender y confiar en tu cuerpo.",
		highlight: false,
		tier: "basic",
	},
	{
		name: "Fluye con tu parto",
		subtitle: "Pack Medio",
		price: 170,
		description:
			"Un acompañamiento integral para trabajar el cuerpo y la mente de forma conjunta. Además de la información teórica y emocional, aprenderás movilidad y posturas útiles para el parto, y técnicas de visualización y meditación para conectar con tu respiración y mantener la calma.",
		features: [
			"Todo lo del Pack Básico",
			"Sesión 3: Movilidad y movimiento para el parto",
			"Sesión 4: Meditación y visualización para conectar con la calma interior",
		],
		ideal:
			"Buscas una preparación más completa, con herramientas prácticas y corporales que te ayuden a vivir tu parto de forma activa y consciente.",
		highlight: false,
		tier: "medium",
	},
	{
		name: "El viaje de nacer",
		subtitle: "Pack Premium",
		price: 250,
		description:
			"Un programa de preparación profundo y personalizado que abarca todas las dimensiones del parto: cuerpo, mente, emociones, vínculo y posparto. Te acompañamos paso a paso para que vivas esta etapa con confianza, seguridad y apoyo constante.",
		features: [
			"Todo lo del Pack Básico y Medio",
			"Sesión 5: Dinámica de conexión en pareja — comunicación, roles y acompañamiento emocional",
			"Sesión 6: Postparto inmediato y cuidados del recién nacido",
			"Entregables en PDF con resúmenes, ejercicios y recursos prácticos",
			"Acompañamiento por WhatsApp durante el proceso",
		],
		ideal:
			"Quieres una preparación completa, en pareja o en solitario, con acompañamiento cercano y recursos prácticos antes, durante y después del parto.",
		highlight: true,
		tier: "premium",
	},
]

const seoData = {
	...serviceData.seo,
	type: "website" as const,
}

const phoneNumber = import.meta.env.WHATSAPP_NUMBER
---

<Layout navScrolled={true} {...seoData}>
	<BreadcrumbSchema items={[{ name: "Servicios" }, { name: serviceName }]} />
	<ServiceSchema
		name={serviceData.name}
		description={serviceData.description}
		priceMin={serviceData.priceMin}
		priceMax={serviceData.priceMax}
		serviceType={serviceData.serviceType}
	/>
	<main id="main-content" class="pt-21">
		{/* Background decorations */}
		<div
			class="bg-secondary/15 shape-blob pointer-events-none absolute bottom-0 left-0 h-64 w-64 -translate-x-1/2 translate-y-1/2"
		>
		</div>
		<section class="container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="z-10 container mx-auto px-4 lg:px-8">
				<div class="mx-auto max-w-4xl text-center">
					<span
						class="bg-coral-light/30 text-primary mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm"
						data-animate="animate-fade-up"
						data-animate-duration="1s"
					>
						<img src="/images/icons/cookie.svg" alt="Icono de galleta" class="h-4 w-4" />
						Acompañamiento personalizado
					</span>
					<h1
						class="font-display text-primary mb-6 text-4xl sm:text-5xl lg:text-6xl"
						data-animate="animate-fade-up"
						data-animate-duration="1s"
						data-animate-delay="0.1s"
					>
						Preparación al <span class="text-accent">Parto</span> en Valencia y Online
					</h1>
					<p
						class="text-muted-foreground mx-auto max-w-3xl text-lg lg:text-xl"
						data-animate="animate-fade-up"
						data-animate-duration="1s"
						data-animate-delay="0.2s"
					>
						Tu matrona en Valencia y online. Un acompañamiento diseñado para que vivas tu parto con
						ciencia, alma y seguridad. Elige el pack de preparación que mejor se adapte a tu viaje.
					</p>
				</div>
			</div>
		</section>

		{/* Pricing Cards */}
		<section class="pb-24 lg:pb-32">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 lg:gap-6">
					{
						packs.map((pack, index) => (
							<Card
								class={`relative overflow-hidden transition-all duration-300 hover:-translate-y-2 ${
									pack.highlight
										? "border-accent ring-accent/20 shadow-lg ring-2"
										: "border-border/50 hover:border-accent/50 hover:shadow-warm"
								}`}
								data-animate="animate-fade-up"
								data-animate-duration="1s"
								data-animate-delay={`${index * 300}ms`}
							>
								{pack.highlight && (
									<div class="bg-accent text-accent-foreground absolute top-0 right-0 left-0 py-2 text-center text-sm font-medium">
										Más popular
									</div>
								)}

								<CardHeader class={pack.highlight ? "pt-12" : ""}>
									<div class="mb-4">
										<CardTitle class="font-display text-primary mb-1 text-2xl">
											{pack.name}
										</CardTitle>
										<CardDescription class="text-accent text-base font-medium">
											{pack.subtitle}
										</CardDescription>
									</div>

									<div class="mb-4 flex items-baseline gap-1">
										<span class="font-display text-primary text-4xl">{pack.price}€</span>
									</div>

									<p class="text-muted-foreground text-sm leading-relaxed">{pack.description}</p>
								</CardHeader>

								<CardContent>
									{/* Features */}
									<ul class="list-none space-y-3">
										{pack.features.map((feature) => (
											<li class="flex items-start gap-3">
												<div class="bg-accent/20 mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full">
													<svg
														class="text-accent h-3 w-3"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="3"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<polyline points="20 6 9 17 4 12" />
													</svg>
												</div>
												<span class="text-muted-foreground text-sm">{feature}</span>
											</li>
										))}
									</ul>
								</CardContent>

								<CardFooter class="flex-col gap-4">
									{/* Ideal for */}
									<div class="bg-muted/50 w-full rounded-xl p-4">
										<p class="text-sm">
											<span class="text-primary font-medium">Ideal para ti si: </span>
											<span class="text-muted-foreground">{pack.ideal}</span>
										</p>
									</div>
									{/* CTA Button */}
									<Button
										variant={pack.highlight ? "hero" : "outline"}
										class="w-full"
										size="lg"
										data-service-tier={pack.tier}
									>
										Reservar {pack.subtitle}
									</Button>
								</CardFooter>
							</Card>
						))
					}
				</div>
			</div>
		</section>
		<AdditionalInfo serviceName={serviceName} />
	</main>
</Layout>

<script define:vars={{ phoneNumber, serviceName }}>
	document.addEventListener("DOMContentLoaded", () => {
		const buttons = document.querySelectorAll("button[data-service-tier]")

		buttons.forEach((button) => {
			button.addEventListener("click", () => {
				const tier = button.getAttribute("data-service-tier") || "basic"
				const message = encodeURIComponent(
					`Hola! Me interesa saber más sobre *${serviceName}* - *Pack ${tier.charAt(0).toUpperCase() + tier.slice(1)}* de *Femm tribu*.`
				)
				window.open(`https://wa.me/34${phoneNumber}?text=${message}`, "_blank")
			})
		})
	})
</script>

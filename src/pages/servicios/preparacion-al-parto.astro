---
import Button from "@/components/ui/Button.astro"
import ServiceDetail from "@/components/ui/ServiceDetail.astro"
import { SERVICES } from "@/data/services"

export const prerender = true

const service = SERVICES.preparacionParto
const motif = "/images/icons/illustrations/ilustracion-negro_07.svg"

const aboutBody = [
	"La sesión de dudas sobre embarazo y parto es una consulta individual con matrona para resolver todo lo que te preocupa de esta etapa, basada en evidencia científica y adaptada a tus necesidades. Te ayudo a entender lo que estás viviendo y a tomar decisiones informadas con tranquilidad.",
	"Hablamos de los cambios del embarazo, de cómo es el parto y sus fases, de cómo elaborar tu plan de parto, de las intervenciones médicas más habituales y de cómo gestionar el miedo al parto. También preparamos el posparto inmediato y el inicio de la lactancia, para que llegues con confianza al gran día.",
	"La sesión dura 60 minutos y puedes hacerla online o presencial en Valencia. Y si prefieres prepararte junto a otras familias, también ofrecemos un programa grupal de preparación al parto.",
]

const work = [
	"Cambios en el embarazo",
	"Preparación al parto",
	"Plan de parto",
	"Intervenciones médicas",
	"Gestión del miedo al parto",
	"Posparto inmediato",
	"Lactancia (inicio)",
]

const audience = [
	"Mujeres embarazadas en cualquier trimestre",
	"Mujeres que quieren prepararse para el parto",
	"Personas con dudas o inseguridad sobre el proceso",
]

const faqs = [
	{
		question: "¿Cuándo empezar la preparación al parto?",
		answer:
			"Lo habitual es empezar alrededor de la semana 28-32, en el tercer trimestre, aunque puedes resolver dudas en cualquier momento del embarazo. Si tienes inquietudes concretas, no hace falta esperar.",
	},
	{
		question: "¿Preparación individual, online o grupal: cuál me conviene?",
		answer:
			"La sesión individual (online o presencial) se adapta a tus dudas y a tu ritmo. La preparación grupal añade el valor de compartir con otras familias. Puedes combinarlas; te ayudo a elegir según tu momento.",
	},
	{
		question: "¿Ofrecéis preparación al parto para parejas?",
		answer:
			"Sí. Tu pareja o acompañante puede participar en la sesión para entender su papel durante el parto y el posparto y aprender cómo sostenerte.",
	},
	{
		question: "¿Qué es un plan de parto y cómo se elabora?",
		answer:
			"Es un documento donde expresas tus preferencias para el parto (posiciones, alivio del dolor, contacto piel con piel…). En la sesión te explico las opciones basadas en evidencia y te ayudo a redactarlo.",
	},
	{
		question: "¿Ofrecéis la sesión de dudas una sola vez?",
		answer:
			"Sí. Es una consulta puntual de 60 minutos por 50 €. Puedes reservar las sesiones que necesites, sin paquetes obligatorios.",
	},
]

const related = [
	{
		href: "/servicios/lactancia",
		title: "Asesoría de Lactancia",
		description: "Para preparar y acompañar el inicio de la lactancia tras el nacimiento.",
		price: "50€ · 60 min",
	},
	{
		href: "/servicios/femmbarre",
		title: "FemmBarre Maternity",
		description: "Barre prenatal online para mantenerte activa y preparar tu cuerpo para el parto.",
		price: "35€ / mes",
	},
]
---

<ServiceDetail
	service={service}
	serviceName="Preparación al Parto"
	color="coral"
	motif={motif}
	eyebrow="Sesión de dudas basada en evidencia"
	h1Accent="Preparación al Parto"
	h1Tail="en Valencia y Online"
	intro="Resolvemos tus dudas sobre embarazo, parto y posparto con información basada en evidencia y acompañamiento emocional, para que vivas tu parto con confianza y tomes decisiones informadas."
	aboutTitle="¿Qué es la sesión de dudas de embarazo y parto?"
	aboutBody={aboutBody}
	work={work}
	audience={audience}
	priceNote="60 min · Online o presencial · Sesión de dudas individual"
	faqs={faqs}
	related={related}
>
	{/* Group-programme banner (PDF: route to WhatsApp for availability) */}
	<div
		class="border-coral/30 bg-coral/10 flex flex-col gap-4 rounded-3xl border-2 border-dashed p-6 sm:flex-row sm:items-center sm:justify-between"
	>
		<div>
			<p class="font-display text-primary text-lg">¿Prefieres preparación al parto en grupo?</p>
			<p class="text-muted-foreground text-sm">
				Organizamos un programa grupal de preparación al parto. Consulta disponibilidad por
				WhatsApp.
			</p>
		</div>
		<Button
			variant="hero"
			size="sm"
			class="shrink-0 rounded-full"
			data-whatsapp-inquiry="Programa grupal de preparación al parto"
		>
			Consultar disponibilidad
		</Button>
	</div>
</ServiceDetail>

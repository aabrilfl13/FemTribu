---
import ServiceDetail from "@/components/ui/ServiceDetail.astro"
import { SERVICES } from "@/data/services"

export const prerender = true

const service = SERVICES.menopausia
const motif = "/images/icons/illustrations/ilustracion-negro_14.svg"

const aboutBody = [
	"La menopausia no es una enfermedad, sino una etapa natural en la vida de toda mujer. Como matrona especializada en salud femenina, te acompaño para que comprendas qué ocurre en tu cuerpo durante la perimenopausia y la menopausia, y para que transites este cambio con información, calma y herramientas reales.",
	"Abordamos los síntomas más frecuentes —sofocos, insomnio, cambios de ánimo, sequedad vaginal o pérdida de densidad ósea— desde un enfoque natural y basado en evidencia científica. No se trata de “aguantar”: se trata de entender tus hormonas y cuidar tu alimentación, tu descanso, tu movimiento y tu salud sexual para mantener tu calidad de vida.",
	"La consulta dura 60 minutos, es totalmente personalizada y se realiza online desde cualquier lugar de España. Un espacio de escucha sin juicio donde resolver tus dudas y diseñar un plan de autocuidado adaptado a tu momento vital.",
]

const work = [
	"Sofocos",
	"Alteraciones del sueño",
	"Cambios emocionales",
	"Sequedad vaginal",
	"Salud ósea",
	"Hábitos y autocuidado",
]

const audience = [
	"Mujeres en perimenopausia",
	"Mujeres en menopausia",
	"Mujeres que quieren entender esta etapa",
]

const faqs = [
	{
		question: "¿Una matrona trata la menopausia?",
		answer:
			"Sí. La matrona es la profesional especializada en la salud de la mujer a lo largo de todas sus etapas, incluida la menopausia. Te ayuda a comprender los cambios hormonales, a aliviar los síntomas desde un enfoque natural y a derivar al especialista cuando es necesario.",
	},
	{
		question: "¿Qué podéis hacer por los sofocos, el insomnio y los cambios emocionales?",
		answer:
			"Trabajamos hábitos de alimentación, descanso, movimiento y gestión del estrés con base científica, además de orientarte sobre suplementación y las opciones disponibles. El objetivo es reducir la intensidad de los síntomas y mejorar tu bienestar diario.",
	},
	{
		question: "¿Atendéis la sequedad vaginal y la salud sexual en la menopausia?",
		answer:
			"Sí. La sequedad vaginal y los cambios en la sexualidad son muy frecuentes y tienen solución. En la consulta hablamos de ello con naturalidad y te damos pautas y recursos para cuidar tu salud íntima.",
	},
	{
		question: "¿En qué etapa puedo pedir cita: perimenopausia, menopausia o postmenopausia?",
		answer:
			"En cualquiera de ellas. Cuanto antes acudas —incluso en la perimenopausia, con los primeros cambios del ciclo— más fácil será anticiparte y cuidar tu salud hormonal y ósea a largo plazo.",
	},
	{
		question: "¿Cuánto cuesta la consulta de menopausia?",
		answer:
			"La consulta de salud en menopausia cuesta 50 € e incluye 60 minutos de atención personalizada online, con posibilidad de seguimiento posterior opcional.",
	},
]

const related = [
	{
		href: "/servicios/salud-hormonal",
		title: "Consulta de Salud Hormonal",
		description:
			"Si buscas entender tu ciclo, el dolor menstrual o los desajustes hormonales antes de esta etapa.",
		price: "50€ · 60 min",
	},
	{
		href: "/servicios/conoce-tu-ciclo",
		title: "Pack Conoce tu Ciclo",
		description:
			"Acompañamiento de 3 meses para comprender en profundidad tu salud hormonal femenina.",
		price: "120€ · 3 meses",
	},
]
---

<ServiceDetail
	service={service}
	serviceName="Menopausia"
	color="terracotta"
	motif={motif}
	eyebrow="Acompañamiento natural y basado en evidencia"
	h1Lead="Salud en"
	h1Accent="Menopausia"
	h1Tail="en Valencia y Online"
	intro="Un acompañamiento integral en Valencia y online para transitar tu menopausia con vitalidad y consciencia. Comprende los cambios de tu cuerpo y mejora tu calidad de vida desde un enfoque natural y basado en evidencia."
	aboutTitle="¿Una matrona acompaña la menopausia?"
	aboutBody={aboutBody}
	work={work}
	audience={audience}
	priceNote="60 min · Online · Sesión personalizada"
	faqs={faqs}
	related={related}
/>

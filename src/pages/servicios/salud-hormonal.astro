---
import ServiceDetail from "@/components/ui/ServiceDetail.astro"
import { SERVICES } from "@/data/services"

export const prerender = true

const service = SERVICES.saludHormonal
const motif = "/images/icons/illustrations/ilustracion-negro_01.svg"

const aboutBody = [
	"La consulta de salud hormonal femenina es un espacio con matrona para entender tu ciclo menstrual y mejorar tu bienestar desde un enfoque integral. Trabajamos desde la educación, la escucha del cuerpo y herramientas prácticas para tu día a día.",
	"Si sufres dolor menstrual, síndrome premenstrual (SPM), ciclos irregulares o notas desajustes hormonales, te ayudo a identificar las fases de tu ciclo y a entender qué está ocurriendo. Revisamos tus hábitos —alimentación, descanso, movimiento y gestión del estrés— porque el equilibrio hormonal se construye, en gran parte, desde el estilo de vida.",
	"La consulta dura 60 minutos, es personalizada y puedes hacerla online o presencial en Valencia. Cuando necesitas un cambio profundo y sostenido, puedes continuar con el pack Conoce tu Ciclo (3 meses) o, si buscas el embarazo, con la consulta preconcepcional.",
]

const work = [
	"Dolor menstrual",
	"Síndrome premenstrual (SPM)",
	"Ciclos irregulares",
	"Desajustes hormonales",
	"Identificación de las fases del ciclo",
	"Hábitos y estilo de vida",
]

const audience = [
	"Mujeres con molestias en su ciclo",
	"Mujeres que quieren entender su cuerpo",
	"Mujeres que buscan equilibrio hormonal natural",
]

const faqs = [
	{
		question: "¿Qué es una consulta de salud hormonal con matrona?",
		answer:
			"Es una consulta para comprender y mejorar tu salud hormonal femenina: dolor menstrual, SPM, ciclos irregulares o desajustes. Combinamos educación sobre tu ciclo con cambios de hábitos y herramientas prácticas, desde un enfoque natural y basado en evidencia.",
	},
	{
		question: "¿Trabajáis SPM, endometriosis o ciclos irregulares?",
		answer:
			"Sí. Acompañamos el síndrome premenstrual, los ciclos irregulares y los síntomas asociados a condiciones como la endometriosis o el SOP desde el estilo de vida, coordinándonos con tu equipo médico cuando es necesario.",
	},
	{
		question: "¿Cuánto dura un acompañamiento de salud hormonal?",
		answer:
			"Una consulta puntual dura 60 minutos. Si buscas un cambio sostenido, el pack Conoce tu Ciclo ofrece 3 meses de seguimiento, porque regular el ciclo y consolidar hábitos lleva varios ciclos.",
	},
	{
		question: "¿Cuál es la diferencia entre la consulta suelta y el pack de 3 meses?",
		answer:
			"La consulta suelta (50 €) resuelve una duda concreta o hace una primera valoración. El pack Conoce tu Ciclo (120 €) es un acompañamiento de 3 meses con seguimiento para un cambio real y datos de tu propio cuerpo.",
	},
	{
		question: "¿Cuánto cuesta la consulta de salud hormonal?",
		answer:
			"La consulta cuesta 50 € e incluye 60 minutos de atención personalizada, online o presencial en Valencia.",
	},
]

const related = [
	{
		href: "/servicios/conoce-tu-ciclo",
		title: "Pack Conoce tu Ciclo",
		description:
			"Acompañamiento de 3 meses para comprender tu ciclo en profundidad y consolidar hábitos. El paso natural tras una primera consulta.",
		price: "120€ · 3 meses",
	},
	{
		href: "/servicios/preconcepcional",
		title: "Consulta Preconcepcional",
		description:
			"Si tu objetivo es preparar el cuerpo de forma consciente antes de buscar el embarazo.",
		price: "50€ · 60 min",
	},
]
---

<ServiceDetail
	service={service}
	serviceName="Salud Hormonal"
	color="terracotta"
	motif={motif}
	eyebrow="Un viaje de autoconocimiento hormonal"
	h1Accent="Salud Hormonal Femenina"
	h1Tail="en Valencia y Online"
	intro="Un viaje de autoconocimiento para entender tus hormonas y vivir en equilibrio. Acompañamiento en Valencia y online para reconciliarte con tu ciclo menstrual y potenciar tu vitalidad."
	aboutTitle="¿Qué es una consulta de salud hormonal?"
	aboutBody={aboutBody}
	work={work}
	audience={audience}
	priceNote="60 min · Online o presencial · Sesión personalizada"
	faqs={faqs}
	relatedTitle="¿Buscas algo más específico?"
	related={related}
/>

---
import AdditionalInfo from "@/components/sections/cta/AdditionalInfo.astro"
import Button from "@/components/ui/Button.astro"
import Card from "@/components/ui/Card.astro"
import CardContent from "@/components/ui/CardContent.astro"
import CardDescription from "@/components/ui/CardDescription.astro"
import CardFooter from "@/components/ui/CardFooter.astro"
import CardHeader from "@/components/ui/CardHeader.astro"
import CardTitle from "@/components/ui/CardTitle.astro"
import Layout from "@/layouts/Layout.astro"

const serviceName = "Salud Hormonal"

const packs = [
	{
		name: "Conecta con tu ciclo",
		subtitle: "Pack Básico",
		price: 60,
		description:
			"Una sesión online en directo para entender de forma clara y sencilla qué ocurre en tu cuerpo durante cada fase del ciclo menstrual.",
		features: [
			"Sesión online en directo de 1h 30 min",
			"Teoría del ciclo menstrual explicada de forma visual",
			"Resolución de dudas en directo",
			"Formulario previo para adaptar la sesión a ti",
		],
		ideal:
			"Estás dando tus primeros pasos en el autoconocimiento hormonal y quieres entender tu cuerpo sin complicaciones.",
		highlight: false,
		tier: "basic",
	},
	{
		name: "Equilibra tu energía",
		subtitle: "Pack Medio",
		price: 80,
		description:
			"Combina la parte educativa del Pack Básico con recursos prácticos que te ayudarán a aplicar lo aprendido en tu día a día.",
		features: [
			"Todo lo del Pack Básico",
			"Guía en PDF con recomendaciones de nutrición y movimiento",
			"Descargables prácticos (calendario del ciclo, hábitos...)",
			"Registro de síntomas personalizado",
		],
		ideal:
			"Quieres pasar de la teoría a la práctica y empezar a vivir en sintonía con tus ritmos naturales.",
		highlight: true,
		tier: "medium",
	},
	{
		name: "Vive en Sintonía",
		subtitle: "Pack Premium",
		price: 200,
		description:
			"Un acompañamiento completo para quienes quieren ir más allá. Aprenderás a escuchar tu cuerpo e integrar hábitos saludables.",
		features: [
			"Todo lo del Pack Medio",
			"Acompañamiento por WhatsApp durante 3 meses",
			"Sesión de revisión y ajustes a los 2 meses",
			"Sesión de consolidación y cierre a los 3 meses",
		],
		ideal:
			"Quieres un acompañamiento cercano y constante para integrar nuevos hábitos y reconectar profundamente con tu cuerpo.",
		highlight: false,
		tier: "premium",
	},
]

const preconceptionPacks = [
	{
		name: "Consulta Preconcepcional",
		subtitle: "Básica",
		price: 50,
		description: "Una consulta completa para preparar tu cuerpo y mente para la concepción.",
		features: [
			"Historia de salud y estilo de vida",
			"Valoración de salud general",
			"Suplementación y cuidados previos",
			"Ciclo menstrual y fertilidad",
			"Consejos para una concepción saludable",
			"Espacio para tus dudas y emociones",
		],
		ideal: "Quieres una valoración inicial antes de buscar el embarazo.",
		highlight: false,
		tier: "preconception",
	},
	{
		name: "Pack Preconcepcional",
		subtitle: "Completo",
		price: 220,
		description:
			"Acompañamiento integral para preparar tu cuerpo de forma consciente para la maternidad.",
		features: [
			"Teoría del ciclo menstrual + resolución de dudas",
			"Consulta preconcepcional completa",
			"Guía en PDF de nutrición, movimiento y estilo de vida",
			"Descargables prácticos",
			"Sesión de seguimiento al mes",
			"Sesión de seguimiento a los dos meses",
		],
		ideal: "Quieres una valoración inicial antes de buscar el embarazo.",
		highlight: false,
		tier: "preconception",
	},
]

const seoData = {
	title: "Salud Hormonal | Matrona en Valencia y Online | Femm tribu",
	description:
		"Aprende a escuchar tu cuerpo con María Belenguer. Asesoría en salud hormonal, nutrición y ciclo menstrual en Valencia y online. ¡Vive en sintonía contigo!",
	type: "website" as const,
}

const phoneNumber = import.meta.env.WHATSAPP_NUMBER
---

<Layout navScrolled={true} {...seoData}>
	<main class="pt-21">
		{/* Background decorations */}
		<div
			class="bg-secondary/15 shape-blob pointer-events-none absolute bottom-0 left-0 h-64 w-64 -translate-x-1/2 translate-y-1/2"
		>
		</div>
		<section class="container mx-auto mt-16 mb-16 px-4 lg:mb-24 lg:px-8">
			<div class="z-10 container mx-auto px-4 lg:px-8">
				<div class="mx-auto max-w-4xl text-center">
					<span
						class="bg-coral-light/30 text-primary mb-6 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm"
					>
						<img src="/images/icons/cookie.svg" alt="Icono de galleta" class="h-4 w-4" />
						Vive tu madurez con vitalidad y consciencia
					</span>
					<h1 class="font-display text-primary mb-6 text-4xl sm:text-5xl lg:text-6xl">
						Acompañamiento por tu Matrona en{" "}
						<span class="text-accent">Salud Hormonal</span>
					</h1>
					<p class="text-muted-foreground mx-auto max-w-3xl text-lg lg:text-xl">
						Un viaje de autoconocimiento para entender tus hormonas y vivir en equilibrio.
						Acompañamiento en Valencia y online para reconciliarte con tu ciclo menstrual y
						potenciar tu vitalidad.
						<span class="text-accent">Elige tu pack.</span>
					</p>
				</div>
			</div>
		</section>

		{/* Pricing Cards */}
		<section class="pb-24 lg:pb-32">
			<div class="container mx-auto px-4 lg:px-8">
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 lg:gap-6">
					{
						packs.map((pack) => (
							<Card
								class={`relative overflow-hidden transition-all duration-500 hover:-translate-y-2 ${
									pack.highlight
										? "border-accent ring-accent/20 shadow-lg ring-2"
										: "border-border/50 hover:border-accent/50 hover:shadow-warm"
								}`}
							>
								{pack.highlight && (
									<div class="bg-accent text-accent-foreground absolute top-0 right-0 left-0 py-2 text-center text-sm font-medium">
										Más popular
									</div>
								)}

								<CardHeader class={pack.highlight ? "pt-12" : ""}>
									<div class="mb-4">
										<CardTitle class="font-display text-primary mb-1 text-2xl">
											{pack.name}
										</CardTitle>
										<CardDescription class="text-accent text-base font-medium">
											{pack.subtitle}
										</CardDescription>
									</div>

									<div class="mb-4 flex items-baseline gap-1">
										<span class="font-display text-primary text-4xl">{pack.price}€</span>
									</div>

									<p class="text-muted-foreground text-sm leading-relaxed">{pack.description}</p>
								</CardHeader>

								<CardContent>
									{/* Features */}
									<div class="space-y-3">
										{pack.features.map((feature) => (
											<div class="flex items-start gap-3">
												<div class="bg-accent/20 mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full">
													<svg
														class="text-accent h-3 w-3"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="3"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<polyline points="20 6 9 17 4 12" />
													</svg>
												</div>
												<span class="text-muted-foreground text-sm">{feature}</span>
											</div>
										))}
									</div>
								</CardContent>

								<CardFooter class="flex-col gap-4">
									{/* Ideal for */}
									<div class="bg-muted/50 w-full rounded-xl p-4">
										<p class="text-sm">
											<span class="text-primary font-medium">Ideal para ti si: </span>
											<span class="text-muted-foreground">{pack.ideal}</span>
										</p>
									</div>
									{/* CTA Button */}
									<Button
										variant={pack.highlight ? "hero" : "outline"}
										class="w-full"
										size="lg"
										data-service-tier={pack.tier}
									>
										Reservar {pack.subtitle}
									</Button>
								</CardFooter>
							</Card>
						))
					}
				</div>
			</div>
		</section>

		<AdditionalInfo serviceName={serviceName} />
	</main>
</Layout>

<script define:vars={{ phoneNumber }}>
	document.addEventListener("DOMContentLoaded", () => {
		const buttons = document.querySelectorAll("button[data-service-tier]")

		buttons.forEach((button) => {
			button.addEventListener("click", () => {
				const tier = button.getAttribute("data-service-tier") || "basic"
				const message = encodeURIComponent(
					`Hola! Me interesa saber más sobre *${serviceName}* - *Pack ${tier.charAt(0).toUpperCase() + tier.slice(1)}* de *Femm tribu*.`
				)
				window.open(`https://wa.me/34${phoneNumber}?text=${message}`, "_blank")
			})
		})
	})
</script>

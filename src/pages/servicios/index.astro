---
import ServiceSchema from "@/components/schema/ServiceSchema.astro"
import AdditionalInfo from "@/components/sections/cta/AdditionalInfo.astro"
import Button from "@/components/ui/Button.astro"
import Eyebrow from "@/components/ui/Eyebrow.astro"
import OfferCard from "@/components/ui/OfferCard.astro"
import SectionHeading from "@/components/ui/SectionHeading.astro"
import ServiceMotif from "@/components/ui/ServiceMotif.astro"
import { STAGE } from "@/components/ui/stageColors"
import WhatsAppActions from "@/components/ui/WhatsAppActions.astro"
import { ADDON_SERVICES, CONSULTATION_PRICE, SERVICES } from "@/data/services"
import Layout from "@/layouts/Layout.astro"
import { getAssetUrl } from "@/services/directus"

export const prerender = true

const seoData = {
	title: "Servicios de Matrona en Valencia y Online | Femm tribu",
	description:
		"Consultas con matrona a 50€ en Valencia y online: lactancia, embarazo y parto, salud hormonal, preconcepción y menopausia. Pack Conoce tu Ciclo (120€) y FemmBarre prenatal (35€/mes).",
	type: "website" as const,
}

// Brand line-art motif per service (fallback shown until a real photo is set).
const ILU = "/images/icons/illustrations"
const serviceMotif: Record<string, string> = {
	"salud-hormonal": `${ILU}/ilustracion-negro_01.svg`,
	"preconcepcional": `${ILU}/ilustracion-negro_03.svg`,
	"preparacion-parto": `${ILU}/ilustracion-negro_07.svg`,
	"lactancia": `${ILU}/ilustracion-negro_05.svg`,
	"menopausia": `${ILU}/ilustracion-negro_14.svg`,
}
const cicloMotif = `${ILU}/ilustracion-negro_02.svg`
const femmbarreMotif = `${ILU}/ilustracion-negro_16.svg`
const pendientesMotif = `${ILU}/ilustracion-negro_09.svg`

// Real photos per service. Fill the path when available; the slot is reserved
// and meanwhile the brand illustration is shown.
//   e.g.  lactancia: "/images/servicios/lactancia.webp",
const servicePhoto: Record<string, string | undefined> = {
	"pendientes-bebe": getAssetUrl("63bc064b-c69f-47a3-aaac-fff5d110ce3f"),
}

type StageKey = "ciclo" | "embarazo" | "maternidad" | "menopausia"

interface ConsultationGroup {
	id: StageKey
	label: string
	title: string
	subtitle: string
	color: "terracotta" | "coral" | "sage" | "forest"
	services: Array<{
		id: string
		name: string
		nameShort: string
		description: string
		url: string
		badge?: { label: string; image: string }
	}>
}

const consultationGroups: ConsultationGroup[] = [
	{
		id: "ciclo",
		label: "Ciclo y hormonas",
		title: "Entiende tu ciclo y tu salud hormonal",
		subtitle:
			"Desde el dolor menstrual hasta la preparación preconcepcional: consultas para conocer tu cuerpo y tomar decisiones informadas.",
		color: "terracotta",
		services: [
			{
				id: SERVICES.saludHormonal.id,
				name: SERVICES.saludHormonal.name,
				nameShort: SERVICES.saludHormonal.nameShort,
				description:
					"Dolor menstrual, SPM, ciclos irregulares o desajustes hormonales. Identifica las fases del ciclo y trabaja hábitos que mejoran tu bienestar hormonal.",
				url: SERVICES.saludHormonal.url,
			},
			{
				id: SERVICES.preconcepcional.id,
				name: SERVICES.preconcepcional.name,
				nameShort: SERVICES.preconcepcional.nameShort,
				description:
					"Para mujeres y parejas que quieren preparar el embarazo de forma consciente. Revisamos ciclo, ovulación, nutrición y suplementación básica.",
				url: SERVICES.preconcepcional.url,
			},
		],
	},
	{
		id: "embarazo",
		label: "Embarazo y parto",
		title: "Prepárate para tu parto con matrona",
		subtitle:
			"Resolvemos dudas sobre embarazo, parto y posparto con información basada en evidencia y acompañamiento emocional.",
		color: "coral",
		services: [
			{
				id: SERVICES.preparacionParto.id,
				name: "Sesión de dudas: Embarazo y Parto",
				nameShort: SERVICES.preparacionParto.nameShort,
				description:
					"Cambios del embarazo, preparación al parto, plan de parto, intervenciones médicas, gestión del miedo, posparto inmediato y lactancia inicial. ¿Prefieres preparación en grupo? Consulta disponibilidad por WhatsApp.",
				url: SERVICES.preparacionParto.url,
			},
		],
	},
	{
		id: "maternidad",
		label: "Maternidad y lactancia",
		title: "Lactancia y acompañamiento posparto",
		subtitle:
			"Acompañamiento individual para resolver cualquier dificultad con la lactancia materna, desde el inicio hasta el destete respetuoso.",
		color: "sage",
		services: [
			{
				id: SERVICES.lactancia.id,
				name: SERVICES.lactancia.name,
				nameShort: SERVICES.lactancia.nameShort,
				description:
					"Agarre, dolor, grietas, producción de leche, uso de sacaleches, lactancia mixta o diferida, vuelta al trabajo y destete respetuoso.",
				url: SERVICES.lactancia.url,
				badge: {
					label: "Laura Jorge",
					image: "/images/logos/laura-jorge/laura-jorge-icon.png",
				},
			},
		],
	},
	{
		id: "menopausia",
		label: "Menopausia",
		title: "Acompañamiento en perimenopausia y menopausia",
		subtitle:
			"Comprende los cambios del cuerpo y mejora tu calidad de vida desde un enfoque natural, cercano y basado en evidencia.",
		color: "forest",
		services: [
			{
				id: SERVICES.menopausia.id,
				name: SERVICES.menopausia.name,
				nameShort: SERVICES.menopausia.nameShort,
				description:
					"Sofocos, alteraciones del sueño, cambios emocionales, sequedad vaginal, salud ósea y hábitos de autocuidado.",
				url: SERVICES.menopausia.url,
			},
		],
	},
]

const cicloPackFeatures = [
	"Seguimiento personalizado",
	"Sesiones individuales",
	"Educación de cada fase",
	"Recomendaciones a medida",
]
const femmbarreFeatures = [
	"1 clase semanal en directo",
	"Acceso a grabaciones",
	"Guiado por matrona profesional",
	"Adaptado a cada trimestre",
]

const ciclosPack = SERVICES.conoceTuCiclo
const femmbarre = SERVICES.femmbarre
const pendientes = ADDON_SERVICES.pendientesBebe

// Flat list of every consultation, to emit one Service schema each.
const consultationSchemas = consultationGroups
	.flatMap((g) => g.services)
	.map((s) => ({
		name: SERVICES[s.id.replace(/-([a-z])/g, (_, c) => c.toUpperCase())]?.name ?? s.name,
		description:
			SERVICES[s.id.replace(/-([a-z])/g, (_, c) => c.toUpperCase())]?.description ?? s.description,
		serviceType:
			SERVICES[s.id.replace(/-([a-z])/g, (_, c) => c.toUpperCase())]?.serviceType ?? s.nameShort,
	}))

const anchors = [
	{ href: "#consultas", label: "Consultas" },
	{ href: "#packs", label: "Packs" },
	{ href: "#suscripcion", label: "Suscripción" },
	{ href: "#puntuales", label: "Servicios puntuales" },
]
---

<Layout navScrolled={true} {...seoData}>
	{/* SEO schemas — one Service per consultation + pack + subscription + addon */}
	{
		consultationSchemas.map((s) => (
			<ServiceSchema
				name={s.name}
				description={s.description}
				priceMin={CONSULTATION_PRICE}
				priceMax={CONSULTATION_PRICE}
				serviceType={s.serviceType}
			/>
		))
	}
	<ServiceSchema
		name={ciclosPack.name}
		description={ciclosPack.description}
		priceMin={ciclosPack.priceMin}
		priceMax={ciclosPack.priceMax}
		serviceType={ciclosPack.serviceType}
		url={ciclosPack.url}
	/>
	<ServiceSchema
		name={femmbarre.name}
		description={femmbarre.description}
		serviceType={femmbarre.serviceType}
		priceMin={femmbarre.priceMin}
		isSubscription={true}
		billingPeriod="month"
		onlineOnly={true}
		url={femmbarre.url}
	/>
	<ServiceSchema
		name={pendientes.name}
		description={pendientes.description}
		priceMin={pendientes.priceMin}
		priceMax={pendientes.priceMax}
		serviceType={pendientes.serviceType}
	/>

	<main id="main-content" class="pt-21">
		{/* Hero */}
		<section class="container mx-auto mt-16 mb-8 px-4 lg:mb-16 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<Eyebrow class="bg-coral-light/30 text-primary mb-6" animate>Servicios</Eyebrow>
				<h1
					class="font-display text-primary mb-6 text-4xl sm:text-5xl lg:text-6xl"
					data-animate="animate-fade-up"
					data-animate-duration="1s"
					data-animate-delay="0.1s"
				>
					Servicios de <span class="text-accent">matrona</span> en Valencia y online
				</h1>
				<p
					class="text-muted-foreground mx-auto max-w-2xl text-lg lg:text-xl"
					data-animate="animate-fade-up"
					data-animate-duration="1s"
					data-animate-delay="0.2s"
				>
					Consultas individuales a {CONSULTATION_PRICE}€ · Pack Conoce tu Ciclo de 3 meses ·
					FemmBarre prenatal · Servicios puntuales. Elige lo que necesites para cada etapa de tu
					vida.
				</p>

				{/* Quick-jump anchors */}
				<div
					class="mt-8 flex flex-wrap justify-center gap-3"
					data-animate="animate-fade-up"
					data-animate-duration="1s"
					data-animate-delay="0.3s"
				>
					{
						anchors.map((a) => (
							<a
								href={a.href}
								class="border-border/50 text-muted-foreground hover:border-accent/50 hover:text-accent rounded-full border px-4 py-2 text-sm transition-colors"
							>
								{a.label}
							</a>
						))
					}
				</div>
			</div>
		</section>

		{/* Consultations grouped by life stage */}
		<section id="consultas" class="scroll-mt-24 py-16 lg:py-20">
			<div class="container mx-auto px-4 lg:px-8">
				<SectionHeading
					class="mb-12"
					color="sage"
					label={`Consultas individuales · ${CONSULTATION_PRICE}€ · 60 min`}
					title="Elige la consulta que necesitas ahora"
					subtitle="Todas las consultas duran 60 minutos y son personalizadas. Puedes realizarlas online o presencial en Valencia."
				/>

				<div class="mx-auto max-w-6xl space-y-12 lg:space-y-16">
					{
						consultationGroups.map((group) => {
							const c = STAGE[group.color]
							return (
								<div
									id={group.id}
									class="scroll-mt-24"
									data-animate="animate-fade-up"
									data-animate-duration="1s"
								>
									{/* Group header */}
									<div class="border-border/30 mb-6 flex flex-col gap-2 border-b pb-4 lg:flex-row lg:items-end lg:justify-between">
										<div>
											<span
												class:list={[
													"mb-2 inline-block rounded-full px-3 py-1 text-xs font-medium tracking-wider uppercase",
													c.chip,
												]}
											>
												{group.label}
											</span>
											<h3 class="font-display text-primary text-2xl lg:text-3xl">{group.title}</h3>
										</div>
										<p class="text-muted-foreground max-w-md text-sm lg:text-right">
											{group.subtitle}
										</p>
									</div>

									{/* Service cards */}
									<div
										class:list={[
											"grid gap-6",
											group.services.length > 1 ? "md:grid-cols-2" : "md:grid-cols-1",
										]}
									>
										{group.services.map((service, index) => (
											<article
												id={service.id}
												class:list={[
													"group bg-background hover:shadow-elegant relative scroll-mt-24 overflow-hidden rounded-3xl border-2 transition-all duration-300",
													c.border,
													c.hover,
												]}
												data-animate="animate-fade-up"
												data-animate-duration="1s"
												data-animate-delay={`${index * 80}ms`}
											>
												<div class="flex flex-col sm:flex-row">
													{/* Visual — real photo if set, else brand motif */}
													<ServiceMotif
														motif={serviceMotif[service.id] ?? cicloMotif}
														image={servicePhoto[service.id]}
														imageAlt={service.name}
														color={group.color}
														class="h-40 w-full sm:h-auto sm:w-44 sm:flex-shrink-0"
													/>

													<div class="flex flex-1 flex-col p-6 lg:p-8">
														{service.badge && (
															<div class="mb-4 flex items-center gap-2">
																<img
																	src={service.badge.image}
																	alt={service.badge.label}
																	loading="lazy"
																	class="h-7 w-auto flex-shrink-0 object-contain"
																/>
																<span class="text-muted-foreground text-xs">
																	En colaboración con {service.badge.label}
																</span>
															</div>
														)}

														<a href={service.url} class="group/link block">
															<h4 class="font-display text-forest group-hover/link:text-accent mb-2 text-xl transition-colors lg:text-2xl">
																{service.name}
															</h4>
														</a>
														<p class="text-muted-foreground mb-5 flex-1 text-sm leading-relaxed">
															{service.description}
														</p>

														<div class="border-border/30 flex items-center justify-between gap-3 border-t pt-4">
															<div class="flex flex-col">
																<span class="font-display text-primary text-xl">
																	{CONSULTATION_PRICE}€
																</span>
																<span class="text-muted-foreground text-xs">
																	60 min · Online o presencial
																</span>
															</div>
															<Button
																href={service.url}
																variant="hero"
																size="sm"
																class="rounded-full text-sm transition-all duration-300 hover:scale-105"
															>
																Ver detalle
															</Button>
														</div>
													</div>
												</div>
											</article>
										))}
									</div>

									{/* Group banner: birth-prep group */}
									{group.id === "embarazo" && (
										<div
											class:list={[
												"mt-6 rounded-2xl border-2 border-dashed p-5 lg:flex lg:items-center lg:justify-between lg:gap-6",
												c.border,
												c.soft,
											]}
										>
											<div class="mb-3 lg:mb-0">
												<p class="font-display text-primary text-lg">
													¿Prefieres preparación al parto en grupo?
												</p>
												<p class="text-muted-foreground text-sm">
													Organizamos programas grupales puntuales. Consulta disponibilidad por
													WhatsApp.
												</p>
											</div>
											<Button
												variant="hero"
												size="sm"
												class="rounded-full text-sm transition-all duration-300 hover:scale-105"
												data-whatsapp-inquiry="Programa grupal de preparación al parto"
											>
												Consultar disponibilidad
											</Button>
										</div>
									)}
								</div>
							)
						})
					}
				</div>
			</div>
		</section>

		<div class="container mx-auto px-4 lg:px-8">
			<div class="border-border/30 mx-auto max-w-xs border-t"></div>
		</div>

		{/* Pack */}
		<section id="packs" class="scroll-mt-24 py-16 lg:py-20">
			<div class="container mx-auto px-4 lg:px-8">
				<SectionHeading
					color="terracotta"
					label="Pack de acompañamiento"
					title="Acompañamientos profundos"
					subtitle="Para quienes quieren ir más allá de una consulta puntual."
				/>
				<div class="mx-auto max-w-3xl" data-animate="animate-fade-up" data-animate-duration="1s">
					<OfferCard
						href={ciclosPack.url}
						title={ciclosPack.name}
						subtitle="Aprende a entender, observar y conectar con tu ciclo menstrual."
						body="Durante 3 meses trabajamos juntas para que interpretes tu ciclo con seguridad, anticipes lo que necesitas en cada fase y tomes decisiones alineadas con tu cuerpo."
						features={cicloPackFeatures}
						price={ciclosPack.priceMin}
						priceSuffix=" · 3 meses"
						ctaLabel="Ver el pack"
						badge="3 meses · Online"
						color="terracotta"
						motif={cicloMotif}
						image={servicePhoto["conoce-tu-ciclo"]}
						imageAlt={ciclosPack.name}
					/>
				</div>
			</div>
		</section>

		<div class="container mx-auto px-4 lg:px-8">
			<div class="border-border/30 mx-auto max-w-xs border-t"></div>
		</div>

		{/* Subscription — FemmBarre */}
		<section id="suscripcion" class="scroll-mt-24 py-16 lg:py-20">
			<div class="container mx-auto px-4 lg:px-8">
				<SectionHeading
					color="accent"
					label="Suscripción mensual"
					title="Bienestar y movimiento"
					subtitle="Clases online diseñadas para cada etapa del embarazo."
				/>
				<div class="mx-auto max-w-3xl" data-animate="animate-fade-up" data-animate-duration="1s">
					<OfferCard
						href={femmbarre.url}
						title={femmbarre.name}
						subtitle="Barre prenatal para embarazadas"
						body="Clases de barre adaptadas al embarazo, guiadas por matrona. Online desde cualquier sitio, a tu ritmo y con total seguridad."
						features={femmbarreFeatures}
						price={femmbarre.priceMin}
						priceSuffix="/mes"
						ctaLabel="Descubre FemmBarre"
						badge="Suscripción mensual"
						color="accent"
						motif={femmbarreMotif}
						image={getAssetUrl("434e8c6a-e85f-4c33-a049-298dd53bedcd")}
						imageAlt="FemmBarre Maternity — Barre prenatal para embarazadas"
					/>
				</div>
			</div>
		</section>

		<div class="container mx-auto px-4 lg:px-8">
			<div class="border-border/30 mx-auto max-w-xs border-t"></div>
		</div>

		{/* One-off services */}
		<section id="puntuales" class="scroll-mt-24 py-16 lg:py-20">
			<div class="container mx-auto px-4 lg:px-8">
				<SectionHeading
					labelClass="bg-coral-light/30 text-primary"
					label="Servicios puntuales"
					title="¿Necesitas algo puntual?"
					subtitle="Servicios individuales que puedes reservar de forma independiente."
				/>

				<div class="mx-auto max-w-3xl">
					<div
						class="bg-background border-border/50 hover:border-accent/30 hover:shadow-elegant group flex flex-col items-center gap-8 rounded-3xl border-2 p-8 transition-all duration-300 lg:flex-row"
						data-animate="animate-fade-up"
						data-animate-duration="1s"
					>
						<div class="relative h-40 w-40 flex-shrink-0 overflow-hidden rounded-2xl">
							<ServiceMotif
								motif={pendientesMotif}
								image={servicePhoto["pendientes-bebe"]}
								imageAlt={pendientes.name}
								color="coral"
								class="h-full w-full"
							/>
							<div
								class="from-forest-dark/85 via-forest-dark/25 absolute right-0 bottom-0 left-0 bg-gradient-to-t to-transparent p-2 text-center"
							>
								<span class="font-display text-cream block text-2xl">{pendientes.price}€</span>
								<span class="text-cream/80 text-xs">por sesión</span>
							</div>
						</div>

						<div class="flex-1 text-center lg:text-left">
							<p class="text-accent mb-1 text-xs font-medium tracking-wider uppercase">
								{pendientes.nameShort}
							</p>
							<h3 class="font-display text-primary mb-3 text-xl lg:text-2xl">
								Colocación de pendientes para tu bebé por profesional sanitario
							</h3>
							<p class="text-muted-foreground mb-4 text-sm leading-relaxed">
								Servicio realizado por una matrona profesional, en un entorno higiénico y con
								materiales hipoalergénicos certificados.
							</p>
							<ul class="mb-5 space-y-1.5">
								{
									pendientes.features.map((feature: string) => (
										<li class="text-muted-foreground flex items-center justify-center gap-2 text-sm lg:justify-start">
											<span class="text-accent">—</span>
											{feature}
										</li>
									))
								}
							</ul>
							<Button
								variant="hero"
								size="sm"
								class="rounded-full text-sm transition-all duration-300 hover:scale-105"
								data-service-name={pendientes.name}
							>
								Reservar {pendientes.nameShort}
							</Button>
						</div>
					</div>
				</div>
			</div>
		</section>

		<div class="container mx-auto px-4 lg:px-8">
			<div class="border-border/30 mx-auto max-w-xs border-t"></div>
		</div>

		<AdditionalInfo serviceName="Servicios" />
	</main>
</Layout>

<WhatsAppActions />

<script is:inline>
	// Smooth-scroll to the quick-jump target when arriving with a hash.
	document.addEventListener("DOMContentLoaded", () => {
		if (window.location.hash) {
			setTimeout(() => {
				document
					.querySelector(window.location.hash)
					?.scrollIntoView({ behavior: "smooth", block: "start" })
			}, 100)
		}
	})
</script>

{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@auth": ["./src/lib/auth"],
      "@auth/*": ["./src/lib/auth/*"],
      "@events": ["./src/lib/events"],
      "@events/*": ["./src/lib/events/*"],
      "@videos": ["./src/lib/videos"],
      "@videos/*": ["./src/lib/videos/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}

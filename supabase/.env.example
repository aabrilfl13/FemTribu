############
# Secrets
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############

# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

############
# URLs
############

# The base URL of your website (where users will be redirected after auth)
# Local development: http://localhost:4321
# Production: https://yourdomain.com
SITE_URL=http://localhost:4321

# Comma-separated list of allowed redirect URLs after authentication
ADDITIONAL_REDIRECT_URLS=http://localhost:4321,http://127.0.0.1:4321

# The URL where your auth service is accessible (for self-hosted only, not needed for local dev)
# API_EXTERNAL_URL=http://192.168.1.100:9999

############
# Auth
############

# How long JWT tokens are valid (in seconds). Default: 3600 (1 hour)
# JWT_EXPIRY=3600

############
# Google OAuth
############

SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
# For local dev: http://127.0.0.1:4321/auth/v1/callback
# For remote: https://your-project.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=http://127.0.0.1:4321/auth/v1/callback
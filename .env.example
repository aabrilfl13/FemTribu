# ==========================================
# ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Copy .env.local.example → .env.local and fill in your values
# Most of these are gitignored secrets

# Public Variables (safe to expose to client)
PUBLIC_GA_ID=
PUBLIC_WHATSAPP_NUMBER=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Webhook Configuration (secrets)
WEBHOOK_URL=
WEBHOOK_AUTH_TOKEN=
WEBHOOK_NEWSLETTER_AUTH_TOKEN=

# Social Media URLs (non-sensitive)
CALENDLY_URL=
WHATSAPP_COMMUNITY_URL=
WHATSAPP_NUMBER=
INSTRAGRAM_URL=
TIKTOK_URL=

# Admin Credentials (secrets)
ADMIN_USERNAME=
ADMIN_PASSWORD=
SECRET_KEY=

# Directus CMS (secrets)
DIRECTUS_URL=
DIRECTUS_TOKEN=

# Supabase (secrets - server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud (secrets)
GOOGLE_CLOUD_PROJECT=
STITCH_ACCESS_TOKEN=

# Video Provider Configuration
# Specify which video provider to use:
#   - "mock": Use mock videos (no external service needed, 8 pre-configured videos)
#   - "bunny": Use Bunny Stream (requires BUNNY_STREAM_* credentials below)
#   - "cloudflare": Use Cloudflare Stream (requires CLOUDFLARE_* credentials below)
# If not set, defaults to "mock"
VIDEOS_PROVIDER=mock

# Bunny Stream Configuration (only needed if VIDEOS_PROVIDER=bunny)
BUNNY_STREAM_LIBRARY_ID=  
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=  # Optional, defaults to iframe.mediadelivery.net


# Environment
ENV=development
DEBUG=false
